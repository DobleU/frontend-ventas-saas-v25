@* Shared/NavMenu.razor *@
@inject PermisoClienteService Permisos
@inject AppState Estado
@inject NavigationManager Nav
@implements IDisposable

<div class="primary-menu">
    <nav class="navbar navbar-expand-xl align-items-center container-xxl px-4">
        <div class="offcanvas offcanvas-start offcanvas-xl w-260" tabindex="-1"
             id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
            <div class="offcanvas-header border-bottom h-70">
                <div class="d-flex align-items-center gap-2">
                    <span class="material-icons-outlined text-primary" style="font-size:2rem;">store</span>
                    <div>
                        <h4 class="logo-text mb-0">Integra*System</h4>
                        <small class="text-muted d-block" style="font-size:.68rem;line-height:1;">CRM &middot; POS &middot; ROUTE &middot; ERP OPE</small>
                    </div>
                </div>
                <a href="javascript:;" class="primaery-menu-close" data-bs-dismiss="offcanvas">
                    <i class="material-icons-outlined">close</i>
                </a>
            </div>
            <div class="offcanvas-body p-0">
                <ul class="navbar-nav align-items-start">
                    @MenuCompleto()
                </ul>
            </div>
        </div>
    </nav>
</div>

@code {
    private string _ruta = string.Empty;

    protected override void OnInitialized()
    {
        Estado.OnChange += StateHasChanged;
        _ruta = Nav.ToBaseRelativePath(Nav.Uri);
        Nav.LocationChanged += OnNav;
    }

    private void OnNav(object? s, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ruta = Nav.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        Estado.OnChange -= StateHasChanged;
        Nav.LocationChanged -= OnNav;
    }

    private bool Activo(string ruta) =>
        _ruta.StartsWith(ruta.TrimStart('/'), StringComparison.OrdinalIgnoreCase);

    private bool TienePermiso(params string[] modulos) =>
        modulos.Any(m => Permisos.TieneAlgunoEn(m));

    RenderFragment MenuCompleto() => @<text>
        <li class="nav-item">
            <NavLink class="nav-link d-flex align-items-center gap-1" href="/dashboard" Match="NavLinkMatch.All">
                <i class="material-icons-outlined fs-5">home</i>
                <span>Inicio</span>
            </NavLink>
        </li>

        <li class="nav-item dropdown" data-menu-id="monitor">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/monitor") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('monitor')">
                <i class="material-icons-outlined fs-5">sensors</i>
                <span>Monitor</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/monitor/mapa", "map", "Mapa General")</li>
                <li>@Item("/monitor/rutas", "monitoring", "Monitor Recorrido")</li>
                <li>@Item("/monitor/clientes", "groups", "Monitor Clientes")</li>
                <li>@Item("/monitor/pos", "point_of_sale", "Monitor POS")</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="crm">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/crm") || Activo("/catalogos/clientes") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('crm')">
                <i class="material-icons-outlined fs-5">support_agent</i>
                <span>CRM</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/catalogos/clientes", "people", "Clientes")</li>
                <li>@Item("/crm/prospectos", "person_add", "Prospectos")</li>
                <li>@Item("/crm/seguimiento-comercial", "event_note", "Seguimiento Comercial")</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="pos">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/pos") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('pos')">
                <i class="material-icons-outlined fs-5">point_of_sale</i>
                <span>POS</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/pos/ventas", "shopping_cart", "Ventas POS")</li>
                <li>@Item("/pos/caja", "payments", "Caja")</li>
                <li>@Item("/pos/tickets", "receipt_long", "Reimpresión de Ticket")</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="route">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/route") || Activo("/ventas/ruta") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('route')">
                <i class="material-icons-outlined fs-5">route</i>
                <span>ROUTE</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/ventas/ruta/recorridos", "directions_car", "Recorridos")</li>
                <li>@Item("/ventas/ruta/visitas", "location_on", "Visitas")</li>
                <li>@Item("/ventas/ruta/eventos", "notifications", "Eventos")</li>
                <li>@Item("/route/clientes-ruta", "groups", "Clientes por Ruta")</li>
                <li>@Item("/route/planeacion-visitas", "calendar_month", "Planeación de Visitas")</li>
                <li>@Item("/route/liquidacion-ruta", "task_alt", "Liquidación de Ruta")</li>
                <li>@Item("/route/escenarios-comerciales", "forum", "Escenarios Comerciales")</li>
                <li>@Item("/route/sincronizacion-app", "sync", "Sincronización App")</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="erp">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/erp") || Activo("/ia-comercial") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('erp')">
                <i class="material-icons-outlined fs-5">business_center</i>
                <span>ERP</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/erp/compras", "shopping_bag", "Compras")</li>
                <li>@Item("/erp/promociones-campanas", "campaign", "Promociones y Campañas")</li>
                <li>@Item("/erp/rh", "badge", "RH")</li>
                <li>@Item("/ia-comercial/respuestas-vendedores", "record_voice_over", "Respuestas para Vendedores")</li>
                <li>@Item("/erp/proveedores", "local_shipping", "Proveedores")</li>
                <li>@Item("/erp/ordenes-compra", "assignment", "Órdenes de Compra")</li>
                <li>@Item("/erp/recepcion-mercancia", "inventory_2", "Recepción de Mercancía")</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="core">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/core") || Activo("/catalogos") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('core')">
                <i class="material-icons-outlined fs-5">dataset</i>
                <span>CORE</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/core/empresas", "domain", "Empresa")</li>
                <li>@Item("/core/sucursales", "store", "Sucursales")</li>
                <li>@Item("/core/zonas", "map", "Zonas")</li>
                <li>@Item("/core/rutas", "route", "Rutas")</li>
                <li>@Item("/core/productos", "inventory_2", "Productos", pronto: true)</li>
                <li>@Item("/core/precios", "sell", "Precios", pronto: true)</li>
                <li>@Item("/core/marcas", "branding_watermark", "Marcas", pronto: true)</li>
                <li>@Item("/core/presentaciones", "widgets", "Presentaciones", pronto: true)</li>
                <li>@Item("/core/monedas", "currency_exchange", "Monedas")</li>
                <li>@Item("/core/series-documento", "tag", "Series de Documento")</li>
                <li>@Item("/core/parametros", "tune", "Parámetros")</li>
                <li>@Item("/catalogos/catalogo-tipos", "category", "Catálogos Tipo", pronto: true)</li>
                <li>@Item("/catalogos/catalogo-items", "list", "Catálogos Item", pronto: true)</li>
                <li>@Item("/catalogos/clasificaciones", "account_tree", "Clasificaciones", pronto: true)</li>
                <li>@Item("/catalogos/unidades", "straighten", "Unidades", pronto: true)</li>
                <li>@Item("/catalogos/impuestos", "receipt_long", "Impuestos", pronto: true)</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="inventarios">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/almacen") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('inventarios')">
                <i class="material-icons-outlined fs-5">warehouse</i>
                <span>INV</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/almacen/almacenes", "warehouse", "Almacenes")</li>
                <li>@Item("/almacen/vehiculos", "local_shipping", "Vehículos")</li>
                <li>@Item("/reportes/inventario/movimientos", "swap_vert", "Movimientos")</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="finanzas">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/finanzas") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('finanzas')">
                <i class="material-icons-outlined fs-5">attach_money</i>
                <span>FIN</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/finanzas/cxc", "account_balance_wallet", "Cuentas por Cobrar")</li>
                <li>@Item("/finanzas/cxp", "money_off", "Cuentas por Pagar")</li>
                <li>@Item("/finanzas/bancos", "account_balance", "Bancos")</li>
                <li>@Item("/finanzas/conciliacion", "balance", "Conciliación")</li>
                <li>@Item("/finanzas/reportes-financieros", "query_stats", "Reportes Financieros")</li>
                <li>@Item("/facturacion/ventas", "receipt_long", "Facturación de Ventas")</li>
                <li>@Item("/facturacion/global", "description", "Facturación Global")</li>
                <li>@Item("/facturacion/cancelaciones", "block", "Cancelaciones")</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="reportes">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/reportes") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('reportes')">
                <i class="material-icons-outlined fs-5">bar_chart</i>
                <span>REP</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/reportes/ventas", "trending_up", "Ventas")</li>
                <li>@Item("/reportes/clientes", "people", "Clientes")</li>
                <li>@Item("/reportes/ruta", "route", "Reportes de Ruta")</li>
                <li>@Item("/reportes/inventario/movimientos", "inventory", "Movimientos de Almacén")</li>
                <li>@Item("/reportes/utilidad-margen", "monitoring", "Utilidad y Margen")</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="admin">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/seguridad") || Activo("/auditoria") || Activo("/suscripcion") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('admin')">
                <i class="material-icons-outlined fs-5">admin_panel_settings</i>
                <span>ADM</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/seguridad/empleados", "badge", "Empleados")</li>
                <li>@Item("/seguridad/usuarios", "manage_accounts", "Usuarios")</li>
                <li>@Item("/seguridad/permisos", "fact_check", "Permisos", pronto: true)</li>
                <li>@Item("/seguridad/roles", "shield", "Roles", pronto: true)</li>
                <li>@Item("/admin/dispositivos-moviles", "devices", "Dispositivos Móviles")</li>
                <li>@Item("/seguridad/sesiones", "sensors", "Sesiones", pronto: true)</li>
                <li>@Item("/admin/auditoria", "history", "Auditoría")</li>
                <li>@Item("/admin/bitacora-errores", "bug_report", "Bitácora de Errores")</li>
                <li>@Item("/suscripcion", "workspace_premium", "Suscripción")</li>
            </ul>
        </li>

        <li class="nav-item dropdown" data-menu-id="config">
            <a class="nav-link d-flex align-items-center gap-1 @(Activo("/config") ? "active" : "")"
               href="javascript:;" onclick="NavMenu.toggle('config')">
                <i class="material-icons-outlined fs-5">settings</i>
                <span>CONF</span>
                <i class="material-icons-outlined fs-6 ms-1">expand_more</i>
            </a>
            <ul class="dropdown-menu">
                <li>@Item("/config/datos-empresa", "domain", "Datos de Empresa")</li>
                <li>@Item("/config/parametros-generales", "tune", "Parámetros Generales")</li>
                <li>@Item("/config/parametros-venta", "point_of_sale", "Parámetros de Venta")</li>
                <li>@Item("/config/parametros-ruta", "route", "Parámetros de Ruta")</li>
                <li>@Item("/config/parametros-inventario", "inventory", "Parámetros de Inventario")</li>
                <li>@Item("/config/parametros-credito", "credit_score", "Parámetros de Crédito")</li>
                <li>@Item("/config/parametros-facturacion", "receipt_long", "Parámetros de Facturación")</li>
                <li>@Item("/config/reglas-comerciales", "rule", "Reglas Comerciales")</li>
                <li>@Item("/config/alertas-sistema", "warning", "Alertas del Sistema")</li>
                <li>@Item("/config/app-movil", "phone_android", "Configuración App Móvil")</li>
                <li>@Item("/config/app/dispositivos", "phone_android", "Dispositivos App")</li>
                <li>@Item("/config/pos/dispositivos", "computer", "Dispositivos POS")</li>
                <li>@Item("/config/audio", "graphic_eq", "Configuración de Audio")</li>
                <li>@Item("/config/ia", "psychology", "Configuración de IA")</li>
                <li>@Item("/config/catalogos-generales", "category", "Catálogos Generales")</li>
            </ul>
        </li>
    </text>;

    RenderFragment Item(string href, string icon, string label, bool pronto = false) =>
        @<a class="dropdown-item nav-dropdown-item @(pronto ? "disabled text-muted" : "") @(Activo(href) ? "active" : "")"
            href="@(pronto ? "javascript:;" : href)">
            <i class="material-icons-outlined nav-dropdown-icon">@icon</i>
            <span class="nav-dropdown-label">@(new MarkupString(label))</span>
            @if (pronto) { <span class="badge bg-secondary ms-auto" style="font-size:9px;">Pronto</span> }
        </a>;
}

<style>
    .primary-menu .dropdown-menu {
        width: max-content;
        min-width: 240px;
        max-width: 360px;
    }

    .primary-menu .nav-dropdown-item {
        display: flex;
        align-items: center;
        gap: .75rem;
        white-space: nowrap;
        padding-right: 1rem;
    }

    .primary-menu .nav-dropdown-icon {
        width: 18px;
        min-width: 18px;
        text-align: center;
        font-size: 16px;
        flex: 0 0 18px;
    }

    .primary-menu .nav-dropdown-label {
        flex: 0 1 auto;
    }
</style>
