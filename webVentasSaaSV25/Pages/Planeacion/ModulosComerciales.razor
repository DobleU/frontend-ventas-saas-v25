<style>
    .module-shell{display:grid;gap:1rem;padding-bottom:2rem}
    .module-hero,.module-actions,.module-grid,.panel-head,.timeline-item{display:flex}
    .module-hero,.panel-head{align-items:flex-start;justify-content:space-between;gap:1rem}
    .module-hero h3,.panel-head h5{margin:0;font-weight:800;color:#344054}
    .module-hero p,.panel-head small{margin:.25rem 0 0;color:#667085}
    .module-kicker{display:inline-flex;padding:.3rem .65rem;border-radius:999px;background:#eef5ff;color:#0d6efd;font-size:.78rem;font-weight:700;margin-bottom:.6rem}
    .module-actions{gap:.5rem;flex-wrap:wrap}
    .module-kpis{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.75rem}
    .kpi-card,.panel-card{background:#fff;border:1px solid #e6eaf0;border-radius:12px;box-shadow:0 4px 18px rgba(18,38,63,.05)}
    .kpi-card{padding:1rem}
    .kpi-card span,.kpi-card small{display:block;color:#667085}
    .kpi-card strong{display:block;font-size:1.4rem;color:#344054}
    .module-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:1rem}
    .panel-card{padding:1rem}
    .timeline-list{display:grid;gap:.9rem}
    .timeline-item{gap:.75rem;align-items:flex-start}
    .timeline-dot{width:12px;height:12px;border-radius:50%;background:#0d6efd;flex:0 0 auto;margin-top:.28rem}
    .timeline-item strong,.timeline-item small{display:block}
    .timeline-item small{color:#667085}
    @@media (max-width:1199.98px){.module-kpis{grid-template-columns:repeat(2,minmax(0,1fr))}.module-grid{grid-template-columns:1fr}}
    @@media (max-width:767.98px){.module-kpis{grid-template-columns:1fr}.module-hero{flex-direction:column}}
</style>
