@inject NavigationManager Nav

<PageTitle>@PageTitleText - Integra*System</PageTitle>

<section class="module-shell">
    <header class="module-hero">
        <div>
            <span class="module-kicker">@ModuleArea</span>
            <h3>@Title</h3>
            <p>@Description</p>
        </div>
        <div class="module-actions">
            <button class="btn btn-primary" type="button">@PrimaryAction</button>
            <button class="btn btn-outline-secondary" type="button">Exportar</button>
            <button class="btn btn-outline-secondary" type="button">Actualizar</button>
        </div>
    </header>

    <section class="module-kpis">
        @foreach (var kpi in Kpis)
        {
            <article class="kpi-card">
                <span>@kpi.Label</span>
                <strong>@kpi.Value</strong>
                <small>@kpi.Note</small>
            </article>
        }
    </section>

    <section class="module-grid">
        <article class="panel-card">
            <div class="panel-head">
                <div>
                    <h5>Filtros y captura</h5>
                    <small>Vista semirreal lista para enlazar backend.</small>
                </div>
            </div>

            <div class="row g-3">
                @foreach (var field in Fields)
                {
                    <div class="col-12 col-md-6">
                        <label class="form-label">@field</label>
                        <input class="form-control" placeholder="@($"Capturar {field.ToLowerInvariant()}")" />
                    </div>
                }
            </div>

            <div class="row g-3 mt-1">
                <div class="col-12">
                    <label class="form-label">Observaciones</label>
                    <textarea class="form-control" rows="4" placeholder="Notas internas, acuerdos, comentarios o contexto operativo."></textarea>
                </div>
            </div>
        </article>

        <article class="panel-card">
            <div class="panel-head">
                <div>
                    <h5>Flujo sugerido</h5>
                    <small>Basado en el documento anexo.</small>
                </div>
            </div>

            <div class="timeline-list">
                @foreach (var step in Steps)
                {
                    <div class="timeline-item">
                        <span class="timeline-dot"></span>
                        <div>
                            <strong>@step.Title</strong>
                            <small>@step.Detail</small>
                        </div>
                    </div>
                }
            </div>
        </article>
    </section>

    <section class="panel-card">
        <div class="panel-head">
            <div>
                <h5>Tabla principal</h5>
                <small>Diseño base con filtros, badges y acciones.</small>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        @foreach (var col in Columns)
                        {
                            <th>@col</th>
                        }
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Rows)
                    {
                        <tr>
                            @foreach (var value in row.Values)
                            {
                                <td>@value</td>
                            }
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1">Editar</button>
                                <button class="btn btn-sm btn-outline-secondary">Detalle</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</section>

