@page "/almacen/almacenes/{IdAlmacen:int}/ingreso-compras"
@page "/almacen/vehiculos/{IdAsignacion:long}/ventas-historicas"
@page "/almacen/vehiculos/{IdAsignacion:long}/editar"
@inject NavigationManager Nav

<PageTitle>@Titulo — VentasSaaSDU</PageTitle>

<Breadcrumb Titulo="@Titulo" Items="@(new[]{ ("Almacén", ""), (Titulo, "") })" />

<div class="card rounded-4">
    <div class="card-body p-4 p-lg-5">
        <div class="d-flex flex-column flex-md-row align-items-md-center gap-4">
            <div class="wh-64 rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center flex-shrink-0">
                <span class="material-icons-outlined fs-2">construction</span>
            </div>
            <div class="flex-grow-1">
                <h4 class="mb-2">@Titulo</h4>
                <p class="text-secondary mb-3">
                    La ruta visual ya quedó conectada desde las cards. Este módulo operativo se diseñará en la siguiente etapa.
                </p>
                <div class="d-flex flex-wrap gap-2 small">
                    @if (IdAlmacen.HasValue)
                    {
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">Almacén: @IdAlmacen</span>
                    }
                    @if (IdAsignacion.HasValue)
                    {
                        <span class="badge bg-info bg-opacity-10 text-info px-3 py-2">Asignación vehículo: @IdAsignacion</span>
                    }
                    <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2">Pendiente de diseño</span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary d-flex align-items-center gap-2" href="javascript:history.back()">
                    <span class="material-icons-outlined">arrow_back</span>
                    Regresar
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? IdAlmacen { get; set; }
    [Parameter] public long? IdAsignacion { get; set; }

    private string Titulo => ObtenerTitulo(Nav.ToBaseRelativePath(Nav.Uri));

    private static string ObtenerTitulo(string ruta)
    {
        ruta = ruta.ToLowerInvariant();

        if (ruta.Contains("ingreso-produccion")) return "Ingreso - Producción";
        if (ruta.Contains("ingreso-compras")) return "Ingreso - Compras";
        if (ruta.Contains("entrega-pedidos-ruta")) return "Entrega pedidos ruta";
        if (ruta.Contains("entrega-pedidos-clientes")) return "Entrega pedidos clientes";
        if (ruta.Contains("transferencia")) return "Transferencia entre almacenes";
        if (ruta.Contains("conteo")) return "Proceso de inventario";
        if (ruta.Contains("ajuste")) return "Ajustes directos inventario";
        if (ruta.Contains("ventas-historicas")) return "Ventas históricas";
        if (ruta.Contains("editar")) return "Editar vehículo";
        if (ruta.Contains("cambiar-chofer")) return "Cambiar de chofer";
        if (ruta.Contains("cambiar-ruta")) return "Cambiar de ruta";
        if (ruta.Contains("inventario")) return "Ver inventario";

        return "Módulo de almacén";
    }
}
