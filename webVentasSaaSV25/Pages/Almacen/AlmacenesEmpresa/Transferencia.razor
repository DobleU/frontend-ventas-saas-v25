@page "/almacen/almacenes/{IdAlmacen:int}/transferencia"
@page "/almacen/vehiculos/{IdAsignacion:long}/transferencia"
@using webVentasSaaSV25.Services.Almacen
@inject InventarioAlmacenWebService Svc

<PageTitle>@TituloPagina - VentasSaaSDU</PageTitle>

<Breadcrumb Titulo="@TituloPagina" Items="@(new[]{ ("Almacen", "/almacen/almacenes"), ("Transferencia", "") })" />

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-3">
    <div>
        <h3 class="mb-1">@TituloPagina</h3>
        <p class="text-secondary mb-0">@DescripcionPagina</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-2" @onclick="CargarAsync" disabled="@_cargando">
            @if (_cargando)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            }
            else
            {
                <span class="material-icons-outlined">refresh</span>
            }
            Actualizar
        </button>
        <a class="btn btn-outline-secondary d-flex align-items-center gap-2" href="javascript:history.back()">
            <span class="material-icons-outlined">arrow_back</span>
            Regresar
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@if (!string.IsNullOrWhiteSpace(_ok))
{
    <div class="alert alert-success">@_ok</div>
}

@if (_cargando && _inventario.Count == 0)
{
    <LoadingSpinner Solo="true" Texto="Cargando transferencia..." />
}

<div class="row g-3">
    <div class="col-12 col-xl-4">
        <div class="card rounded-4 h-100">
            <div class="card-body">
                <h5 class="mb-3">Captura</h5>

                <div class="mb-3">
                    <label class="form-label">@EtiquetaDestino</label>
                    <select class="form-select" @bind="_idAlmacenDestino">
                        <option value="0">@TextoSeleccionDestino</option>
                        @foreach (var a in _almacenesDestino)
                        {
                            <option value="@a.IdAlmacen">@a.Nombre</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Producto origen</label>
                    <select class="form-select" value="@_idProductoSeleccionado" @onchange="OnProductoChanged">
                        <option value="0">Selecciona producto</option>
                        @foreach (var item in ProductosDisponibles)
                        {
                            <option value="@item.IdProducto">@NombreProductoCombo(item)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Lote origen</label>
                    <select class="form-select" @bind="_idLoteSeleccionado" disabled="@(_idProductoSeleccionado <= 0)">
                        <option value="0">Selecciona lote</option>
                        @foreach (var item in LotesDisponibles)
                        {
                            <option value="@item.IdLote">Lote @item.NumLote - Stock @Fmt(item.CantidadPiezas)</option>
                        }
                    </select>
                </div>

                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label">Cajas</label>
                        <InputNumber class="form-control" @bind-Value="_cajas" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Piezas</label>
                        <InputNumber class="form-control" @bind-Value="_piezas" />
                    </div>
                </div>

                <div class="small text-secondary mt-2">
                    @if (Seleccionado is not null)
                    {
                        <span>Equivale a @Fmt(CantidadCapturada) pieza(s). Cantidad por caja: @(Seleccionado.CantXcaja ?? 0).</span>
                    }
                    else
                    {
                        <span>Selecciona producto y lote para calcular cajas y piezas.</span>
                    }
                </div>

                <button type="button" class="btn btn-primary w-100 mt-3 d-flex align-items-center justify-content-center gap-2"
                        @onclick="AgregarDetalleAsync"
                        disabled="@(!PuedeAgregar || _agregando)">
                    @if (_agregando)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <span class="material-icons-outlined">add</span>
                    }
                    Agregar
                </button>

                <div class="mt-3">
                    <label class="form-label">Observaciones</label>
                    <textarea class="form-control" rows="3" @bind="_observaciones" placeholder="Opcional"></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card rounded-4 h-100">
            <div class="card-body">
                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
                    <div>
                        <h5 class="mb-1">Detalle</h5>
                        <div class="text-secondary small">@_detalle.Count producto(s), @Fmt(_detalle.Sum(x => x.Cantidad)) pieza(s)</div>
                    </div>
                    <button type="button" class="btn btn-success d-flex align-items-center gap-2" @onclick="EntregarAsync" disabled="@(!_detalle.Any() || _guardando)">
                        @if (_guardando)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        }
                        else
                        {
                            <span class="material-icons-outlined">local_shipping</span>
                        }
                        ENTREGAR
                    </button>
                </div>

                @if (_detalle.Count == 0)
                {
                    <div class="text-center text-secondary py-5">
                        <span class="material-icons-outlined fs-1 d-block mb-2">inventory_2</span>
                        Agrega productos para crear la transferencia.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th>Lote</th>
                                    <th class="text-end">Stock origen</th>
                                    <th class="text-end">Transferir</th>
                                    <th class="text-end"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _detalle)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.NombreProducto</div>
                                            <div class="text-secondary small">@item.Sku</div>
                                        </td>
                                        <td>@item.NumLote</td>
                                        <td class="text-end">@Fmt(item.StockOrigen)</td>
                                        <td class="text-end">@Fmt(item.Cantidad)</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => QuitarDetalle(item)">
                                                <span class="material-icons-outlined">delete</span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int IdAlmacen { get; set; }
    [Parameter] public long? IdAsignacion { get; set; }

    private bool _cargando;
    private bool _guardando;
    private bool _agregando;
    private string? _error;
    private string? _ok;
    private readonly List<AlmacenEmpresaCardResponse> _almacenesDestino = [];
    private readonly List<InventarioAlmacenItemResponse> _inventario = [];
    private readonly List<TransferenciaDetalleVm> _detalle = [];
    private int _idAlmacenDestino;
    private int _idProductoSeleccionado;
    private long _idLoteSeleccionado;
    private int _cajas;
    private int _piezas;
    private string? _observaciones;
    private SubalmacenVehiculoCardResponse? _vehiculoOrigen;

    private bool EsTransferenciaVehiculos => IdAsignacion.HasValue;
    private int IdAlmacenOrigen => EsTransferenciaVehiculos ? (_vehiculoOrigen?.IdSubalmacen ?? 0) : IdAlmacen;
    private string TituloPagina => EsTransferenciaVehiculos ? "Transferencia entre vehiculos" : "Transferencia entre almacenes";
    private string DescripcionPagina => EsTransferenciaVehiculos
        ? "Mueve existencia del vehiculo origen a otro vehiculo activo con trazabilidad de salida y entrada."
        : "Mueve existencia del almacen origen a otro almacen de sucursal con trazabilidad de salida y entrada.";
    private string EtiquetaDestino => EsTransferenciaVehiculos ? "Vehiculo destino" : "Almacen destino";
    private string TextoSeleccionDestino => EsTransferenciaVehiculos ? "Selecciona vehiculo" : "Selecciona almacen";

    private InventarioAlmacenItemResponse? Seleccionado
        => _inventario.FirstOrDefault(x => x.IdProducto == _idProductoSeleccionado && x.IdLote == _idLoteSeleccionado);

    private List<InventarioAlmacenItemResponse> ProductosDisponibles
        => _inventario
            .Where(x => x.CantidadPiezas > 0)
            .GroupBy(x => x.IdProducto)
            .Select(g => g.OrderBy(x => x.NombreProducto).First())
            .OrderBy(x => x.NombreProducto)
            .ToList();

    private List<InventarioAlmacenItemResponse> LotesDisponibles
        => _inventario
            .Where(x => x.IdProducto == _idProductoSeleccionado && x.CantidadPiezas > 0)
            .OrderBy(x => x.FechaCaducidad ?? DateTime.MaxValue)
            .ThenBy(x => x.NumLote)
            .ToList();

    private bool PuedeAgregar
        => _idAlmacenDestino > 0 && _idProductoSeleccionado > 0 && _idLoteSeleccionado > 0 && CantidadCapturada > 0;

    private decimal CantidadCapturada
    {
        get
        {
            var cantXcaja = Seleccionado?.CantXcaja ?? 0;
            return (_cajas * cantXcaja) + _piezas;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        _cargando = true;
        _error = null;
        _ok = null;

        try
        {
            _almacenesDestino.Clear();

            if (EsTransferenciaVehiculos)
            {
                var (vehiculo, errVehiculo) = await Svc.GetSubalmacenVehiculoByIdAsync(IdAsignacion!.Value);
                if (!string.IsNullOrWhiteSpace(errVehiculo) || vehiculo is null)
                {
                    _error = errVehiculo ?? "Vehiculo origen no encontrado.";
                    return;
                }

                _vehiculoOrigen = vehiculo;

                var (vehiculos, errVehiculos) = await Svc.GetSubalmacenesVehiculosCardsAsync(vehiculo.IdAlmacenPadre, isActive: true);
                if (!string.IsNullOrWhiteSpace(errVehiculos))
                {
                    _error = errVehiculos;
                    return;
                }

                _almacenesDestino.AddRange((vehiculos ?? [])
                    .Where(x => x.IdAsignacion != IdAsignacion && x.IsActive)
                    .OrderBy(x => x.NombreRuta)
                    .ThenBy(x => x.NombreVehiculo)
                    .Select(x => new AlmacenEmpresaCardResponse
                    {
                        IdAlmacen = x.IdSubalmacen,
                        Nombre = $"{x.NombreRuta} - {x.NombreVehiculo}"
                    }));
            }
            else
            {
                var (almacenes, errAlmacenes) = await Svc.GetAlmacenesCardsAsync(isActive: true);
                if (!string.IsNullOrWhiteSpace(errAlmacenes))
                {
                    _error = errAlmacenes;
                    return;
                }

                _almacenesDestino.AddRange((almacenes ?? [])
                    .Where(x => x.IdAlmacen != IdAlmacen && x.IsActive && x.IdRuta is null)
                    .OrderBy(x => x.Nombre));
            }

            if (IdAlmacenOrigen <= 0)
            {
                _error = "No se pudo resolver el almacen origen.";
                return;
            }

            var (inv, errInv) = await Svc.GetInventarioAsync(IdAlmacenOrigen, page: 1, pageSize: 1000, soloConExistencia: true);
            if (!string.IsNullOrWhiteSpace(errInv))
            {
                _error = errInv;
                return;
            }

            _inventario.Clear();
            _inventario.AddRange(inv?.Items ?? []);
            _idProductoSeleccionado = 0;
            _idLoteSeleccionado = 0;
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task AgregarDetalleAsync()
    {
        _agregando = true;
        _error = null;
        _ok = null;

        try
        {
            var seleccionado = Seleccionado;
            if (seleccionado is null)
            {
                _error = "Selecciona un producto y lote.";
                return;
            }

            var cantidad = CantidadCapturada;
            if (cantidad <= 0)
            {
                _error = "Captura cajas o piezas mayores a cero.";
                return;
            }

            var existente = _detalle.FirstOrDefault(x => x.IdProducto == seleccionado.IdProducto && x.IdLote == seleccionado.IdLote);
            var cantidadActual = existente?.Cantidad ?? 0;
            if (cantidadActual + cantidad > seleccionado.CantidadPiezas)
            {
                _error = $"No hay existencia suficiente. Stock origen: {Fmt(seleccionado.CantidadPiezas)}.";
                return;
            }

            if (existente is null)
            {
                _detalle.Add(new TransferenciaDetalleVm
                {
                    IdProducto = seleccionado.IdProducto,
                    IdLote = seleccionado.IdLote,
                    NombreProducto = seleccionado.NombreProducto,
                    Sku = seleccionado.Sku,
                    NumLote = seleccionado.NumLote,
                    StockOrigen = seleccionado.CantidadPiezas,
                    Cantidad = cantidad,
                    CantCajas = _cajas > 0 ? Convert.ToInt16(_cajas) : null,
                    CantPiezas = _piezas > 0 ? _piezas : null
                });
            }
            else
            {
                existente.Cantidad += cantidad;
                existente.CantCajas = Convert.ToInt16((existente.CantCajas ?? 0) + _cajas);
                existente.CantPiezas = (existente.CantPiezas ?? 0) + _piezas;
            }

            _cajas = 0;
            _piezas = 0;
        }
        finally
        {
            _agregando = false;
        }

        await Task.CompletedTask;
    }

    private void QuitarDetalle(TransferenciaDetalleVm item)
    {
        _detalle.Remove(item);
    }

    private async Task EntregarAsync()
    {
        _error = null;
        _ok = null;

        if (_idAlmacenDestino <= 0)
        {
            _error = $"Selecciona {EtiquetaDestino.ToLowerInvariant()}.";
            return;
        }

        if (_detalle.Count == 0)
        {
            _error = "Agrega al menos un producto.";
            return;
        }

        _guardando = true;
        try
        {
            var request = new CrearTransferenciaAlmacenRequest
            {
                IdAlmacenDestino = _idAlmacenDestino,
                PermitirDestinoRuta = EsTransferenciaVehiculos,
                Observaciones = _observaciones,
                Detalle = _detalle.Select(x => new CrearTransferenciaAlmacenDetalleRequest
                {
                    IdProducto = x.IdProducto,
                    IdLote = x.IdLote,
                    Cantidad = x.Cantidad,
                    CantCajas = x.CantCajas,
                    CantPiezas = x.CantPiezas
                }).ToList()
            };

            var (idMovimiento, error) = await Svc.CrearTransferenciaAlmacenAsync(IdAlmacenOrigen, request);
            if (!string.IsNullOrWhiteSpace(error))
            {
                _error = error;
                return;
            }

            _ok = $"Transferencia creada correctamente. Movimiento salida: {idMovimiento}.";
            _detalle.Clear();
            _observaciones = null;
            await CargarAsync();
            _ok = $"Transferencia creada correctamente. Movimiento salida: {idMovimiento}.";
        }
        finally
        {
            _guardando = false;
        }
    }

    private void OnProductoChanged(ChangeEventArgs e)
    {
        _idProductoSeleccionado = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _idLoteSeleccionado = 0;
        _cajas = 0;
        _piezas = 0;
    }

    private static string NombreProductoCombo(InventarioAlmacenItemResponse item)
        => string.IsNullOrWhiteSpace(item.NombreCorto)
            ? item.NombreProducto
            : $"{item.NombreProducto} ({item.NombreCorto})";

    private static string Fmt(decimal value)
        => value.ToString("#,##0.####");

    private sealed class TransferenciaDetalleVm
    {
        public int IdProducto { get; set; }
        public long IdLote { get; set; }
        public string NombreProducto { get; set; } = string.Empty;
        public string? Sku { get; set; }
        public string NumLote { get; set; } = string.Empty;
        public decimal StockOrigen { get; set; }
        public decimal Cantidad { get; set; }
        public short? CantCajas { get; set; }
        public int? CantPiezas { get; set; }
    }
}
