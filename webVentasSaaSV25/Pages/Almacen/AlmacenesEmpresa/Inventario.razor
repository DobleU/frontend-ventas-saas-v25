@page "/almacen/almacenes/{IdAlmacen:int}/inventario"
@using System.Globalization
@using System.Text
@inject InventarioAlmacenWebService Svc
@inject IJSRuntime JS

<PageTitle>Ver inventario - VentasSaaSDU</PageTitle>

<Breadcrumb Titulo="Ver inventario" Items="@(new[]{ ("Almacén","/almacen/almacenes"), ("Ver inventario","") })" />
<AlertMessage @ref="_alerta" />

<section class="inventory-page-shell">
    <div class="inventory-hero">
        <div>
            <div class="inventory-kicker">
                <span class="material-icons-outlined">inventory_2</span>
                Almacén @IdAlmacen
            </div>
            <h3>Inventario por producto y lote</h3>
            <p>Consulta existencias en piezas y cajas, con lote, caducidad y valor actualizado.</p>
        </div>
        <div class="inventory-totals">
            <div>
                <span>Registros</span>
                <strong>@(_paged?.TotalRecords ?? 0)</strong>
            </div>
            <div>
                <span>Piezas</span>
                <strong>@_totalPiezas.ToString("N2", _mx)</strong>
            </div>
            <div>
                <span>Valor venta</span>
                <strong>@_totalVenta.ToString("C2", _mx)</strong>
            </div>
        </div>
    </div>

    <DataGrid TItem="InventarioAlmacenItemResponse"
              Titulo="Inventario"
              Modulo="almacen"
              Items="_paged?.Items"
              TotalRecords="_paged?.TotalRecords ?? 0"
              Page="_page"
              PageSize="_pageSize"
              Loading="_loading"
              MostrarNuevo="false"
              MostrarImportar="false"
              MostrarExportar="true"
              SearchPlaceholder="Buscar producto, SKU, código o lote"
              OnPageChanged="OnPage"
              OnPageSizeChange="OnPageSize"
              OnSearch="OnSearch"
              OnExportar="Exportar">
        <HeaderRow>
            <th>Producto</th>
            <th style="width:130px">Lote</th>
            <th style="width:115px">Caducidad</th>
            <th style="width:115px" class="text-end">Piezas</th>
            <th style="width:115px" class="text-end">Cajas</th>
            <th style="width:115px" class="text-end">Costo</th>
            <th style="width:115px" class="text-end">Valor</th>
            <th style="width:120px">Actualizado</th>
        </HeaderRow>
        <RowTemplate>
            <td>
                <div class="fw-semibold">@context.NombreProducto</div>
                <div class="small text-secondary d-flex flex-wrap gap-2">
                    <span>@(context.Sku ?? "Sin SKU")</span>
                    <span>@(context.CodigoBarra ?? "Sin código")</span>
                    @if (!string.IsNullOrWhiteSpace(context.NombreCategoria))
                    {
                        <span>@context.NombreCategoria</span>
                    }
                </div>
            </td>
            <td>
                <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis border border-primary-subtle">
                    @context.NumLote
                </span>
            </td>
            <td>@(context.FechaCaducidad?.ToString("dd/MM/yyyy") ?? "-")</td>
            <td class="text-end fw-semibold">@context.CantidadPiezas.ToString("N2", _mx)</td>
            <td class="text-end">@(context.CantidadCajas?.ToString("N2", _mx) ?? "-")</td>
            <td class="text-end">@(context.CostoTotal?.ToString("C2", _mx) ?? "-")</td>
            <td class="text-end fw-semibold text-success">@context.ValorVenta.ToString("C2", _mx)</td>
            <td class="small text-secondary">@MxTime.DateTime(context.UltimaActualizacion)</td>
        </RowTemplate>
        <AccionesExtra>
            <li>
                <a class="dropdown-item d-flex align-items-center gap-2" href="javascript:;">
                    <span class="material-icons-outlined fs-6">visibility</span>
                    Ver lote
                </a>
            </li>
        </AccionesExtra>
    </DataGrid>
</section>

<style>
    .inventory-page-shell {
        display: grid;
        gap: 1rem;
    }

    .inventory-hero {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.25rem;
        border-radius: 16px;
        background: linear-gradient(135deg, #0f4c81 0%, #146b8f 45%, #20a17b 100%);
        color: #fff;
        box-shadow: 0 14px 32px rgba(15, 76, 129, .22);
    }

    .inventory-hero h3 {
        margin: .3rem 0 .2rem;
        color: #fff;
        font-weight: 800;
    }

    .inventory-hero p {
        margin: 0;
        color: rgba(255,255,255,.82);
    }

    .inventory-kicker {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        font-weight: 700;
        color: #dffcf4;
    }

    .inventory-totals {
        display: grid;
        grid-template-columns: repeat(3, minmax(110px, 1fr));
        gap: .65rem;
        min-width: 390px;
    }

    .inventory-totals > div {
        padding: .75rem .9rem;
        border-radius: 12px;
        background: rgba(255,255,255,.16);
        border: 1px solid rgba(255,255,255,.24);
    }

    .inventory-totals span {
        display: block;
        color: rgba(255,255,255,.78);
        font-size: .78rem;
    }

    .inventory-totals strong {
        display: block;
        color: #fff;
        font-size: 1.2rem;
        margin-top: .15rem;
    }

    @@media (max-width: 900px) {
        .inventory-hero {
            flex-direction: column;
        }

        .inventory-totals {
            min-width: 0;
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter] public int IdAlmacen { get; set; }

    private readonly CultureInfo _mx = CultureInfo.GetCultureInfo("es-MX");
    private AlertMessage? _alerta;
    private InventarioAlmacenPagedResult<InventarioAlmacenItemResponse>? _paged;
    private bool _loading;
    private string? _search;
    private int _page = 1;
    private int _pageSize = 20;
    private decimal _totalPiezas;
    private decimal _totalVenta;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _loading = true;
        var (data, error) = await Svc.GetInventarioAsync(IdAlmacen, _search, _page, _pageSize);
        _loading = false;

        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return;
        }

        _paged = data;
        _totalPiezas = _paged?.Items.Sum(x => x.CantidadPiezas) ?? 0;
        _totalVenta = _paged?.Items.Sum(x => x.ValorVenta) ?? 0;
    }

    private async Task OnSearch(string? search)
    {
        _search = search;
        _page = 1;
        await Cargar();
    }

    private async Task OnPage(int page)
    {
        _page = page;
        await Cargar();
    }

    private async Task OnPageSize(int pageSize)
    {
        _pageSize = pageSize;
        _page = 1;
        await Cargar();
    }

    private async Task Exportar()
    {
        var rows = _paged?.Items ?? new List<InventarioAlmacenItemResponse>();
        if (rows.Count == 0)
        {
            _alerta?.MostrarInfo("No hay datos para exportar.");
            return;
        }

        var csv = new StringBuilder();
        csv.AppendLine("Producto,SKU,Codigo,Lote,Caducidad,Piezas,Cajas,Costo,Valor,Actualizado");
        foreach (var r in rows)
        {
            csv.AppendLine(string.Join(",",
                Csv(r.NombreProducto),
                Csv(r.Sku),
                Csv(r.CodigoBarra),
                Csv(r.NumLote),
                Csv(r.FechaCaducidad?.ToString("dd/MM/yyyy")),
                r.CantidadPiezas.ToString(CultureInfo.InvariantCulture),
                (r.CantidadCajas ?? 0).ToString(CultureInfo.InvariantCulture),
                (r.CostoTotal ?? 0).ToString(CultureInfo.InvariantCulture),
                r.ValorVenta.ToString(CultureInfo.InvariantCulture),
                Csv(MxTime.DateTime(r.UltimaActualizacion))));
        }

        var fileName = $"inventario-almacen-{IdAlmacen}.csv";
        var serializedCsv = System.Text.Json.JsonSerializer.Serialize(csv.ToString());
        var script =
            "(() => {" +
            $"const blob = new Blob([{serializedCsv}], {{ type: 'text/csv;charset=utf-8;' }});" +
            "const url = URL.createObjectURL(blob);" +
            "const a = document.createElement('a');" +
            "a.href = url;" +
            $"a.download = '{fileName}';" +
            "document.body.appendChild(a);" +
            "a.click();" +
            "a.remove();" +
            "URL.revokeObjectURL(url);" +
            "})();";

        await JS.InvokeVoidAsync("eval", script);
    }

    private static string Csv(string? value)
    {
        value ??= string.Empty;
        return "\"" + value.Replace("\"", "\"\"") + "\"";
    }
}
