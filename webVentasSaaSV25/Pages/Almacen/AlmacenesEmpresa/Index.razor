@page "/almacen/almacenes"
@using System.Globalization
@using webVentasSaaSV25.Services.Almacen
@inject InventarioAlmacenWebService Svc
@inject NavigationManager Nav

<PageTitle>Almacenes de la Empresa — VentasSaaSDU</PageTitle>

<Breadcrumb Titulo="Almacenes de la Empresa" Items="@(new[]{ ("Almacén", ""), ("Almacenes de la Empresa", "") })" />
<AlertMessage @ref="_alerta" AutoOcultarMs="6000" />

<div class="row g-3 mb-3">
    <div class="col-12 col-md-4 col-xl-3">
        <WidgetKpiIcono Icono="warehouse" ColorIcono="primary" Valor="@TotalAlmacenes" Etiqueta="Almacenes activos" />
    </div>
    <div class="col-12 col-md-4 col-xl-3">
        <WidgetKpiIcono Icono="payments" ColorIcono="success" Valor="@MontoTotal" Etiqueta="Inventario actual" />
    </div>
    <div class="col-12 col-md-4 col-xl-3">
        <WidgetKpiIcono Icono="local_shipping" ColorIcono="info" Valor="@TotalSubalmacenes" Etiqueta="Vehículos / subalmacenes" />
    </div>
    <div class="col-12 col-xl-3">
        <div class="card rounded-4 h-100">
            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                <div>
                    <p class="mb-1 text-secondary small">Vista operativa</p>
                    <h6 class="mb-0">Cards por almacén</h6>
                </div>
                <span class="material-icons-outlined text-primary fs-2">dashboard_customize</span>
            </div>
        </div>
    </div>
</div>

<div class="card rounded-4 mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-lg-6">
                <div class="position-relative">
                    <input class="form-control ps-5" placeholder="Buscar almacén, sucursal u observaciones..." @bind="_search" />
                    <span class="material-icons-outlined position-absolute ms-3 translate-middle-y start-0 top-50 fs-5 text-secondary">search</span>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-auto">
                <select class="form-select" @bind="_isActiveText">
                    <option value="true">Activos</option>
                    <option value="false">Inactivos</option>
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="col-12 col-sm-6 col-lg-auto">
                <div class="d-flex gap-2">
                    <AppButton Tipo="primary" Icono="search" Texto="Buscar" OnClick="Cargar" Loading="_loading" />
                    <AppButton Tipo="light" Icono="restart_alt" Texto="Limpiar" OnClick="Limpiar" Disabled="_loading" />
                </div>
            </div>
        </div>
    </div>
</div>

@if (_loading)
{
    <LoadingSpinner Solo="true" Texto="Cargando almacenes..." />
}
else if (_items.Count == 0)
{
    <div class="card rounded-4">
        <div class="card-body text-center py-5">
            <span class="material-icons-outlined fs-1 text-secondary">inventory_2</span>
            <h5 class="mt-2 mb-1">No hay almacenes para mostrar</h5>
            <p class="text-secondary mb-0">Revisa los filtros o crea un almacén principal desde el módulo administrativo.</p>
        </div>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 row-cols-xxl-4 g-3">
        @foreach (var a in _items)
        {
            <div class="col">
                <InventarioCard Icono="@a.Icono"
                                ColorIcono="primary"
                                TipoCard="@a.TipoCard"
                                Nombre="@a.Nombre"
                                Subtitulo="@a.Subtitulo"
                                EtiquetaValor="@a.EtiquetaValor"
                                IconoValor="@a.IconoValor"
                                MontoInventario="@a.MontoInventario"
                                MontoInventarioCosto="@a.MontoInventarioCosto"
                                ProductosActivos="@a.ProductosActivos"
                                ExistenciaTotal="@a.ExistenciaTotal"
                                InventarioActualizadoUtc="@a.InventarioActualizadoUtc"
                                NombreEncargado="@a.NombreEncargado"
                                IsActive="@a.IsActive"
                                EtiquetaExtra="Vehículos"
                                ValorExtra="@FormatNumero(a.TotalSubalmacenes)"
                                IconoExtra="local_shipping">
                    <Opciones>
                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="@($"/almacen/almacenes/{a.IdAlmacen}/inventario")"><span class="material-icons-outlined fs-6">inventory_2</span>Ver inventario</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><h6 class="dropdown-header text-uppercase small">Ingresos</h6></li>
                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="@($"/almacen/almacenes/{a.IdAlmacen}/ingreso-produccion")"><span class="material-icons-outlined fs-6">precision_manufacturing</span>Ingreso - Producción</a></li>
                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="@($"/almacen/almacenes/{a.IdAlmacen}/ingreso-compras")"><span class="material-icons-outlined fs-6">shopping_cart</span>Ingreso - Compras</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><h6 class="dropdown-header text-uppercase small">Entregas y movimientos</h6></li>
                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="@($"/almacen/almacenes/{a.IdAlmacen}/entrega-pedidos-ruta")"><span class="material-icons-outlined fs-6">local_shipping</span>Entrega pedidos ruta</a></li>
                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="@($"/almacen/almacenes/{a.IdAlmacen}/entrega-pedidos-clientes")"><span class="material-icons-outlined fs-6">group</span>Entrega pedidos clientes</a></li>
                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="@($"/almacen/almacenes/{a.IdAlmacen}/transferencia")"><span class="material-icons-outlined fs-6">sync_alt</span>Transferencia entre almacenes</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><h6 class="dropdown-header text-uppercase small">Control</h6></li>
                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="@($"/almacen/almacenes/{a.IdAlmacen}/conteo")"><span class="material-icons-outlined fs-6">fact_check</span>Proceso de inventario</a></li>
                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="@($"/almacen/almacenes/{a.IdAlmacen}/ajuste")"><span class="material-icons-outlined fs-6">tune</span>Ajustes directos inventario</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="@($"/almacen/{a.IdAlmacen}/vehiculos")"><span class="material-icons-outlined fs-6">directions_car</span>Vehículos</a></li>
                    </Opciones>
                </InventarioCard>
            </div>
        }
    </div>
}

@code {
    private static readonly CultureInfo CulturaMx = CultureInfo.GetCultureInfo("es-MX");
    private readonly List<AlmacenEmpresaCardResponse> _items = [];
    private AlertMessage? _alerta;
    private bool _loading;
    private string? _search;
    private string _isActiveText = "true";

    private string TotalAlmacenes => _items.Count(x => x.IsActive).ToString("N0", CulturaMx);
    private string TotalSubalmacenes => _items.Sum(x => x.TotalSubalmacenes).ToString("N0", CulturaMx);
    private string MontoTotal => _items.Sum(x => x.MontoInventario).ToString("C2", CulturaMx);
    private static string FormatNumero(int value) => value.ToString("N0", CulturaMx);

    protected override async Task OnInitializedAsync() => await Cargar();

    private bool? IsActiveFiltro => _isActiveText switch
    {
        "true" => true,
        "false" => false,
        _ => null
    };

    private async Task Cargar()
    {
        _loading = true;
        var (data, error) = await Svc.GetAlmacenesCardsAsync(_search, IsActiveFiltro);
        _loading = false;

        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return;
        }

        _items.Clear();
        if (data is not null)
            _items.AddRange(data);
    }

    private async Task Limpiar()
    {
        _search = null;
        _isActiveText = "true";
        await Cargar();
    }
}
