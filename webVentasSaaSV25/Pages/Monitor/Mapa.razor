    private static bool IsTrasladoError(ReporteVisitaRowResponse visita)
    {
        var segundos = EffectiveTrasladoSeconds(visita.SegundosTraslado, visita.MinutosTraslado);
        if (segundos <= 15)
            return true;

        return (visita.MinutosTraslado ?? 0) > 45;
    }
    private static bool IsTrasladoError(MapStop stop)
    {
        var segundos = EffectiveTrasladoSeconds(stop.SegundosTraslado, stop.MinutosTraslado);
        if (segundos <= 15)
            return true;

        return (stop.MinutosTraslado ?? 0) > 45;
    }
    private static string TrasladoMonitorText(ReporteVisitaRowResponse visita)
    {
        var minutos = visita.MinutosTraslado ?? 0;
        var segundos = EffectiveTrasladoSeconds(visita.SegundosTraslado, visita.MinutosTraslado);
        var estado = IsTrasladoError(visita) ? "Traslado error" : "Traslado OK";
        return $"{estado} · {minutos:N0} min · {segundos:N0} seg";
    }
    private static string TrasladoMonitorText(MapStop stop)
    {
        var minutos = stop.MinutosTraslado ?? 0;
        var segundos = EffectiveTrasladoSeconds(stop.SegundosTraslado, stop.MinutosTraslado);
        var estado = IsTrasladoError(stop) ? "Traslado error" : "Traslado OK";
        return $"{estado} · {minutos:N0} min · {segundos:N0} seg";
    }
    private static int EffectiveTrasladoSeconds(int segundosTraslado, int? minutosTraslado)
        => segundosTraslado <= 0 && (minutosTraslado ?? 0) > 0
            ? minutosTraslado!.Value * 60
            : segundosTraslado;
    private static string GeoText(string source) => source switch
    {
        "REAL_FIN" => "GPS real de cierre",
        "REAL_INICIO" => "GPS de inicio",
        "CLIENTE_DIR" => "Direccion del cliente",
        _ => "Sin coordenada confiable"
    };

    private static string Money(decimal amount) => amount.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("es-MX"));
    private static string BuildLastVisitText(DateTime? ultimaVisitaUtc, int? diasSinVisita, string? fallback)
    {
        if (ultimaVisitaUtc.HasValue)
        {
            var fecha = ultimaVisitaUtc.Value.ToLocalTime().ToString("dd/MM/yyyy");
            return diasSinVisita.HasValue ? $"{fecha} Â· {diasSinVisita.Value} dia(s)" : fecha;
        }

        return string.IsNullOrWhiteSpace(fallback) ? "Sin visita reciente" : fallback;
    }
    private static string FrequencyLabel(int weeks) => weeks switch
    {
        <= 1 => "Cada semana",
        2 => "Cada 2 semanas",
        3 => "Cada 3 semanas",
        4 => "Cada 4 semanas",
        _ => $"Cada {weeks} semanas"
    };
    private static string VisitAgeClass(MapStop stop) => stop.DaysSinceLastVisit.HasValue && stop.DaysSinceLastVisit.Value > 15 ? "visit-late" : string.Empty;
    private static MapBounds? BuildBounds(List<MapStop> stops, MapStop? selected)
    {
        var points = stops.ToList();
        if (selected is not null && selected.HasValidCoordinates && points.All(x => x.Id != selected.Id))
            points.Add(selected);
        if (!points.Any()) return null;

        var minLat = (double)points.Min(x => x.Latitude!.Value);
        var maxLat = (double)points.Max(x => x.Latitude!.Value);
        var minLon = (double)points.Min(x => x.Longitude!.Value);
        var maxLon = (double)points.Max(x => x.Longitude!.Value);
        var latPad = Math.Max((maxLat - minLat) * 0.12d, 0.0035d);
        var lonPad = Math.Max((maxLon - minLon) * 0.12d, 0.0035d);
        return new MapBounds(minLat - latPad, maxLat + latPad, minLon - lonPad, maxLon + lonPad);
    }
    private int VisitOrder(int idCliente)
        => VisibleStops.FirstOrDefault(x => x.Id == idCliente)?.Order ?? 0;
