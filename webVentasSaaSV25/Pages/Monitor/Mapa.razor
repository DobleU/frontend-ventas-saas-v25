    .detail-grid span{color:#667085}
    .detail-grid strong{font-weight:650;color:#344054}
    .visit-late{color:#b42318 !important}
    .preline{white-space:pre-line}
    .detail-actions{display:flex;gap:.45rem;flex-wrap:wrap;margin-top:1.25rem}
    .monitor-shortcuts{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.75rem;margin-top:.85rem}
    .shortcut-card{display:flex;align-items:flex-start;gap:.8rem;text-decoration:none;padding:.95rem 1rem;border-radius:10px;border:1px solid #e6eaf0;background:linear-gradient(180deg,#fff,#f8fbff);box-shadow:0 4px 18px rgba(18,38,63,.04);color:#344054}
    .shortcut-card:hover{border-color:#bfd7ff;background:#eef5ff}
    .shortcut-card span{font-size:22px;color:#0d6efd}
    .shortcut-card strong,.shortcut-card small{display:block}
    .shortcut-card small{color:#667085}
    .empty-state{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:#667085;gap:.25rem;padding:1rem}
    .empty-state.small{position:static;min-height:180px}
    .empty-state i{font-size:52px;color:#98a2b3}
    @@media (max-width:1399.98px){.route-map-shell{grid-template-columns:320px 1fr}.detail-panel{grid-column:1/-1;min-height:auto}.map-canvas{min-height:520px}}
    @@media (max-width:991.98px){.route-map-page{width:100%;margin-left:0}.route-map-header{flex-direction:column}.map-metrics,.monitor-shortcuts{grid-template-columns:1fr 1fr}.route-map-shell{grid-template-columns:1fr}.stop-list{max-height:360px}.map-stage,.route-sidebar{min-height:auto}.map-canvas{min-height:430px}}
    @@media (max-width:767.98px){.monitor-shortcuts{grid-template-columns:1fr}}
</style>

@code {
    [SupplyParameterFromQuery(Name = "ruta")] public int? QueryRouteId { get; set; }
    [SupplyParameterFromQuery(Name = "cliente")] public int? QueryClientId { get; set; }

    private const string StorageKey = "monitor-mapa-state";
    private const string MapElementId = "monitor-mapa-google";

    private enum MapMode { Route, Tour }
    private enum VisitStatus { Pending, Done, Alert }

    private MapMode _mode = MapMode.Route;
    private int _routeId;
    private long _recorridoId;
    private string? _error;
    private bool _loading;
    private bool _restored;
    private bool _loadingImage;
    private DateTime _fechaTrabajo = DateTime.Today;
    private string _frecuenciaSeleccionada = "Todas";
    private List<MapaRutaOptionResponse> _routes = [];
    private List<MapaRecorridoOptionResponse> _recorridos = [];
    private List<MapStop> _stops = [];
    private MapStop? _selected;
    private string? _selectedImageDataUrl;
    private MapaConfiguracionResponse? _mapConfig;
    private DotNetObjectReference<GoogleMapBridge>? _mapBridgeRef;
    private bool _mapDirty;
    private readonly (int Numero, string Nombre)[] _diasSemana =
    [
        (1, "Lunes"),
        (2, "Martes"),
        (3, "Miercoles"),
        (4, "Jueves"),
        (5, "Viernes"),
        (6, "Sabado"),
        (7, "Domingo")
    ];
    private readonly string[] _frecuencias = ["Todas", "Cada semana", "Cada 2 semanas", "Cada 3 semanas", "Cada 4 semanas"];

    private List<MapStop> VisibleStops => _stops
        .Where(MatchesFrequency)
        .OrderBy(s => s.Order)
        .ToList();

    private string MapStatusText => VisibleStops.Any()
        ? $"{VisibleStops.Count} cliente(s) programado(s) para {_fechaTrabajo:dd/MM/yyyy}."
        : "Sin clientes programados para la fecha seleccionada.";
    private string RouteNameText => _routes.FirstOrDefault(x => x.IdRuta == _routeId)?.Nombre ?? "seleccionada";
    private string ClientesConImagenTexto => VisibleStops.Count == 0 ? "0" : VisibleStops.Count(x => x.HasImage).ToString("N0");
    private string ClientesConVisitaVencidaTexto => VisibleStops.Count == 0 ? "0" : VisibleStops.Count(x => x.DaysSinceLastVisit.HasValue && x.DaysSinceLastVisit.Value > 15).ToString("N0");
    private List<MapStop> VisibleStopsWithCoordinates => VisibleStops.Where(x => x.HasValidCoordinates).ToList();
    private MapBounds? CurrentBounds => BuildBounds(VisibleStopsWithCoordinates, _selected);
    private string? CurrentMapUrl => _selected is not null && _selected.HasValidCoordinates
        ? $"https://www.google.com/maps?q={_selected.Latitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)},{_selected.Longitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}"
        : null;
    private bool CanShowMap => _mapConfig?.MostrarMapa == true && _mapConfig?.TieneApiKey == true;
    private string MapConfigMessage => string.IsNullOrWhiteSpace(_mapConfig?.MensajeConfiguracion)
        ? "Debe dar de alta la configuracion de mapas para esta empresa."
        : _mapConfig!.MensajeConfiguracion;

    private string RutasRouteUrl => _routeId > 0 ? $"/monitor/rutas?ruta={_routeId}" : "/monitor/rutas";
    private string ClientesRouteUrl => _routeId > 0 ? $"/monitor/clientes?ruta={_routeId}" : "/monitor/clientes";
    private string RecorridosRouteUrl => _routeId > 0 ? $"/ventas/ruta/recorridos?ruta={_routeId}" : "/ventas/ruta/recorridos";
    private string VisitasRouteUrl => _routeId > 0 ? $"/ventas/ruta/visitas?ruta={_routeId}" : "/ventas/ruta/visitas";
    private string VentasReportUrl => _routeId > 0 ? $"/reportes/ventas?ruta={_routeId}" : "/reportes/ventas";
    private string ClientesReportUrl => _routeId > 0 ? $"/reportes/clientes?ruta={_routeId}" : "/reportes/clientes";

    protected override async Task OnInitializedAsync()
    {
        var (config, configError) = await MapaApi.GetConfiguracionAsync();
        _mapConfig = config;
        var (routes, error) = await MapaApi.GetRutasAsync();
        _routes = routes?.ToList() ?? [];
        _error = error ?? configError;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_restored)
        {
            _restored = true;
            await RestoreStateAsync();
            if (QueryRouteId is > 0)
            {
                _routeId = QueryRouteId.Value;
            }

            if (_routeId > 0)
            {
                if (_mode == MapMode.Tour)
                {
                    await LoadRecorridosAsync();
                    await LoadRouteAsync();
                }
                else
                {
                    await LoadRouteAsync();
                }
                StateHasChanged();
            }
        }

        if (_mapDirty && CanShowMap)
        {
            _mapDirty = false;
            await RenderGoogleMapAsync();
        }
    }

    private async Task OnRouteChangedAsync(ChangeEventArgs e)
    {
        _routeId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        await SaveStateAsync();
        if (_mode == MapMode.Tour)
        {
            await LoadRecorridosAsync();
            await LoadRouteAsync();
            return;
        }

        await LoadRouteAsync();
    }

    private async Task OnRecorridoChangedAsync(ChangeEventArgs e)
    {
        _recorridoId = long.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        await SaveStateAsync();
        await LoadRouteAsync();
    }

    private async Task OnFechaTrabajoChangedAsync(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var fecha))
            _fechaTrabajo = fecha.Date;
        await SaveStateAsync();
        await LoadRouteAsync();
    }

    private async Task ReloadRouteAsync() => await LoadRouteAsync();

    private async Task LoadRecorridosAsync()
    {
        _selected = null;
        _stops = [];
        _recorridoId = 0;
        _error = null;

        if (_routeId <= 0)
        {
            _recorridos = [];
            _mapDirty = true;
            await SaveStateAsync();
            return;
        }

        _loading = true;
        var (items, error) = await MapaApi.GetRecorridosAsync(_routeId);
        _loading = false;
        _error = error;
        _recorridos = items?.ToList() ?? [];
        _recorridoId = _recorridos.FirstOrDefault()?.IdRecorrido ?? 0;

        _mapDirty = true;
        await SaveStateAsync();
    }

    private async Task LoadRouteAsync()
    {
        _selected = null;
        _stops = [];
        _error = null;

        if (_routeId <= 0) return;
        if (_mode == MapMode.Tour && _recorridoId <= 0)
        {
            _mapDirty = true;
            await SaveStateAsync();
            return;
        }

        _loading = true;
        var (map, error) = await MapaApi.GetRutaAsync(new MapaRutaRequest
        {
            IdRuta = _routeId,
            IdRecorrido = _mode == MapMode.Tour ? _recorridoId : null,
            FechaTrabajo = _fechaTrabajo,
            Modo = _mode == MapMode.Tour ? "recorrido" : "ruta"
        });
        _loading = false;
        _error = error;

        var loadedStops = map?.Puntos.Select(FromApiPoint).ToList() ?? [];
        _stops = _mode == MapMode.Route
            ? loadedStops
                .GroupBy(x => x.Id)
                .Select(g => g
                    .OrderBy(x => x.Order)
                    .ThenByDescending(x => x.HasValidCoordinates)
                    .First())
                .OrderBy(x => x.Order)
                .ToList()
            : loadedStops;
        _selected = _stops.FirstOrDefault();
        if (QueryClientId is > 0)
        {
            _selected = _stops.FirstOrDefault(x => x.Id == QueryClientId.Value) ?? _selected;
        }
        await LoadSelectedImageAsync();
        _mapDirty = true;
        await SaveStateAsync();
    }

    private static MapStop FromApiPoint(MapaClientePuntoResponse point)
        => new(
            Id: point.IdCliente,
            Order: point.Orden,
            Name: point.Nombre,
            RouteName: point.NombreRuta ?? "Sin ruta",
            Address: point.Direccion ?? "Direccion pendiente",
            Phone: point.Telefono,
            Rfc: point.Rfc,
            CreditText: point.Credito,
            LastVisit: BuildLastVisitText(point.UltimaVisitaUtc, point.DiasSinVisita, point.UltimaVisita),
            GeoSource: point.GeoSource,
            ProductTop: point.ProductoTop,
            FrequencyWeeks: point.FrecuenciaSemanas <= 0 ? 1 : point.FrecuenciaSemanas,
            HasImage: point.TieneImagen,
            ImageUrl: point.UrlImagen,
            LastVisitUtc: point.UltimaVisitaUtc,
            DaysSinceLastVisit: point.DiasSinVisita,
            TotalSalesAmount: point.MontoHistoricoTotal,
            HasBilling: point.TieneFacturacion,
            BillingName: point.RazonSocialFacturacion,
            Status: point.Estado?.ToLowerInvariant() switch
            {
                "visitado" => VisitStatus.Done,
                "alerta" => VisitStatus.Alert,
                _ => VisitStatus.Pending
            },
            Latitude: point.Latitud,
            Longitude: point.Longitud);

    private bool MatchesFrequency(MapStop stop)
    {
        if (string.Equals(_frecuenciaSeleccionada, "Todas", StringComparison.OrdinalIgnoreCase))
            return true;

        return _frecuenciaSeleccionada switch
        {
            "Cada semana" => stop.FrequencyWeeks == 1,
            "Cada 2 semanas" => stop.FrequencyWeeks == 2,
            "Cada 3 semanas" => stop.FrequencyWeeks == 3,
            "Cada 4 semanas" => stop.FrequencyWeeks == 4,
            _ => true
        };
    }

    private async Task SelectStopAsync(MapStop stop)
    {
        _selected = stop;
        await LoadSelectedImageAsync();
        _mapDirty = true;
    }

    private async Task SetMode(MapMode mode)
    {
        _mode = mode;
        await SaveStateAsync();
        if (_mode == MapMode.Tour)
        {
            await LoadRecorridosAsync();
            await LoadRouteAsync();
            return;
        }
        await LoadRouteAsync();
    }
    private async Task SelectRecorridoAsync(MapaRecorridoOptionResponse tour)
    {
        _recorridoId = tour.IdRecorrido;
        await SaveStateAsync();
        await LoadRouteAsync();
    }
    private string ModeClass(MapMode mode) => _mode == mode ? "btn-primary" : "btn-outline-primary";
    private async Task SetDayAsync(int diaSemana)
    {
        var currentDay = DiaSemanaNumero(_fechaTrabajo);
        _fechaTrabajo = _fechaTrabajo.AddDays(diaSemana - currentDay);
        await SaveStateAsync();
        await LoadRouteAsync();
    }
    private string DayClass(int diaSemana) => DiaSemanaNumero(_fechaTrabajo) == diaSemana ? "active" : "";
    private async Task SetFrequencyAsync(string frecuencia)
    {
        _frecuenciaSeleccionada = frecuencia;
        await SaveStateAsync();
    }
    private string FrequencyClass(string frecuencia) => string.Equals(_frecuenciaSeleccionada, frecuencia, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    private string SelectedClass(MapStop stop) => _selected?.Id == stop.Id ? "selected" : "";
    private string SelectedRecorridoClass(MapaRecorridoOptionResponse tour) => tour.IdRecorrido == _recorridoId ? "selected" : "";
    private static string StatusClass(VisitStatus status) => status switch { VisitStatus.Done => "done", VisitStatus.Alert => "alert", _ => "pending" };
    private static string StatusText(VisitStatus status) => status switch { VisitStatus.Done => "Visitado", VisitStatus.Alert => "Alerta", _ => "Pendiente" };
    private static string TextOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "Sin dato" : value;
    private static string GeoText(string source) => source switch
    {
        "REAL_FIN" => "GPS real de cierre",
        "REAL_INICIO" => "GPS de inicio",
        "CLIENTE_DIR" => "Direccion del cliente",
        _ => "Sin coordenada confiable"
    };

    private static string Money(decimal amount) => amount.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("es-MX"));
    private static string BuildLastVisitText(DateTime? ultimaVisitaUtc, int? diasSinVisita, string? fallback)
    {
        if (ultimaVisitaUtc.HasValue)
        {
            var fecha = ultimaVisitaUtc.Value.ToLocalTime().ToString("dd/MM/yyyy");
            return diasSinVisita.HasValue ? $"{fecha} · {diasSinVisita.Value} dia(s)" : fecha;
        }

        return string.IsNullOrWhiteSpace(fallback) ? "Sin visita reciente" : fallback;
    }
    private static string FrequencyLabel(int weeks) => weeks switch
    {
        <= 1 => "Cada semana",
        2 => "Cada 2 semanas",
        3 => "Cada 3 semanas",
        4 => "Cada 4 semanas",
        _ => $"Cada {weeks} semanas"
    };
    private static string VisitAgeClass(MapStop stop) => stop.DaysSinceLastVisit.HasValue && stop.DaysSinceLastVisit.Value > 15 ? "visit-late" : string.Empty;
    private static MapBounds? BuildBounds(List<MapStop> stops, MapStop? selected)
    {
        var points = stops.ToList();
        if (selected is not null && selected.HasValidCoordinates && points.All(x => x.Id != selected.Id))
            points.Add(selected);
        if (!points.Any()) return null;

        var minLat = (double)points.Min(x => x.Latitude!.Value);
        var maxLat = (double)points.Max(x => x.Latitude!.Value);
        var minLon = (double)points.Min(x => x.Longitude!.Value);
        var maxLon = (double)points.Max(x => x.Longitude!.Value);
        var latPad = Math.Max((maxLat - minLat) * 0.12d, 0.0035d);
        var lonPad = Math.Max((maxLon - minLon) * 0.12d, 0.0035d);
        return new MapBounds(minLat - latPad, maxLat + latPad, minLon - lonPad, maxLon + lonPad);
    }
    private async Task RenderGoogleMapAsync()
    {
        if (!CanShowMap || string.IsNullOrWhiteSpace(_mapConfig?.ApiKey))
        {
            return;
        }

        _mapBridgeRef ??= DotNetObjectReference.Create(new GoogleMapBridge(HandleMapMarkerClickAsync));

        var payload = new
        {
            centerLat = CurrentBounds is null ? 0d : (CurrentBounds.MinLat + CurrentBounds.MaxLat) / 2d,
            centerLng = CurrentBounds is null ? 0d : (CurrentBounds.MinLon + CurrentBounds.MaxLon) / 2d,
            zoom = 13,
            selectedZoom = 17,
            selectedId = _selected?.Id ?? 0,
            clickMethod = nameof(GoogleMapBridge.HandleMapMarkerClick),
            dotNetRef = _mapBridgeRef,
            markers = VisibleStopsWithCoordinates.Select(x => new
            {
                id = x.Id,
                lat = (double)x.Latitude!.Value,
                lng = (double)x.Longitude!.Value,
                label = x.Order.ToString(),
                title = $"{x.Order}. {x.Name}",
                status = StatusClass(x.Status)
            }).ToList()
        };

        await JS.InvokeVoidAsync("AppInterop.renderMonitorMap", MapElementId, _mapConfig.ApiKey, payload);
    }

    private async Task HandleMapMarkerClickAsync(int idCliente)
    {
        var stop = VisibleStops.FirstOrDefault(x => x.Id == idCliente);
        if (stop is null)
        {
            return;
        }

        await SelectStopAsync(stop);
        StateHasChanged();
    }

    private async Task LoadSelectedImageAsync()
    {
        _selectedImageDataUrl = null;
        _loadingImage = false;

        if (_selected is null || !_selected.HasImage)
        {
            return;
        }

        _loadingImage = true;
        var (bytes, contentType, error) = await MapaApi.GetClienteFotoAsync(_selected.Id);
        _loadingImage = false;

        if (!string.IsNullOrWhiteSpace(error) || bytes is null || bytes.Length == 0)
        {
            return;
        }

        var safeContentType = string.IsNullOrWhiteSpace(contentType) ? "image/jpeg" : contentType;
        _selectedImageDataUrl = $"data:{safeContentType};base64,{Convert.ToBase64String(bytes)}";
    }

    private async Task RestoreStateAsync()
    {
        var json = await JS.InvokeAsync<string?>("AppInterop.localStorageGet", StorageKey);
        if (string.IsNullOrWhiteSpace(json))
        {
            return;
        }

        try
        {
            var state = System.Text.Json.JsonSerializer.Deserialize<MonitorMapState>(json);
            if (state is null)
            {
                return;
            }

            if (QueryRouteId is null or <= 0)
            {
                _routeId = state.RouteId;
            }

            _recorridoId = state.RecorridoId;
            _fechaTrabajo = state.FechaTrabajo == default ? DateTime.Today : state.FechaTrabajo;
            _frecuenciaSeleccionada = string.IsNullOrWhiteSpace(state.Frecuencia) ? "Todas" : state.Frecuencia;
            _mode = Enum.TryParse<MapMode>(state.Mode, out var mode) ? mode : MapMode.Route;
        }
        catch
        {
        }
    }

    private async Task SaveStateAsync()
    {
        var payload = new MonitorMapState(_routeId, _recorridoId, _fechaTrabajo, _frecuenciaSeleccionada, _mode.ToString(), _selected?.Id);
        await JS.InvokeVoidAsync("AppInterop.localStorageSet", StorageKey, System.Text.Json.JsonSerializer.Serialize(payload));
    }

    private static int DiaSemanaNumero(DateTime fecha)
        => fecha.DayOfWeek switch
        {
            DayOfWeek.Monday => 1,
            DayOfWeek.Tuesday => 2,
            DayOfWeek.Wednesday => 3,
            DayOfWeek.Thursday => 4,
            DayOfWeek.Friday => 5,
            DayOfWeek.Saturday => 6,
            _ => 7
        };

    private sealed record MapStop(
        int Id,
        int Order,
        string Name,
        string RouteName,
        string Address,
        string? Phone,
        string? Rfc,
        string CreditText,
        string LastVisit,
        int FrequencyWeeks,
        bool HasImage,
        string? ImageUrl,
        DateTime? LastVisitUtc,
        int? DaysSinceLastVisit,
        decimal TotalSalesAmount,
        bool HasBilling,
        string? BillingName,
        VisitStatus Status,
        decimal? Latitude,
        decimal? Longitude,
        string GeoSource,
        string? ProductTop)
    {
        public bool HasValidCoordinates => Latitude.HasValue && Longitude.HasValue && Latitude.Value != 0 && Longitude.Value != 0;
    }

    private sealed record MapBounds(double MinLat, double MaxLat, double MinLon, double MaxLon);
    private sealed record MonitorMapState(int RouteId, long RecorridoId, DateTime FechaTrabajo, string Frecuencia, string Mode, int? SelectedClientId);
    private sealed class GoogleMapBridge(Func<int, Task> onMarkerClick)
    {
        [JSInvokable]
        public Task HandleMapMarkerClick(int id) => onMarkerClick(id);
    }
}
