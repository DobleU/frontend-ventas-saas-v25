@page "/monitor/mapa"
@inject MonitorMapaService MapaApi
@inject IJSRuntime JS

<PageTitle>Mapa General - Integra*System</PageTitle>

<div class="route-map-page">
    <header class="route-map-header">
        <div>
            <h4>Mapa General</h4>
            <p>Planeacion visual de ruta, clientes y visitas.</p>
        </div>

        <div class="route-map-actions">
            <a class="btn btn-outline-secondary" href="@RutasRouteUrl">
                <i class="material-icons-outlined">route</i>
                Monitor rutas
            </a>
            <a class="btn btn-outline-secondary" href="@ClientesRouteUrl">
                <i class="material-icons-outlined">groups</i>
                Monitor clientes
            </a>
            <button class="btn btn-outline-primary" type="button" @onclick="ReloadRouteAsync" disabled="@(_routeId <= 0 || _loading)">
                <i class="material-icons-outlined">refresh</i>
                Recargar
            </button>
            <div class="btn-group" role="group" aria-label="Modo">
                <button class="btn @ModeClass(MapMode.Route)" type="button" @onclick="() => SetMode(MapMode.Route)">Ruta</button>
                <button class="btn @ModeClass(MapMode.Tour)" type="button" @onclick="() => SetMode(MapMode.Tour)">Recorrido</button>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-warning py-2">@_error</div>
    }
    @if (!CanShowMap && !string.IsNullOrWhiteSpace(MapConfigMessage))
    {
        <div class="alert alert-info py-2">@MapConfigMessage</div>
    }

    <section class="map-metrics" aria-label="Resumen de mapa">
        @if (_mode == MapMode.Tour)
        {
            <div><span>Total clientes programados</span><strong>@TourProgramadosTexto</strong></div>
            <div><span>Clientes visitados</span><strong>@TourVisitadosTexto</strong></div>
            <div><span>Clientes no visitados</span><strong>@TourNoVisitadosTexto</strong></div>
            <div><span>Monto total del recorrido</span><strong>@TourMontoTexto</strong></div>
        }
        else
        {
            <div><span>Total clientes en ruta</span><strong>@VisibleStops.Count</strong></div>
            <div><span>Programados del dia</span><strong>@VisibleStops.Count</strong></div>
            <div><span>Con imagen</span><strong>@ClientesConImagenTexto</strong></div>
            <div><span>Ultima visita +15 dias</span><strong>@ClientesConVisitaVencidaTexto</strong></div>
        }
    </section>

    <section class="route-map-shell">
        <aside class="route-sidebar">
            <div class="control-card">
                <label class="form-label">Ruta</label>
                <select class="form-select" value="@_routeId" @onchange="OnRouteChangedAsync">
                    <option value="0">Selecciona una ruta</option>
        @foreach (var route in _routes)
        {
            <option value="@route.IdRuta">@route.Nombre</option>
        }
                </select>

                @if (_mode == MapMode.Tour)
                {
                    <label class="form-label mt-3">Fecha de trabajo</label>
                    <input class="form-control" type="date" value="@_fechaTrabajo.ToString("yyyy-MM-dd")" @onchange="OnFechaTrabajoChangedAsync" />

                    <button class="btn btn-primary w-100 mt-3" type="button" @onclick="BuscarRecorridoAsync" disabled="@(_routeId <= 0 || _loading)">
                        <i class="material-icons-outlined">search</i>
                        Buscar
                    </button>
                }
                else
                {
                    <label class="form-label mt-3">Fecha de trabajo</label>
                    <input class="form-control" type="date" value="@_fechaTrabajo.ToString("yyyy-MM-dd")" @onchange="OnFechaTrabajoChangedAsync" />
                }

                @if (_mode == MapMode.Route)
                {
                    <label class="form-label mt-3">Dia de la semana</label>
                    <div class="chip-filter-grid">
                        @foreach (var dia in _diasSemana)
                        {
                            <button type="button" class="@DayClass(dia.Numero)" @onclick='@(() => SetDayAsync(dia.Numero))'>@dia.Nombre</button>
                        }
                    </div>

                    <label class="form-label mt-3">Frecuencia</label>
                    <div class="chip-filter-grid">
                        @foreach (var frecuencia in _frecuencias)
                        {
                            <button type="button" class="@FrequencyClass(frecuencia)" @onclick='@(() => SetFrequencyAsync(frecuencia))'>@frecuencia</button>
                        }
                    </div>
                }
            </div>

            <div class="stop-list">
                <div class="stop-list-title">
                    <h6>@(_mode == MapMode.Tour ? "Visitas del recorrido" : "Clientes del dia")</h6>
                    <span>@VisibleStops.Count</span>
                </div>

                @if (_loading)
                {
                    <div class="empty-state small">Cargando clientes...</div>
                }
                else if (_mode == MapMode.Tour && !_tourSearchExecuted)
                {
                    <div class="empty-state small">Selecciona ruta, fecha y presiona Buscar para cargar el recorrido.</div>
                }
                else if (!VisibleStops.Any())
                {
                    <div class="empty-state small">@(_mode == MapMode.Tour ? "El recorrido encontrado no devolvio visitas para este monitor." : "Selecciona ruta y fecha para consultar clientes programados.")</div>
                }
                else
                {
                    @foreach (var stop in VisibleStops)
                    {
                        <button type="button" class="stop-card @SelectedClass(stop)" @onclick="() => SelectStopAsync(stop)">
                            <span class="stop-order">@stop.Order</span>
                            <span class="stop-main">
                                <strong>@stop.Name</strong>
                                <small>@stop.Address</small>
                                @if (_mode == MapMode.Tour)
                                {
                                    <small class="@TrasladoBadgeClass(stop)">@TrasladoMonitorText(stop)</small>
                                }
                            </span>
                            <span class="status-dot @StatusClass(stop.Status)"></span>
                        </button>
                    }
                }
            </div>
        </aside>

        <main class="map-stage">
            <div class="map-topbar">
                <div>
                    <span class="source-pill">Mapa real con puntos</span>
                    <span class="text-muted">@MapStatusText</span>
                </div>
                <div class="map-tools">
                    @if (!string.IsNullOrWhiteSpace(CurrentMapUrl))
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="@CurrentMapUrl" target="_blank" rel="noopener noreferrer">
                            <i class="material-icons-outlined">open_in_new</i>
                            Abrir mapa
                        </a>
                    }
                </div>
            </div>

            <div class="map-canvas map-canvas-real">
                @if (!VisibleStops.Any())
                {
                    <div class="empty-state">
                        <i class="material-icons-outlined">map</i>
                        <strong>Sin puntos en el mapa</strong>
                        <span>@(_mode == MapMode.Tour ? "Presiona Buscar para revisar el recorrido encontrado." : "Elige una ruta y fecha para revisar la programacion del dia.")</span>
                    </div>
                }
                else if (!CanShowMap)
                {
                    <div class="empty-state">
                        <i class="material-icons-outlined">map</i>
                        <strong>Mapa no configurado</strong>
                        <span>@MapConfigMessage</span>
                    </div>
                }
                else if (CurrentBounds is null)
                {
                    <div class="empty-state">
                        <i class="material-icons-outlined">location_off</i>
                        <strong>Sin coordenadas validas</strong>
                        <span>Los puntos visibles no tienen latitud y longitud confiables para dibujarse en el mapa.</span>
                    </div>
                }
                else
                {
                    <div id="@MapElementId" class="google-map-frame" aria-label="Mapa general de ruta"></div>
                }
            </div>
        </main>

        <aside class="detail-panel">
            @if (_mode == MapMode.Tour)
            {
                <div class="route-focus-card mb-3">
                    <div class="panel-head compact-head">
                        <div>
                            <h5>Resumen del recorrido</h5>
                            <small>@TourResumenTitulo</small>
                        </div>
                    </div>
                    <div class="detail-grid route-focus-grid">
                        <span>Ruta</span><strong>@RouteNameText</strong>
                        <span>Fecha</span><strong>@_fechaTrabajo.ToString("dd/MM/yyyy")</strong>
                        <span>Recorrido</span><strong>@TextOrDash(SelectedRecorridoNombre)</strong>
                        <span>Programados</span><strong>@TourProgramadosTexto</strong>
                        <span>Visitados</span><strong>@TourVisitadosTexto</strong>
                        <span>No visitados</span><strong>@TourNoVisitadosTexto</strong>
                        <span>Monto venta</span><strong>@TourMontoTexto</strong>
                    </div>
                </div>

                <div class="tour-tabs-card mb-3">
                    <div class="tour-tabs">
                        <button type="button" class="@TourTabClass("resumen")" @onclick='() => SetTourTab("resumen")'>Resumen</button>
                        <button type="button" class="@TourTabClass("visitas")" @onclick='() => SetTourTab("visitas")'>Visitas</button>
                        <button type="button" class="@TourTabClass("pendientes")" @onclick='() => SetTourTab("pendientes")'>No visitados</button>
                        <button type="button" class="@TourTabClass("cierre")" @onclick='() => SetTourTab("cierre")'>Cierre</button>
                    </div>

                    @if (_loadingTourDetail)
                    {
                        <div class="empty-state small">Cargando detalle del recorrido...</div>
                    }
                    else if (_tourTab == "resumen")
                    {
                        <div class="detail-grid route-focus-grid">
                            <span>Vendedor</span><strong>@TextOrDash(_tourCierre?.NombreVendedor)</strong>
                            <span>Inicio</span><strong>@FormatDateTime(_tourCierre?.FechaInicioUtc)</strong>
                            <span>Min recorrido</span><strong>@NumberOrDash(_tourCierre?.MinutosRecorrido)</strong>
                            <span>Visitas con venta</span><strong>@(_tourVisitas?.Kpi.VisitasConVenta ?? _tourCierre?.VisitasConVenta ?? 0)</strong>
                            <span>Visitas sin venta</span><strong>@(_tourVisitas?.Kpi.VisitasSinVenta ?? _tourCierre?.VisitasSinVenta ?? 0)</strong>
                            <span>Visitas extra</span><strong>@(_tourVisitas?.Kpi.VisitasExtra ?? _tourCierre?.TotalVisitasExtra ?? 0)</strong>
                            <span>Lecturas QR</span><strong>@((_tourVisitas?.Kpi.LecturasQr ?? 0).ToString("N0"))</strong>
                            <span>GPS valido 50m</span><strong>@((_tourVisitas?.Kpi.VisitasGpsValido ?? 0).ToString("N0"))</strong>
                            <span>Tiempo traslado</span><strong>@((_tourVisitas?.Kpi.TiempoMuertoMinutos ?? 0).ToString("N0")) min</strong>
                            <span>Efectivo</span><strong>@Money(_tourCierre?.TotalEfectivo ?? 0m)</strong>
                            <span>Credito</span><strong>@Money(_tourCierre?.TotalCredito ?? 0m)</strong>
                            <span>Cobros</span><strong>@Money(_tourCierre?.TotalCobros ?? 0m)</strong>
                            <span>Cancelaciones</span><strong>@Money(_tourCierre?.TotalCancelaciones ?? 0m)</strong>
                            <span>Gastos</span><strong>@Money(_tourCierre?.TotalGastos ?? 0m)</strong>
                            <span>Gasolina</span><strong>@Money(_tourCierre?.TotalGasolina ?? 0m)</strong>
                            <span>Liquido</span><strong>@Money(_tourCierre?.LiquidoARecibir ?? 0m)</strong>
                        </div>
                    }
                    else if (_tourTab == "visitas")
                    {
                        @if (_tourVisitas?.Visitas?.Any() == true)
                        {
                            <div class="tour-list">
                                @foreach (var visita in _tourVisitas.Visitas)
                                {
                                    <div class="tour-list-item">
                                        <strong>@visita.Cliente</strong>
                                        <small>#@VisitOrder(visita.IdCliente) · @TextOrDash(visita.Sucursal)</small>
                                        <small>@TextOrDash(visita.Estatus) · @Money(visita.MontoVentas)</small>
                                        <small class="@TrasladoBadgeClass(visita)">
                                            @TrasladoMonitorText(visita)
                                        </small>
                                        <small class="@GpsBadgeClass(visita.GpsValido50m)">
                                            @GpsMonitorText(visita.DistanciaMetros, visita.GpsValido50m)
                                        </small>
                                        <small>@TextOrDash(visita.ProductosVendidos)</small>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state small">No hay visitas cargadas para este recorrido.</div>
                        }
                    }
                    else if (_tourTab == "pendientes")
                    {
                        @if (_tourVisitas?.NoVisitados?.Any() == true)
                        {
                            <div class="tour-list">
                                @foreach (var cliente in _tourVisitas.NoVisitados)
                                {
                                    <div class="tour-list-item">
                                        <strong>@cliente.Cliente</strong>
                                        <small>#@cliente.Orden · @TextOrDash(cliente.Sucursal)</small>
                                        <small>@TextOrDash(cliente.TipoVisita) · @TextOrDash(cliente.Telefono)</small>
                                        <small>@TextOrDash(cliente.Direccion)</small>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state small">No hay clientes pendientes para este recorrido.</div>
                        }
                    }
                    else
                    {
                        <div class="tour-text-block">
                            <h6>Resumen de cierre</h6>
                            <pre>@TextBlockOrDash(TourResumenCierreTexto)</pre>
                            <h6>Ventas cierre</h6>
                            <pre>@TextBlockOrDash(TourVentasCierreTexto)</pre>
                            <h6>Inventario inicio</h6>
                            <pre>@TextBlockOrDash(TourInventarioInicioTexto)</pre>
                            <h6>Inventario cierre</h6>
                            <pre>@TextBlockOrDash(TourInventarioCierreTexto)</pre>
                            <h6>Recargas en ruta</h6>
                            <pre>@TextBlockOrDash(TourRecargasTexto)</pre>
                        </div>
                    }
                </div>
            }

            @if (_selected is null)
            {
                <div class="empty-state small">
                    <i class="material-icons-outlined">storefront</i>
                    <strong>@(_mode == MapMode.Tour ? "Selecciona una visita" : "Selecciona un cliente")</strong>
                    <span>@(_mode == MapMode.Tour ? "Veras venta, productos y datos generales del cliente visitado." : "Veras telefono, credito, estado y acciones rapidas.")</span>
                </div>
            }
            else
            {
                <div class="detail-head">
                    <span class="status-dot @StatusClass(_selected.Status)"></span>
                    <div>
                        <h5>@_selected.Name</h5>
                        <small>@_selected.RouteName</small>
                    </div>
                </div>

                <div class="client-photo-card">
                    @if (_loadingImage)
                    {
                        <div class="photo-empty">Cargando imagen...</div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_selectedImageDataUrl))
                    {
                        <img src="@_selectedImageDataUrl" alt="Foto de cliente" />
                    }
                    else
                    {
                        <div class="photo-empty">No tiene imagen</div>
                    }
                </div>

                <div class="detail-grid">
                    <span>Orden</span><strong>@_selected.Order</strong>
                    <span>Estado</span><strong>@StatusText(_selected.Status)</strong>
                    <span>Telefono</span><strong>@TextOrDash(_selected.Phone)</strong>
                    <span>RFC</span><strong>@TextOrDash(_selected.Rfc)</strong>
                    <span>Credito</span><strong>@_selected.CreditText</strong>
                    @if (_mode == MapMode.Route)
                    {
                        <span>Ultima visita</span><strong class="@VisitAgeClass(_selected)">@_selected.LastVisit</strong>
                        <span>Frecuencia</span><strong>@FrequencyLabel(_selected.FrequencyWeeks)</strong>
                    }
                    else
                    {
                        <span>Resultado</span><strong>@(_selected.Status == VisitStatus.Done ? "Visitado" : "Sin cierre")</strong>
                        <span>Venta / top</span><strong class="preline">@TextOrDash(_selected.ProductTop)</strong>
                    }
                    <span>GPS</span><strong>@GeoText(_selected.GeoSource)</strong>
                    <span>Monto historico</span><strong>@Money(_selected.TotalSalesAmount)</strong>
                    <span>Facturacion</span><strong>@(_selected.HasBilling ? TextOrDash(_selected.BillingName) : "No factura")</strong>
                    @if (_mode == MapMode.Route)
                    {
                        <span>Top productos</span><strong class="preline">@TextOrDash(_selected.ProductTop)</strong>
                    }
                    <span>Direccion</span><strong>@_selected.Address</strong>
                </div>
            }
        </aside>
    </section>

    <section class="monitor-shortcuts">
        <a class="shortcut-card" href="@RecorridosRouteUrl">
            <span class="material-icons-outlined">route</span>
            <div>
                <strong>Recorridos</strong>
                <small>Consulta cierres y efectividad.</small>
            </div>
        </a>
        <a class="shortcut-card" href="@VisitasRouteUrl">
            <span class="material-icons-outlined">location_on</span>
            <div>
                <strong>Visitas</strong>
                <small>Auditoria y tiempos entre clientes.</small>
            </div>
        </a>
        <a class="shortcut-card" href="@VentasReportUrl">
            <span class="material-icons-outlined">bar_chart</span>
            <div>
                <strong>Reporte ventas</strong>
                <small>Busqueda y exportacion desde operacion.</small>
            </div>
        </a>
        <a class="shortcut-card" href="@ClientesReportUrl">
            <span class="material-icons-outlined">download</span>
            <div>
                <strong>Reporte clientes</strong>
                <small>Consulta base operativa por ruta.</small>
            </div>
        </a>
    </section>
</div>

<style>
    .route-map-page{width:calc(100vw - 2rem);margin-left:calc(50% - 50vw + 1rem);min-height:calc(100vh - 150px)}
    .route-map-header{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1rem}
    .route-map-header h4{margin:0 0 .2rem;font-weight:700;color:#344054}
    .route-map-header p{margin:0;color:#667085}
    .route-map-actions{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;justify-content:flex-end}
    .route-map-actions .btn{display:inline-flex;align-items:center;gap:.35rem}
    .route-map-actions i{font-size:18px}
    .map-metrics{display:grid;grid-template-columns:repeat(4,minmax(120px,1fr));gap:.75rem;margin-bottom:.75rem}
    .map-metrics div,.control-card,.map-stage,.detail-panel{background:#fff;border:1px solid #e6eaf0;border-radius:8px;box-shadow:0 4px 16px rgba(18,38,63,.04)}
    .map-metrics div{padding:.85rem 1rem}
    .map-metrics span{display:block;color:#667085;font-size:.8rem}
    .map-metrics strong{font-size:1.2rem;color:#344054}
    .route-map-shell{display:grid;grid-template-columns:minmax(280px,340px) 1fr minmax(270px,330px);gap:.75rem;align-items:stretch}
    .route-sidebar{display:flex;flex-direction:column;gap:.75rem;min-height:calc(100vh - 300px)}
    .control-card{padding:1rem}
    .control-card.compact{padding:.85rem 1rem}
    .chip-filter-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.45rem}
    .chip-filter-grid button{border:1px solid #d7dde6;background:#fff;color:#475467;border-radius:7px;padding:.45rem .55rem;font-size:.86rem}
    .chip-filter-grid button.active{border-color:#0d6efd;background:#eaf2ff;color:#0d6efd;font-weight:650}
    .chip-filter-grid button:disabled{background:#f8fafc;color:#98a2b3;border-color:#e5e7eb;cursor:not-allowed}
    .stop-list{background:#fff;border:1px solid #e6eaf0;border-radius:8px;overflow:auto;max-height:calc(100vh - 455px)}
    .stop-list-title{position:sticky;top:0;background:#fff;z-index:2;display:flex;align-items:center;justify-content:space-between;padding:.9rem 1rem;border-bottom:1px solid #eef2f7}
    .stop-list-title h6{margin:0;font-weight:700}
    .stop-list-title span{background:#0d6efd;color:#fff;border-radius:999px;min-width:28px;text-align:center;font-size:.8rem;padding:.1rem .45rem}
    .stop-card{width:100%;display:flex;align-items:center;gap:.7rem;border:0;border-bottom:1px solid #f1f4f8;background:#fff;padding:.8rem 1rem;text-align:left;color:#344054}
    .stop-card:hover,.stop-card.selected{background:#eaf2ff}
    .stop-order{width:30px;height:30px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;background:#eef2f7;font-weight:700;font-size:.78rem}
    .stop-main{flex:1;min-width:0}
    .stop-main strong,.stop-main small{display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .stop-main small{color:#667085}
    .stop-main .travel-ok{color:#067647;font-weight:700}
    .stop-main .travel-error{color:#b42318;font-weight:700}
    .status-dot{width:11px;height:11px;border-radius:50%;display:inline-flex;flex:0 0 auto;background:#98a2b3}
    .status-dot.pending,.pin.pending{background:#0d6efd}
    .status-dot.done,.pin.done{background:#198754}
    .status-dot.alert,.pin.alert{background:#dc3545}
    .map-stage{padding:1rem;min-height:calc(100vh - 300px);display:flex;flex-direction:column}
    .map-topbar{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:.75rem}
    .source-pill{display:inline-flex;align-items:center;background:#eaf2ff;color:#0d6efd;border-radius:999px;font-size:.78rem;font-weight:700;padding:.22rem .55rem;margin-right:.5rem}
    .map-tools{display:flex;align-items:center;gap:.35rem}
    .map-tools button{width:32px;height:32px;border:1px solid #d7dde6;background:#fff;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;color:#475467}
    .map-tools span{min-width:42px;text-align:center;color:#667085;font-size:.85rem}
    .map-canvas{position:relative;flex:1;min-height:620px;border:1px solid #dbe5ef;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#d9efe2,#f4f8fb 45%,#d8e7f8)}
    .map-canvas-real{background:#eef2f7}
    .google-map-frame{width:100%;height:100%;min-height:620px;border:0;display:block;border-radius:8px}
    .detail-panel{padding:1rem;min-height:calc(100vh - 300px)}
    .detail-head{display:flex;align-items:flex-start;gap:.65rem;padding-bottom:1rem;border-bottom:1px solid #eef2f7;margin-bottom:1rem}
    .detail-head h5{margin:0;font-weight:700;color:#344054}
    .detail-head small{color:#667085}
    .client-photo-card{margin-bottom:1rem}
    .client-photo-card img{width:100%;height:190px;object-fit:cover;border-radius:10px;border:1px solid #e6eaf0;background:#f8fafc}
    .photo-empty{height:190px;border:1px dashed #d0d8e2;border-radius:10px;display:flex;align-items:center;justify-content:center;color:#667085;background:#f8fafc;font-weight:600}
    .detail-grid{display:grid;grid-template-columns:105px 1fr;gap:.65rem .75rem;font-size:.9rem}
    .detail-grid span{color:#667085}
    .detail-grid strong{font-weight:650;color:#344054}
    .visit-late{color:#b42318 !important}
    .preline{white-space:pre-line}
    .tour-tabs-card{border:1px solid #e6eaf0;border-radius:10px;padding:.85rem;background:linear-gradient(180deg,#fff,#f8fbff)}
    .tour-tabs{display:flex;gap:.45rem;flex-wrap:wrap;margin-bottom:.85rem}
    .tour-tabs button{border:1px solid #d7dde6;background:#fff;color:#475467;border-radius:999px;padding:.38rem .7rem;font-size:.82rem;font-weight:600}
    .tour-tabs button.active{border-color:#0d6efd;background:#eaf2ff;color:#0d6efd}
    .tour-list{display:flex;flex-direction:column;gap:.6rem;max-height:360px;overflow:auto}
    .tour-list-item{border:1px solid #e6eaf0;border-radius:8px;padding:.7rem .8rem;background:#fff}
