            $"Fecha: {_fechaTrabajo:dd/MM/yyyy}",
            $"Recorrido: {TextOrDash(SelectedRecorridoNombre)}",
            $"Programados: {TourProgramadosTexto}",
            $"Visitados: {TourVisitadosTexto}",
            $"No visitados: {TourNoVisitadosTexto}",
