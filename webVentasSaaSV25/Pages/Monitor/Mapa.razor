            $"Sin venta: {_tourVisitas?.Kpi.VisitasSinVenta ?? _tourCierre?.VisitasSinVenta ?? 0}",
            $"Extra: {_tourVisitas?.Kpi.VisitasExtra ?? _tourCierre?.TotalVisitasExtra ?? 0}",
            $"Monto total: {TourMontoTexto}"
