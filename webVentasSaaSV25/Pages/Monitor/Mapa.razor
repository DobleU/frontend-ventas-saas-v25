    private static string GpsMonitorText(decimal? distanciaMetros, bool gpsValido50m)
    {
        if (gpsValido50m)
        {
            return distanciaMetros.HasValue
                ? $"Ubicacion OK · {distanciaMetros.Value:N0} m"
                : "Ubicacion OK";
        }

