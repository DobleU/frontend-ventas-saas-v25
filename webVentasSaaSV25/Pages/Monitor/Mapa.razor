    private async Task LoadTourDetailAsync()
    {
        if (_mode != MapMode.Tour || _routeId <= 0 || _recorridoId <= 0)
            return;

        _loadingTourDetail = true;
        _tourDetailError = null;

        var (visitas, visitasError) = await MapaApi.GetReporteVisitasAsync(_routeId, _fechaTrabajo, _recorridoId);
        var (cierre, cierreError) = await MapaApi.GetRecorridoCierreCompletoAsync(_recorridoId);

        _loadingTourDetail = false;
        _tourVisitas = visitas;
        _tourCierre = cierre;

        _error = FirstError(_error, visitasError);
        _tourDetailError = FirstError(cierreError);
        if (_tourVisitas?.Visitas?.Any() == true)
        {
            var visitasPorCliente = _tourVisitas.Visitas
                .OrderBy(x => x.FechaInicioUtc ?? DateTime.MaxValue)
                .ThenBy(x => x.IdVisita)
                .GroupBy(x => x.IdCliente)
                .ToDictionary(g => g.Key, g => new Queue<ReporteVisitaRowResponse>(g));

            _stops = _stops
                .OrderBy(x => visitasPorCliente.TryGetValue(x.Id, out var queue) && queue.TryPeek(out var visita) ? visita.IdVisita : long.MaxValue)
                .ThenBy(x => x.Order)
                .Select(x =>
                {
                    if (!visitasPorCliente.TryGetValue(x.Id, out var queue) || !queue.TryDequeue(out var visita))
                        return x;

                    return x with
                    {
                        SegundosTraslado = visita.SegundosTraslado,
                        MinutosTraslado = visita.MinutosTraslado
                    };
                })
                .ToList();
        }
        _tourTab = "resumen";
    }
