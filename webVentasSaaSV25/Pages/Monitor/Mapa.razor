@page "/monitor/mapa"
@inject MonitorMapaService MapaApi

<PageTitle>Mapa General - Integra*System</PageTitle>

<div class="route-map-page">
    <header class="route-map-header">
        <div>
            <h4>Mapa General</h4>
            <p>Planeacion visual de ruta, clientes y visitas.</p>
        </div>

        <div class="route-map-actions">
            <button class="btn btn-outline-secondary" type="button" @onclick="LoadDemo">
                <i class="material-icons-outlined">science</i>
                Demo
            </button>
            <button class="btn btn-outline-primary" type="button" @onclick="ReloadRouteAsync" disabled="@(_routeId <= 0 || _loading)">
                <i class="material-icons-outlined">refresh</i>
                Recargar
            </button>
            <div class="btn-group" role="group" aria-label="Modo">
                <button class="btn @ModeClass(MapMode.Route)" type="button" @onclick="() => SetMode(MapMode.Route)">Ruta</button>
                <button class="btn @ModeClass(MapMode.Tour)" type="button" @onclick="() => SetMode(MapMode.Tour)">Recorrido</button>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-warning py-2">@_error</div>
    }

    <section class="map-metrics" aria-label="Resumen de mapa">
        <div><span>Clientes</span><strong>@VisibleStops.Count</strong></div>
        <div><span>Visitados</span><strong>@VisibleStops.Count(s => s.Status == VisitStatus.Done)</strong></div>
        <div><span>Pendientes</span><strong>@VisibleStops.Count(s => s.Status == VisitStatus.Pending)</strong></div>
        <div><span>Alertas</span><strong>@VisibleStops.Count(s => s.Status == VisitStatus.Alert)</strong></div>
    </section>

    <section class="route-map-shell">
        <aside class="route-sidebar">
            <div class="control-card">
                <label class="form-label">Ruta</label>
                <select class="form-select" value="@_routeId" @onchange="OnRouteChangedAsync">
                    <option value="0">Selecciona una ruta</option>
        @foreach (var route in _routes)
        {
            <option value="@route.IdRuta">@route.Nombre</option>
        }
                </select>

                @if (_mode == MapMode.Tour)
                {
                    <label class="form-label mt-3">Recorrido</label>
                    <select class="form-select" value="@_recorridoId" @onchange="OnRecorridoChangedAsync">
                        <option value="0">Selecciona un recorrido</option>
                        @foreach (var tour in _recorridos)
                        {
                            <option value="@tour.IdRecorrido">@tour.Nombre</option>
                        }
                    </select>
                }

                <label class="form-label mt-3">Buscar</label>
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="material-icons-outlined">search</i>
                    </span>
                    <input class="form-control" placeholder="Cliente, RFC, telefono" @bind="_search" @bind:event="oninput" />
                </div>
            </div>

            <div class="control-card compact">
                <label class="form-label">Estado</label>
                <div class="status-filter">
                    <button type="button" class="@FilterClass(null)" @onclick="() => SetFilter(null)">Todos</button>
                    <button type="button" class="@FilterClass(VisitStatus.Pending)" @onclick="() => SetFilter(VisitStatus.Pending)">Pendientes</button>
                    <button type="button" class="@FilterClass(VisitStatus.Done)" @onclick="() => SetFilter(VisitStatus.Done)">Visitados</button>
                    <button type="button" class="@FilterClass(VisitStatus.Alert)" @onclick="() => SetFilter(VisitStatus.Alert)">Alertas</button>
                </div>
            </div>

            <div class="stop-list">
                <div class="stop-list-title">
                    <h6>Itinerario</h6>
                    <span>@VisibleStops.Count</span>
                </div>

                @if (_loading)
                {
                    <div class="empty-state small">Cargando clientes...</div>
                }
                else if (!VisibleStops.Any())
                {
                    <div class="empty-state small">Selecciona una ruta o usa Demo.</div>
                }
                else
                {
                    @foreach (var stop in VisibleStops)
                    {
                        <button type="button" class="stop-card @SelectedClass(stop)" @onclick="() => SelectStop(stop)">
                            <span class="stop-order">@stop.Order</span>
                            <span class="stop-main">
                                <strong>@stop.Name</strong>
                                <small>@stop.Address</small>
                            </span>
                            <span class="status-dot @StatusClass(stop.Status)"></span>
                        </button>
                    }
                }
            </div>
        </aside>

        <main class="map-stage">
            <div class="map-topbar">
                <div>
                    <span class="source-pill">@(_demoMode ? "Demo local" : "Datos API")</span>
                    <span class="text-muted">@MapStatusText</span>
                </div>
                <div class="map-tools">
                    <button type="button" title="Alejar" @onclick="ZoomOut"><i class="material-icons-outlined">remove</i></button>
                    <span>@($"{_zoom:0.0}x")</span>
                    <button type="button" title="Acercar" @onclick="ZoomIn"><i class="material-icons-outlined">add</i></button>
                    <button type="button" title="Centrar" @onclick="ResetView"><i class="material-icons-outlined">my_location</i></button>
                </div>
            </div>

            <div class="map-canvas">
                <div class="map-grid"></div>
                @if (!VisibleStops.Any())
                {
                    <div class="empty-state">
                        <i class="material-icons-outlined">map</i>
                        <strong>Sin puntos en el mapa</strong>
                        <span>Elige una ruta o presiona Demo para probar la operacion.</span>
                    </div>
                }
                else
                {
                    <div class="map-layer" style="transform:translate(@_panX%, @_panY%) scale(@_zoom.ToString(System.Globalization.CultureInfo.InvariantCulture));">
                        <svg class="route-svg" viewBox="0 0 100 100" preserveAspectRatio="none">
                            <polyline points="@RoutePath" />
                        </svg>

                        @foreach (var stop in VisibleStops)
                        {
                            <button type="button"
                                    class="pin @StatusClass(stop.Status) @SelectedClass(stop)"
                                    data-geo="@stop.GeoSource"
                                    style="left:@stop.X%;top:@stop.Y%"
                                    title="@stop.Name"
                                    @onclick="() => SelectStop(stop)">
                                <i class="material-icons-outlined">@GeoIcon(stop.GeoSource)</i>
                                <span>@stop.Order</span>
                            </button>
                        }
                    </div>
                }
            </div>
        </main>

        <aside class="detail-panel">
            @if (_selected is null)
            {
                <div class="empty-state small">
                    <i class="material-icons-outlined">storefront</i>
                    <strong>Selecciona un cliente</strong>
                    <span>Veras telefono, credito, estado y acciones rapidas.</span>
                </div>
            }
            else
            {
                <div class="detail-head">
                    <span class="status-dot @StatusClass(_selected.Status)"></span>
                    <div>
                        <h5>@_selected.Name</h5>
                        <small>@_selected.RouteName</small>
                    </div>
                </div>

                <div class="detail-grid">
                    <span>Orden</span><strong>@_selected.Order</strong>
                    <span>Estado</span><strong>@StatusText(_selected.Status)</strong>
                    <span>Telefono</span><strong>@TextOrDash(_selected.Phone)</strong>
                    <span>RFC</span><strong>@TextOrDash(_selected.Rfc)</strong>
                    <span>Credito</span><strong>@_selected.CreditText</strong>
                    <span>Ultima visita</span><strong>@_selected.LastVisit</strong>
                    <span>GPS</span><strong>@GeoText(_selected.GeoSource)</strong>
                    <span>Top productos</span><strong class="preline">@TextOrDash(_selected.ProductTop)</strong>
                    <span>Direccion</span><strong>@_selected.Address</strong>
                </div>

                <div class="detail-actions">
                    <button class="btn btn-sm btn-primary" type="button" @onclick="MarkDone">Marcar visitado</button>
                    <button class="btn btn-sm btn-outline-danger" type="button" @onclick="MarkAlert">Marcar alerta</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="MarkPending">Pendiente</button>
                </div>
            }
        </aside>
    </section>
</div>

<style>
    .route-map-page{width:calc(100vw - 2rem);margin-left:calc(50% - 50vw + 1rem);min-height:calc(100vh - 150px)}
    .route-map-header{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1rem}
    .route-map-header h4{margin:0 0 .2rem;font-weight:700;color:#344054}
    .route-map-header p{margin:0;color:#667085}
    .route-map-actions{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;justify-content:flex-end}
    .route-map-actions .btn{display:inline-flex;align-items:center;gap:.35rem}
    .route-map-actions i{font-size:18px}
    .map-metrics{display:grid;grid-template-columns:repeat(4,minmax(120px,1fr));gap:.75rem;margin-bottom:.75rem}
    .map-metrics div,.control-card,.map-stage,.detail-panel{background:#fff;border:1px solid #e6eaf0;border-radius:8px;box-shadow:0 4px 16px rgba(18,38,63,.04)}
    .map-metrics div{padding:.85rem 1rem}
    .map-metrics span{display:block;color:#667085;font-size:.8rem}
    .map-metrics strong{font-size:1.2rem;color:#344054}
    .route-map-shell{display:grid;grid-template-columns:minmax(280px,340px) 1fr minmax(270px,330px);gap:.75rem;align-items:stretch}
    .route-sidebar{display:flex;flex-direction:column;gap:.75rem;min-height:calc(100vh - 300px)}
    .control-card{padding:1rem}
    .control-card.compact{padding:.85rem 1rem}
    .status-filter{display:grid;grid-template-columns:1fr 1fr;gap:.45rem}
    .status-filter button{border:1px solid #d7dde6;background:#fff;color:#475467;border-radius:7px;padding:.45rem .55rem;font-size:.86rem}
    .status-filter button.active{border-color:#0d6efd;background:#eaf2ff;color:#0d6efd;font-weight:650}
    .stop-list{background:#fff;border:1px solid #e6eaf0;border-radius:8px;overflow:auto;max-height:calc(100vh - 455px)}
    .stop-list-title{position:sticky;top:0;background:#fff;z-index:2;display:flex;align-items:center;justify-content:space-between;padding:.9rem 1rem;border-bottom:1px solid #eef2f7}
    .stop-list-title h6{margin:0;font-weight:700}
    .stop-list-title span{background:#0d6efd;color:#fff;border-radius:999px;min-width:28px;text-align:center;font-size:.8rem;padding:.1rem .45rem}
    .stop-card{width:100%;display:flex;align-items:center;gap:.7rem;border:0;border-bottom:1px solid #f1f4f8;background:#fff;padding:.8rem 1rem;text-align:left;color:#344054}
    .stop-card:hover,.stop-card.selected{background:#eaf2ff}
    .stop-order{width:30px;height:30px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;background:#eef2f7;font-weight:700;font-size:.78rem}
    .stop-main{flex:1;min-width:0}
    .stop-main strong,.stop-main small{display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .stop-main small{color:#667085}
    .status-dot{width:11px;height:11px;border-radius:50%;display:inline-flex;flex:0 0 auto;background:#98a2b3}
    .status-dot.pending,.pin.pending{background:#0d6efd}
    .status-dot.done,.pin.done{background:#198754}
    .status-dot.alert,.pin.alert{background:#dc3545}
    .map-stage{padding:1rem;min-height:calc(100vh - 300px);display:flex;flex-direction:column}
    .map-topbar{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:.75rem}
    .source-pill{display:inline-flex;align-items:center;background:#eaf2ff;color:#0d6efd;border-radius:999px;font-size:.78rem;font-weight:700;padding:.22rem .55rem;margin-right:.5rem}
    .map-tools{display:flex;align-items:center;gap:.35rem}
    .map-tools button{width:32px;height:32px;border:1px solid #d7dde6;background:#fff;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;color:#475467}
    .map-tools span{min-width:42px;text-align:center;color:#667085;font-size:.85rem}
    .map-canvas{position:relative;flex:1;min-height:620px;border:1px solid #dbe5ef;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#d9efe2,#f4f8fb 45%,#d8e7f8)}
    .map-grid{position:absolute;inset:0;background:linear-gradient(90deg,transparent 49%,rgba(255,255,255,.55) 50%,transparent 51%),linear-gradient(0deg,transparent 49%,rgba(255,255,255,.55) 50%,transparent 51%);background-size:90px 90px}
    .map-layer{position:absolute;inset:0;transform-origin:center;transition:transform .18s ease}
    .route-svg{position:absolute;inset:0;width:100%;height:100%;z-index:1;pointer-events:none}
    .route-svg polyline{fill:none;stroke:#0d6efd;stroke-width:.48;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:1.2 1;opacity:.82}
    .pin{position:absolute;z-index:2;transform:translate(-50%,-100%);width:34px;height:34px;border:2px solid #fff;border-radius:50% 50% 50% 8px;rotate:45deg;color:#fff;box-shadow:0 10px 20px rgba(16,24,40,.2);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.74rem}
    .pin span,.pin i{rotate:-45deg}
    .pin i{display:none;font-size:17px}
    .pin[data-geo="REAL_INICIO"]{border-style:dashed}
    .pin[data-geo="CLIENTE_DIR"]{background:#6f42c1}
    .pin[data-geo="CLIENTE_DIR"] i,.pin[data-geo="SIN_COORDENADA"] i{display:block}
    .pin[data-geo="CLIENTE_DIR"] span,.pin[data-geo="SIN_COORDENADA"] span{display:none}
    .pin[data-geo="SIN_COORDENADA"]{background:#6c757d;opacity:.72}
    .pin.selected{scale:1.18;z-index:4;box-shadow:0 12px 28px rgba(220,53,69,.35)}
    .detail-panel{padding:1rem;min-height:calc(100vh - 300px)}
    .detail-head{display:flex;align-items:flex-start;gap:.65rem;padding-bottom:1rem;border-bottom:1px solid #eef2f7;margin-bottom:1rem}
    .detail-head h5{margin:0;font-weight:700;color:#344054}
    .detail-head small{color:#667085}
    .detail-grid{display:grid;grid-template-columns:105px 1fr;gap:.65rem .75rem;font-size:.9rem}
    .detail-grid span{color:#667085}
    .detail-grid strong{font-weight:650;color:#344054}
    .preline{white-space:pre-line}
    .detail-actions{display:flex;gap:.45rem;flex-wrap:wrap;margin-top:1.25rem}
    .empty-state{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:#667085;gap:.25rem;padding:1rem}
    .empty-state.small{position:static;min-height:180px}
    .empty-state i{font-size:52px;color:#98a2b3}
    @@media (max-width:1399.98px){.route-map-shell{grid-template-columns:320px 1fr}.detail-panel{grid-column:1/-1;min-height:auto}.map-canvas{min-height:520px}}
    @@media (max-width:991.98px){.route-map-page{width:100%;margin-left:0}.route-map-header{flex-direction:column}.map-metrics{grid-template-columns:1fr 1fr}.route-map-shell{grid-template-columns:1fr}.stop-list{max-height:360px}.map-stage,.route-sidebar{min-height:auto}.map-canvas{min-height:430px}}
</style>

@code {
    private enum MapMode { Route, Tour }
    private enum VisitStatus { Pending, Done, Alert }

    private MapMode _mode = MapMode.Route;
    private VisitStatus? _statusFilter;
    private int _routeId;
    private long _recorridoId;
    private string? _search;
    private string? _error;
    private bool _loading;
    private bool _demoMode;
    private decimal _zoom = 1m;
    private int _panX;
    private int _panY;
    private List<MapaRutaOptionResponse> _routes = [];
    private List<MapaRecorridoOptionResponse> _recorridos = [];
    private List<MapStop> _stops = [];
    private MapStop? _selected;

    private List<MapStop> VisibleStops => _stops
        .Where(s => _statusFilter is null || s.Status == _statusFilter)
        .Where(MatchesSearch)
        .OrderBy(s => s.Order)
        .ToList();

    private string RoutePath => string.Join(" ", VisibleStops.Select(s => $"{s.X},{s.Y}"));

    private string MapStatusText => VisibleStops.Any()
        ? $"{VisibleStops.Count} punto(s) listos para operar."
        : "Sin clientes cargados para esta ruta.";

    protected override async Task OnInitializedAsync()
    {
        var (routes, error) = await MapaApi.GetRutasAsync();
        _routes = routes?.ToList() ?? [];
        _error = error;
    }

    private async Task OnRouteChangedAsync(ChangeEventArgs e)
    {
        _routeId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        await LoadRecorridosAsync();
        await LoadRouteAsync();
    }

    private async Task OnRecorridoChangedAsync(ChangeEventArgs e)
    {
        _recorridoId = long.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        await LoadRouteAsync();
    }

    private async Task ReloadRouteAsync() => await LoadRouteAsync();

    private async Task LoadRecorridosAsync()
    {
        var (items, error) = await MapaApi.GetRecorridosAsync(_routeId > 0 ? _routeId : null);
        _recorridos = items?.ToList() ?? [];
        _error ??= error;
        _recorridoId = _recorridos.FirstOrDefault()?.IdRecorrido ?? 0;
    }

    private async Task LoadRouteAsync()
    {
        _demoMode = false;
        _selected = null;
        _stops = [];
        _error = null;
        ResetView();

        if (_routeId <= 0) return;
        if (_mode == MapMode.Tour && _recorridoId <= 0)
        {
            await LoadRecorridosAsync();
            if (_recorridoId <= 0) return;
        }

        _loading = true;
        var (map, error) = await MapaApi.GetRutaAsync(new MapaRutaRequest
        {
            IdRuta = _routeId,
            IdRecorrido = _mode == MapMode.Tour ? _recorridoId : null,
            Search = _search,
            Modo = _mode == MapMode.Tour ? "recorrido" : "ruta"
        });
        _loading = false;
        _error = error;

        _stops = map?.Puntos.Select(FromApiPoint).ToList() ?? [];
        _selected = _stops.FirstOrDefault();
    }

    private void LoadDemo()
    {
        _demoMode = true;
        _error = null;
        _routeId = _routeId <= 0 ? -1 : _routeId;
        var routeName = _routeId > 0 ? _routes.FirstOrDefault(r => r.IdRuta == _routeId)?.Nombre ?? "Ruta seleccionada" : "Ruta demo norte";

        _stops = Enumerable.Range(1, 18)
            .Select(i => new MapStop(
                Id: i,
                Order: i,
                Name: $"Cliente demo {i:00}",
                RouteName: routeName,
                Address: $"Zona {((i - 1) % 6) + 1}, manzana {20 + i}",
                Phone: $"555-02{i:000}",
                Rfc: $"DEMO{i:000}0101AA{i % 10}",
                CreditText: i % 4 == 0 ? $"Limite {(3000 + i * 250):C0}" : "Sin credito",
                LastVisit: i % 3 == 0 ? "Ayer" : "Sin visita reciente",
                Status: i % 7 == 0 ? VisitStatus.Alert : i % 5 == 0 ? VisitStatus.Done : VisitStatus.Pending,
                X: PositionX(i),
                Y: PositionY(i),
                GeoSource: i % 6 == 0 ? "CLIENTE_DIR" : "REAL_FIN",
                ProductTop: "BOT|000100\nBTP|000058\nCAUTR|000002"))
            .ToList();

        _selected = _stops.FirstOrDefault();
        ResetView();
    }

    private static MapStop FromApiPoint(MapaClientePuntoResponse point)
        => new(
            Id: point.IdCliente,
            Order: point.Orden,
            Name: point.Nombre,
            RouteName: point.NombreRuta ?? "Sin ruta",
            Address: point.Direccion ?? "Direccion pendiente",
            Phone: point.Telefono,
            Rfc: point.Rfc,
            CreditText: point.Credito,
            LastVisit: point.UltimaVisita,
            GeoSource: point.GeoSource,
            ProductTop: point.ProductoTop,
            Status: point.Estado?.ToLowerInvariant() switch
            {
                "visitado" => VisitStatus.Done,
                "alerta" => VisitStatus.Alert,
                _ => VisitStatus.Pending
            },
            X: (int)Math.Clamp(point.X, 8, 92),
            Y: (int)Math.Clamp(point.Y, 10, 90));

    private bool MatchesSearch(MapStop stop)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        return stop.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || stop.Address.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || (stop.Phone?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
            || (stop.Rfc?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private void SelectStop(MapStop stop)
    {
        _selected = stop;
        _panX = Math.Clamp(50 - stop.X, -18, 18);
        _panY = Math.Clamp(50 - stop.Y, -18, 18);
    }

    private async Task SetMode(MapMode mode)
    {
        _mode = mode;
        if (_mode == MapMode.Tour)
            await LoadRecorridosAsync();
        await LoadRouteAsync();
    }
    private string ModeClass(MapMode mode) => _mode == mode ? "btn-primary" : "btn-outline-primary";
    private void SetFilter(VisitStatus? status) => _statusFilter = status;
    private string FilterClass(VisitStatus? status) => _statusFilter == status ? "active" : "";
    private string SelectedClass(MapStop stop) => _selected?.Id == stop.Id ? "selected" : "";
    private static string StatusClass(VisitStatus status) => status switch { VisitStatus.Done => "done", VisitStatus.Alert => "alert", _ => "pending" };
    private static string StatusText(VisitStatus status) => status switch { VisitStatus.Done => "Visitado", VisitStatus.Alert => "Alerta", _ => "Pendiente" };
    private static string TextOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "Sin dato" : value;
    private static string GeoIcon(string source) => source switch { "CLIENTE_DIR" => "place", "SIN_COORDENADA" => "location_off", _ => "near_me" };
    private static string GeoText(string source) => source switch
    {
        "REAL_FIN" => "GPS real de cierre",
        "REAL_INICIO" => "GPS de inicio",
        "CLIENTE_DIR" => "Direccion del cliente",
        _ => "Sin coordenada confiable"
    };

    private void MarkDone() => UpdateSelectedStatus(VisitStatus.Done);
    private void MarkAlert() => UpdateSelectedStatus(VisitStatus.Alert);
    private void MarkPending() => UpdateSelectedStatus(VisitStatus.Pending);

    private void UpdateSelectedStatus(VisitStatus status)
    {
        if (_selected is null) return;
        var index = _stops.FindIndex(s => s.Id == _selected.Id);
        if (index < 0) return;
        _stops[index] = _stops[index] with { Status = status };
        _selected = _stops[index];
    }

    private void ZoomIn() => _zoom = Math.Min(2.4m, _zoom + .2m);
    private void ZoomOut() => _zoom = Math.Max(.8m, _zoom - .2m);
    private void ResetView()
    {
        _zoom = 1m;
        _panX = 0;
        _panY = 0;
    }

    private static int PositionX(int order)
    {
        var baseX = 12 + ((order - 1) * 11 % 76);
        var wave = (int)Math.Round(Math.Sin(order * .85) * 8);
        return Math.Clamp(baseX + wave, 8, 92);
    }

    private static int PositionY(int order)
    {
        var baseY = 14 + ((order - 1) * 17 % 70);
        var wave = (int)Math.Round(Math.Cos(order * .65) * 9);
        return Math.Clamp(baseY + wave, 10, 90);
    }

    private sealed record MapStop(
        int Id,
        int Order,
        string Name,
        string RouteName,
        string Address,
        string? Phone,
        string? Rfc,
        string CreditText,
        string LastVisit,
        VisitStatus Status,
        int X,
        int Y,
        string GeoSource,
        string? ProductTop);
}
