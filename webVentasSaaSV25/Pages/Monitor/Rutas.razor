@page "/monitor/rutas"
@using System.Globalization
@inject MonitorMapaService MonitorApi

<PageTitle>Monitor de Recorrido - Integra*System</PageTitle>

<div class="monitor-page">
    <header class="monitor-hero">
        <div>
            <h4>Monitor de Recorrido</h4>
            <p>Consulta operativa por ruta y fecha con foco en recorrido, cobertura, tiempos de traslado, visitas y venta.</p>
        </div>
        <div class="monitor-hero-actions">
            <a class="btn btn-outline-secondary" href="@MapaRouteUrl">
                <i class="material-icons-outlined">map</i>
                Ver mapa
            </a>
            <button class="btn btn-outline-primary" type="button" @onclick="CargarAsync" disabled="@(_loading || _routeId <= 0)">
                <i class="material-icons-outlined">refresh</i>
                Recargar
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-warning py-2">@_error</div>
    }
    @if (!CanShowMap && !string.IsNullOrWhiteSpace(MapConfigMessage))
    {
        <div class="alert alert-info py-2">@MapConfigMessage</div>
    }

    <section class="monitor-top-grid">
        <article class="monitor-panel">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-5">
                    <label class="form-label">Ruta</label>
                    <select class="form-select" value="@_routeId" @onchange="OnRouteChangedAsync">
                        <option value="0">Selecciona una ruta</option>
                        @foreach (var route in _routes)
                        {
                            <option value="@route.IdRuta">@route.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Fecha</label>
                    <input class="form-control" type="date" @bind="_fecha" />
                </div>
                <div class="col-12 col-md-3">
                    <button class="btn btn-primary w-100" type="button" @onclick="CargarAsync" disabled="@(_loading || _routeId <= 0)">
                        <i class="material-icons-outlined fs-6">search</i>
                        Consultar
                    </button>
                </div>
            </div>
        </article>

        <article class="monitor-panel monitor-kpis">
            <div><span>Programados</span><strong>@ProgramadosTexto</strong></div>
            <div><span>Realizados</span><strong>@_visitas.Kpi.TotalVisitas</strong></div>
            <div><span>Pendientes</span><strong>@Pendientes</strong></div>
            <div><span>Venta</span><strong>@_visitas.Kpi.MontoVentas.ToString("C0", _mx)</strong></div>
        </article>
    </section>

    <section class="monitor-route-layout">
        <article class="monitor-panel">
            <div class="panel-head">
                <div>
                    <h5>Resumen del recorrido</h5>
                    <small>@ResumenRuta</small>
                </div>
                <span class="source-pill">@EstadoRecorrido</span>
            </div>

            @if (_loading)
            {
                <div class="monitor-empty">Cargando informacion del recorrido...</div>
            }
            else if (_routeId <= 0)
            {
                <div class="monitor-empty">Selecciona una ruta para iniciar el monitoreo.</div>
            }
            else if (_recorrido is null)
            {
                <div class="monitor-empty">No se encontro recorrido para la fecha seleccionada.</div>
            }
            else
            {
                <div class="route-summary-grid route-summary-grid-hero">
                    <div class="summary-card">
                        <span>Vendedor</span>
                        <strong>@Texto(_recorrido.Vendedor)</strong>
                    </div>
                    <div class="summary-card">
                        <span>Efectividad</span>
                        <strong>@_recorrido.Efectividad.ToString("N1", _mx)%</strong>
                    </div>
                    <div class="summary-card">
                        <span>Con venta</span>
                        <strong>@_visitas.Kpi.VisitasConVenta</strong>
                    </div>
                    <div class="summary-card">
                        <span>Sin venta</span>
                        <strong>@_visitas.Kpi.VisitasSinVenta</strong>
                    </div>
                    <div class="summary-card">
                        <span>Tiempo recorrido</span>
                        <strong>@_recorrido.MinutosRecorrido min</strong>
                    </div>
                    <div class="summary-card">
                        <span>Pausa</span>
                        <strong>@_recorrido.MinutosPausa min</strong>
                    </div>
                    <div class="summary-card">
                        <span>QR</span>
                        <strong>@_visitas.Kpi.PorcentajeQr.ToString("N1", _mx)%</strong>
                    </div>
                    <div class="summary-card">
                        <span>GPS valido</span>
                        <strong>@_visitas.Kpi.PorcentajeGpsValido.ToString("N1", _mx)%</strong>
                    </div>
                    <div class="summary-card">
                        <span>Visitas extra</span>
                        <strong>@_visitas.Kpi.VisitasExtra</strong>
                    </div>
                    <div class="summary-card">
                        <span>Recargas</span>
                        <strong>@(_recorrido.TieneRecargas ? $"{_recorrido.TotalRecargas} evento(s)" : "Sin recargas")</strong>
                    </div>
                    <div class="summary-card">
                        <span>Tiempo traslado</span>
                        <strong>@_visitas.Kpi.TiempoMuertoMinutos min</strong>
                    </div>
                </div>

                @if (_recorrido.TieneRecargas)
                {
                    <div class="recarga-banner">
                        <strong>Hubo recargas en el recorrido.</strong>
                        <span>Se detectaron @_recorrido.TotalRecargas bloque(s) de recarga registrados en el cierre operativo.</span>
                    </div>
                }

                <div class="route-focus-card">
                    <div class="panel-head compact-head">
                        <div>
                            <h5>Ficha principal del recorrido</h5>
                            <small>Prioridad visual para datos operativos del cierre.</small>
                        </div>
                    </div>

                    @if (_recorrido is null)
                    {
                        <div class="monitor-empty small">No hay datos del recorrido para esta ruta y fecha.</div>
                    }
                    else
                    {
                        <div class="detail-grid route-focus-grid">
                            <span>Ruta</span><strong>@_recorrido.Ruta</strong>
                            <span>Vendedor</span><strong>@Texto(_recorrido.Vendedor)</strong>
                            <span>Inicio</span><strong>@FechaHora(_recorrido.FechaInicioUtc)</strong>
                            <span>Fin</span><strong>@FechaHora(_recorrido.FechaFinUtc)</strong>
                            <span>Estatus</span><strong>@Texto(_recorrido.Estatus)</strong>
                            <span>Efectividad</span><strong>@_recorrido.Efectividad.ToString("N1", _mx)%</strong>
                            <span>Monto efectivo</span><strong>@_recorrido.MontoEfectivo.ToString("C2", _mx)</strong>
                            <span>Monto credito</span><strong>@_recorrido.MontoCredito.ToString("C2", _mx)</strong>
                            <span>Cancelaciones</span><strong>@_recorrido.MontoCancelaciones.ToString("C2", _mx)</strong>
                            <span>Recargas</span><strong>@(_recorrido.TieneRecargas ? $"{_recorrido.TotalRecargas} evento(s)" : "Sin recargas")</strong>
                            <span>Traslado total</span><strong>@_visitas.Kpi.TiempoMuertoMinutos min</strong>
                            <span>QR leidos</span><strong>@_visitas.Kpi.LecturasQr</strong>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="monitor-panel">
            <div class="panel-head">
                <div>
                    <h5>Visitas del recorrido</h5>
                    <small>@_visitas.Visitas.Count registro(s)</small>
                </div>
            </div>

            @if (_loading)
            {
                <div class="monitor-empty small">Cargando visitas...</div>
            }
            else if (!_visitas.Visitas.Any())
            {
                <div class="monitor-empty small">No hay visitas registradas para este filtro.</div>
            }
            else
            {
                <div class="route-client-list">
                    @foreach (var visit in OrderedVisits)
                    {
                        <button type="button" class="route-client-card @SelectedClass(visit)" @onclick="() => SelectVisit(visit)">
                            <span class="status-dot @StatusClass(visit)"></span>
                            <div class="route-client-main">
                                <strong>#@VisitOrder(visit) @(visit.Sucursal ?? visit.Cliente)</strong>
                                <small>@visit.Cliente</small>
                                <small>@Texto(visit.Direccion)</small>
                            </div>
                            <span class="route-client-order">@Math.Round(visit.SegundosVisita / 60m, 1) m</span>
                        </button>
                    }
                </div>
            }
        </article>

        <article class="monitor-panel">
            <div class="panel-head">
                <div>
                    <h5>Detalle del cliente visitado</h5>
                    <small>Venta, productos y datos generales del punto seleccionado.</small>
                </div>
            </div>

            @if (_selectedVisit is null)
            {
                <div class="monitor-empty small">Selecciona una visita para revisar detalle.</div>
            }
            else
            {
                <div class="detail-grid">
                    <span>Cliente</span><strong>@_selectedVisit.Cliente</strong>
                    <span>Sucursal</span><strong>@Texto(_selectedVisit.Sucursal)</strong>
                    <span>Direccion</span><strong>@Texto(_selectedVisit.Direccion)</strong>
                    <span>Estatus</span><strong>@Texto(_selectedVisit.Estatus)</strong>
                    <span>Motivo</span><strong>@Texto(_selectedVisit.MotivoNoVenta)</strong>
                    <span>Inicio</span><strong>@FechaHora(_selectedVisit.FechaInicioUtc)</strong>
                    <span>Fin</span><strong>@FechaHora(_selectedVisit.FechaFinUtc)</strong>
                    <span>Visita</span><strong>@Math.Round(_selectedVisit.SegundosVisita / 60m, 1) min</strong>
                    <span>Traslado</span><strong>@(_selectedVisit.MinutosTraslado?.ToString("N0", _mx) ?? "Sin dato")</strong>
                    <span>QR</span><strong>@(_selectedVisit.TieneQr ? "Si" : "No")</strong>
                    <span>Tipo</span><strong>@(_selectedVisit.EsExtra ? "Extra" : _selectedVisit.EsProgramada ? "Programada" : "Libre")</strong>
                    <span>GPS</span><strong>@GpsTexto(_selectedVisit)</strong>
                    <span>Ventas</span><strong>@_selectedVisit.Ventas</strong>
                    <span>Monto</span><strong>@_selectedVisit.MontoVentas.ToString("C2", _mx)</strong>
                    <span>Resultado</span><strong>@(_selectedVisit.Ventas > 0 ? "Con venta" : "Sin venta")</strong>
                    <span>Productos</span><strong class="preline">@Texto(_selectedVisit.ProductosVendidos)</strong>
                    <span>Observaciones</span><strong>@Texto(_selectedVisit.Observaciones)</strong>
                </div>

                <div class="detail-actions">
                    <a class="btn btn-sm btn-primary" href="@($"/monitor/clientes?ruta={_routeId}&cliente={_selectedVisit.IdCliente}")">Ir a monitor cliente</a>
                    <a class="btn btn-sm btn-outline-secondary" href="@($"/monitor/mapa?ruta={_routeId}&cliente={_selectedVisit.IdCliente}")">Ver en mapa</a>
                </div>
            }
        </article>

        <article class="monitor-panel">
            <div class="panel-head">
                <div>
                    <h5>Mapa del recorrido</h5>
                    <small>Mapa real con puntos numerados del recorrido seleccionado.</small>
                </div>
            </div>

            @if (_loading)
            {
                <div class="monitor-empty small">Cargando mapa del recorrido...</div>
            }
            else if (!CanShowMap)
            {
                <div class="monitor-empty small">@MapConfigMessage</div>
            }
            else if (RouteBounds is null || string.IsNullOrWhiteSpace(RouteMapEmbedUrl))
            {
                <div class="monitor-empty small">Sin puntos con coordenadas validas para dibujar el recorrido.</div>
            }
            else
            {
                <div class="route-map-actions">
                    @if (!string.IsNullOrWhiteSpace(RouteMapUrl))
                    {
                        <a class="btn btn-sm btn-outline-secondary" href="@RouteMapUrl" target="_blank" rel="noopener noreferrer">
                            <i class="material-icons-outlined">open_in_new</i>
                            Abrir mapa
                        </a>
                    }
                </div>
                <div class="route-map-canvas route-map-canvas-real">
                    <iframe class="google-map-frame"
                            title="Mapa del recorrido"
                            src="@RouteMapEmbedUrl"
                            loading="lazy"></iframe>
                    <div class="route-map-marker-layer">
                        @foreach (var stop in OrderedMapStops)
                        {
                            <button type="button"
                                    class="route-map-pin @RoutePinClass(stop)"
                                    style="left:@RouteMarkerLeft(stop);top:@RouteMarkerTop(stop)"
                                    title="@($"{stop.Orden}. {stop.Nombre}")"
                                    @onclick="() => SelectVisitByClient(stop.IdCliente)">
                                <span>@stop.Orden</span>
                            </button>
                        }
                    </div>
                </div>
            }
        </article>

        <article class="monitor-panel">
            <div class="panel-head">
                <div>
                    <h5>No visitados</h5>
                    <small>@_visitas.NoVisitados.Count registro(s) programados</small>
                </div>
            </div>

            @if (_loading)
            {
                <div class="monitor-empty small">Cargando pendientes...</div>
            }
            else if (!_visitas.NoVisitados.Any())
            {
                <div class="monitor-empty small">Sin clientes programados pendientes para esta fecha.</div>
            }
            else
            {
                <div class="route-client-list">
                    @foreach (var pending in _visitas.NoVisitados)
                    {
                        <div class="route-client-card static-card">
                            <span class="status-dot alert"></span>
                            <div class="route-client-main">
                                <strong>@pending.Cliente</strong>
                                <small>@Texto(pending.Direccion)</small>
                                <small>@Texto(pending.Telefono)</small>
                            </div>
                            <span class="route-client-order">#@pending.Orden</span>
                        </div>
                    }
                </div>
            }
        </article>
    </section>
</div>

<style>
    .monitor-page{display:grid;gap:1rem}
    .monitor-hero,.monitor-top-grid,.monitor-route-layout,.panel-head,.monitor-kpis,.route-summary-grid,.monitor-shortcuts,.shortcut-card,.detail-actions{display:flex}
    .monitor-hero,.panel-head,.shortcut-card{align-items:flex-start;justify-content:space-between;gap:1rem}
    .monitor-hero h4,.panel-head h5{margin:0;font-weight:700;color:#344054}
    .monitor-hero p,.panel-head small{margin:0;color:#667085}
    .monitor-hero-actions,.detail-actions{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
    .monitor-hero-actions .btn,.shortcut-card{display:inline-flex;align-items:center;gap:.35rem}
    .monitor-top-grid{gap:1rem;align-items:stretch}
    .monitor-top-grid>.monitor-panel:first-child{flex:1.3}
    .monitor-top-grid>.monitor-panel:last-child{flex:1}
    .monitor-panel{background:#fff;border:1px solid #e6eaf0;border-radius:10px;padding:1rem;box-shadow:0 4px 18px rgba(18,38,63,.05)}
    .monitor-kpis{display:grid;grid-template-columns:repeat(2,minmax(120px,1fr));gap:.75rem}
    .monitor-kpis div,.summary-card{background:#f8fafc;border:1px solid #edf2f7;border-radius:9px;padding:.9rem}
    .monitor-kpis span,.summary-card span{display:block;color:#667085;font-size:.8rem}
    .monitor-kpis strong,.summary-card strong{font-size:1.2rem;color:#344054}
    .monitor-route-layout{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(320px,.9fr) minmax(320px,.85fr);gap:1rem}
    .route-summary-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.75rem}
    .route-summary-grid-hero{margin-top:.5rem}
    .recarga-banner{margin-top:1rem;border:1px solid #dbe5ef;background:#f8fbff;border-radius:10px;padding:.9rem 1rem;display:grid;gap:.2rem}
    .recarga-banner strong{color:#0d6efd}
    .recarga-banner span{color:#667085}
    .route-focus-card{margin-top:1rem;border:1px solid #dbe5ef;background:linear-gradient(180deg,#fff,#f8fbff);border-radius:12px;padding:1rem}
    .compact-head{margin-bottom:.75rem}
    .route-focus-grid{grid-template-columns:140px 1fr}
    .route-client-list{display:grid;gap:.6rem;max-height:620px;overflow:auto}
    .route-client-card{width:100%;border:1px solid #edf2f7;background:#fff;border-radius:10px;padding:.75rem;gap:.75rem;align-items:flex-start;text-align:left}
    .route-client-card.active-card,.route-client-card:hover{background:#eef5ff;border-color:#bfd7ff}
    .route-client-card.static-card:hover{background:#fff;border-color:#edf2f7}
    .route-client-main{flex:1;min-width:0}
    .route-client-main strong,.route-client-main small{display:block}
    .route-client-main small{color:#667085}
    .route-client-order{display:inline-flex;align-items:center;justify-content:center;min-width:58px;height:34px;border-radius:999px;background:#eef2f7;font-weight:700;font-size:.8rem;color:#344054;padding:0 .55rem}
    .status-dot{width:12px;height:12px;border-radius:50%;background:#98a2b3;flex:0 0 auto;margin-top:.25rem}
    .status-dot.pending{background:#0d6efd}.status-dot.done{background:#198754}.status-dot.alert{background:#dc3545}
    .route-map-actions{display:flex;justify-content:flex-end;margin-bottom:.6rem}
    .route-map-canvas{position:relative;min-height:380px;border:1px solid #dbe5ef;border-radius:12px;overflow:hidden;background:linear-gradient(135deg,#d9efe2,#f4f8fb 45%,#d8e7f8)}
    .route-map-canvas-real{background:#eef2f7}
    .google-map-frame{width:100%;height:100%;min-height:380px;border:0;display:block}
    .route-map-marker-layer{position:absolute;inset:0;pointer-events:none}
    .route-map-pin{position:absolute;transform:translate(-50%,-100%);width:34px;height:34px;border:2px solid #fff;border-radius:50% 50% 50% 8px;rotate:45deg;color:#fff;box-shadow:0 10px 20px rgba(16,24,40,.2);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.74rem;border:none;pointer-events:auto}
    .route-map-pin span{rotate:-45deg}
    .route-map-pin.pending{background:#0d6efd}
    .route-map-pin.done{background:#198754}
    .route-map-pin.alert{background:#dc3545}
    .detail-grid{display:grid;grid-template-columns:110px 1fr;gap:.7rem .8rem;font-size:.92rem}
    .detail-grid span{color:#667085}.detail-grid strong{color:#344054;font-weight:650}
    .preline{white-space:pre-line}
    .monitor-empty{display:flex;align-items:center;justify-content:center;min-height:180px;text-align:center;color:#667085}
    .monitor-empty.small{min-height:120px}
    .source-pill{display:inline-flex;align-items:center;background:#eaf2ff;color:#0d6efd;border-radius:999px;font-size:.78rem;font-weight:700;padding:.22rem .55rem}
    @@media (max-width:1399.98px){.monitor-route-layout{grid-template-columns:1fr 1fr}}
    @@media (max-width:1199.98px){.monitor-route-layout{grid-template-columns:1fr 1fr}.monitor-top-grid{flex-direction:column}}
    @@media (max-width:767.98px){.monitor-route-layout{grid-template-columns:1fr}}
</style>

@code {
    [SupplyParameterFromQuery(Name = "ruta")] public int? QueryRouteId { get; set; }

    private readonly CultureInfo _mx = CultureInfo.GetCultureInfo("es-MX");
    private List<MapaRutaOptionResponse> _routes = [];
    private ReporteRecorridosResponse _recorridos = new();
    private ReporteVisitasResponse _visitas = new();
    private List<MapaClientePuntoResponse> _mapStops = [];
    private ReporteRecorridoRowResponse? _recorrido;
    private ReporteVisitaRowResponse? _selectedVisit;
    private MapaConfiguracionResponse? _mapConfig;
    private int _routeId;
    private DateTime _fecha = DateTime.Today;
    private bool _loading;
    private string? _error;

    private string MapaRouteUrl => _routeId > 0 ? $"/monitor/mapa?ruta={_routeId}" : "/monitor/mapa";
    private string ClientesRouteUrl => _routeId > 0 ? $"/monitor/clientes?ruta={_routeId}" : "/monitor/clientes";
    private string RecorridosRouteUrl => _routeId > 0 ? $"/ventas/ruta/recorridos?ruta={_routeId}" : "/ventas/ruta/recorridos";
    private string VisitasRouteUrl => _routeId > 0 ? $"/ventas/ruta/visitas?ruta={_routeId}" : "/ventas/ruta/visitas";
    private string ProgramadosTexto => _recorrido?.VisitasProgramadas.ToString("N0", _mx) ?? "0";
    private int Pendientes => Math.Max((_recorrido?.VisitasProgramadas ?? 0) - _visitas.Kpi.TotalVisitas, 0);
    private List<ReporteVisitaRowResponse> OrderedVisits => _visitas.Visitas
        .OrderBy(x => x.FechaInicioUtc ?? DateTime.MaxValue)
        .ThenBy(x => x.IdVisita)
        .ToList();
    private List<MapaClientePuntoResponse> OrderedMapStops => _mapStops
        .Where(HasValidCoordinates)
        .OrderBy(x => x.Orden)
        .ToList();
    private MapaClientePuntoResponse? SelectedMapStop => _selectedVisit is null
        ? OrderedMapStops.FirstOrDefault()
        : OrderedMapStops.FirstOrDefault(x => x.IdCliente == _selectedVisit.IdCliente) ?? OrderedMapStops.FirstOrDefault();
    private MapBounds? RouteBounds => BuildBounds(OrderedMapStops, SelectedMapStop);
    private string? RouteMapEmbedUrl => BuildOpenStreetMapEmbedUrl(RouteBounds);
    private string? RouteMapUrl => BuildOpenStreetMapUrl(RouteBounds, SelectedMapStop);
    private string ResumenRuta => _recorrido is null
        ? "Sin recorrido cargado"
        : $"{_recorrido.Ruta} · {_fecha:dd/MM/yyyy}";
    private string EstadoRecorrido => Texto(_recorrido?.Estatus);
    private bool CanShowMap => _mapConfig?.MostrarMapa == true && _mapConfig?.TieneApiKey == true;
    private string MapConfigMessage => string.IsNullOrWhiteSpace(_mapConfig?.MensajeConfiguracion)
        ? "Debe dar de alta la configuracion de mapas para esta empresa."
        : _mapConfig!.MensajeConfiguracion;

    protected override async Task OnInitializedAsync()
    {
        var (config, configError) = await MonitorApi.GetConfiguracionAsync();
        _mapConfig = config;
        var (routes, error) = await MonitorApi.GetRutasAsync();
        _routes = routes?.ToList() ?? [];
        _error = error ?? configError;

        if (QueryRouteId is > 0)
        {
            _routeId = QueryRouteId.Value;
            await CargarAsync();
        }
    }

    private async Task OnRouteChangedAsync(ChangeEventArgs e)
    {
        _routeId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        _loading = true;
        _error = null;
        _recorridos = new();
        _visitas = new();
        _mapStops = [];
        _recorrido = null;
        _selectedVisit = null;

        if (_routeId <= 0)
        {
            _loading = false;
            return;
        }

        var (recorridos, recorridosError) = await MonitorApi.GetReporteRecorridosAsync(_routeId, _fecha, _fecha, 50);
        _recorridos = recorridos ?? new();
        _recorrido = _recorridos.Recorridos
            .OrderByDescending(x => x.FechaInicioUtc ?? x.FechaRecorrido)
            .FirstOrDefault();

        if (_recorrido is not null)
        {
            var (visitas, visitasError) = await MonitorApi.GetReporteVisitasAsync(_routeId, _fecha, _recorrido.IdRecorrido);
            _visitas = visitas ?? new();
            _selectedVisit = OrderedVisits.FirstOrDefault();

            var (mapa, mapaError) = await MonitorApi.GetRutaAsync(new MapaRutaRequest
            {
                IdRuta = _routeId,
                IdRecorrido = _recorrido.IdRecorrido,
                Modo = "recorrido"
            });
            _mapStops = mapa?.Puntos.ToList() ?? [];

            _error = visitasError ?? mapaError ?? recorridosError;
        }
        else
        {
            _error = recorridosError;
        }

        _loading = false;
    }

    private void SelectVisit(ReporteVisitaRowResponse visit) => _selectedVisit = visit;
    private void SelectVisitByClient(int idCliente)
        => _selectedVisit = OrderedVisits.FirstOrDefault(x => x.IdCliente == idCliente) ?? _selectedVisit;
    private string SelectedClass(ReporteVisitaRowResponse visit) => _selectedVisit?.IdVisita == visit.IdVisita ? "active-card" : "";
    private int VisitOrder(ReporteVisitaRowResponse visit)
        => OrderedVisits.FindIndex(x => x.IdVisita == visit.IdVisita) + 1;
    private string RoutePinClass(MapaClientePuntoResponse stop)
    {
        var visit = OrderedVisits.FirstOrDefault(x => x.IdCliente == stop.IdCliente);
        if (visit is null) return "pending";
        return StatusClass(visit);
    }

    private static string StatusClass(ReporteVisitaRowResponse visit)
    {
        if (visit.Ventas > 0) return "done";
        if (!string.IsNullOrWhiteSpace(visit.MotivoNoVenta)) return "alert";
        return "pending";
    }

    private static string Texto(string? value) => string.IsNullOrWhiteSpace(value) ? "Sin dato" : value;
    private static string FechaHora(DateTime? value) => value?.ToLocalTime().ToString("dd/MM HH:mm") ?? "Sin dato";
    private static string GpsTexto(ReporteVisitaRowResponse visit)
    {
        if (visit.DistanciaMetros is null) return "Sin referencia";
        var baseText = $"{visit.DistanciaMetros.Value:N1} m";
        return visit.GpsValido50m ? $"{baseText} · Valido" : $"{baseText} · Fuera de rango";
    }
    private string RouteMarkerLeft(MapaClientePuntoResponse stop) => $"{ProjectX(stop):0.##}%";
    private string RouteMarkerTop(MapaClientePuntoResponse stop) => $"{ProjectY(stop):0.##}%";
    private double ProjectX(MapaClientePuntoResponse stop)
    {
        var bounds = RouteBounds;
        if (bounds is null || !HasValidCoordinates(stop)) return 50d;
        var min = bounds.MinLon;
        var max = bounds.MaxLon;
        var value = (double)stop.Longitud!.Value;
        return max <= min ? 50d : Math.Clamp((value - min) / (max - min) * 100d, 4d, 96d);
    }
    private double ProjectY(MapaClientePuntoResponse stop)
    {
        var bounds = RouteBounds;
        if (bounds is null || !HasValidCoordinates(stop)) return 50d;
        var min = MercatorY(bounds.MaxLat);
        var max = MercatorY(bounds.MinLat);
        var value = MercatorY((double)stop.Latitud!.Value);
        return max <= min ? 50d : Math.Clamp((value - min) / (max - min) * 100d, 6d, 96d);
    }
    private static bool HasValidCoordinates(MapaClientePuntoResponse point)
        => point.Latitud.HasValue && point.Longitud.HasValue && point.Latitud.Value != 0 && point.Longitud.Value != 0;
    private static MapBounds? BuildBounds(List<MapaClientePuntoResponse> points, MapaClientePuntoResponse? selected)
    {
        var items = points.ToList();
        if (selected is not null && HasValidCoordinates(selected) && items.All(x => x.IdCliente != selected.IdCliente))
            items.Add(selected);
        if (!items.Any()) return null;

        var minLat = (double)items.Min(x => x.Latitud!.Value);
        var maxLat = (double)items.Max(x => x.Latitud!.Value);
        var minLon = (double)items.Min(x => x.Longitud!.Value);
        var maxLon = (double)items.Max(x => x.Longitud!.Value);
        var latPad = Math.Max((maxLat - minLat) * 0.12d, 0.0035d);
        var lonPad = Math.Max((maxLon - minLon) * 0.12d, 0.0035d);
        return new MapBounds(minLat - latPad, maxLat + latPad, minLon - lonPad, maxLon + lonPad);
    }
    private static string? BuildOpenStreetMapEmbedUrl(MapBounds? bounds)
        => bounds is null
            ? null
            : $"https://www.openstreetmap.org/export/embed.html?bbox={bounds.MinLon.ToString(CultureInfo.InvariantCulture)}%2C{bounds.MinLat.ToString(CultureInfo.InvariantCulture)}%2C{bounds.MaxLon.ToString(CultureInfo.InvariantCulture)}%2C{bounds.MaxLat.ToString(CultureInfo.InvariantCulture)}&layer=mapnik";
    private static string? BuildOpenStreetMapUrl(MapBounds? bounds, MapaClientePuntoResponse? selected)
        => selected is not null && HasValidCoordinates(selected)
            ? $"https://www.openstreetmap.org/?mlat={selected.Latitud!.Value.ToString(CultureInfo.InvariantCulture)}&mlon={selected.Longitud!.Value.ToString(CultureInfo.InvariantCulture)}#map=16/{selected.Latitud!.Value.ToString(CultureInfo.InvariantCulture)}/{selected.Longitud!.Value.ToString(CultureInfo.InvariantCulture)}"
            : bounds is null
                ? null
                : $"https://www.openstreetmap.org/?bbox={bounds.MinLon.ToString(CultureInfo.InvariantCulture)}%2C{bounds.MinLat.ToString(CultureInfo.InvariantCulture)}%2C{bounds.MaxLon.ToString(CultureInfo.InvariantCulture)}%2C{bounds.MaxLat.ToString(CultureInfo.InvariantCulture)}";
    private static double MercatorY(double latitude)
    {
        var radians = latitude * Math.PI / 180d;
        return Math.Log(Math.Tan(Math.PI / 4d + radians / 2d));
    }
    private sealed record MapBounds(double MinLat, double MaxLat, double MinLon, double MaxLon);
}
