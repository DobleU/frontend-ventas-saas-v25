@page "/monitor/rutas"
@inject MonitorMapaService MonitorApi
@inject IJSRuntime JS

<PageTitle>Monitor de Rutas - Integra*System</PageTitle>

<div class="monitor-page">
    <header class="monitor-hero">
        <div>
            <h4>Monitor de Rutas</h4>
            <p>Seguimiento operativo por ruta con foco en cobertura, alertas y clientes por atender.</p>
        </div>
        <div class="monitor-hero-actions">
            <a class="btn btn-outline-secondary" href="@MapaRouteUrl">
                <i class="material-icons-outlined">map</i>
                Ver mapa
            </a>
            <button class="btn btn-outline-primary" type="button" @onclick="RecargarAsync" disabled="@_loading">
                <i class="material-icons-outlined">refresh</i>
                Recargar
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-warning py-2">@_error</div>
    }

    <section class="monitor-top-grid">
        <article class="monitor-panel">
            <label class="form-label">Ruta</label>
            <select class="form-select" value="@_routeId" @onchange="OnRouteChangedAsync">
                <option value="0">Selecciona una ruta</option>
                @foreach (var route in _routes)
                {
                    <option value="@route.IdRuta">@route.Nombre</option>
                }
            </select>

            <label class="form-label mt-3">Buscar cliente</label>
            <div class="input-group">
                <span class="input-group-text bg-white">
                    <i class="material-icons-outlined">search</i>
                </span>
                <input class="form-control" value="@_search" @oninput="OnSearchInput" placeholder="Nombre, RFC o telefono" />
            </div>

            <div class="monitor-pill-row mt-3">
                <button type="button" class="@FilterClass(null)" @onclick="() => SetFilterAsync(null)">Todos</button>
                <button type="button" class="@FilterClass(RouteClientStatus.Pending)" @onclick="() => SetFilterAsync(RouteClientStatus.Pending)">Pendientes</button>
                <button type="button" class="@FilterClass(RouteClientStatus.Done)" @onclick="() => SetFilterAsync(RouteClientStatus.Done)">Visitados</button>
                <button type="button" class="@FilterClass(RouteClientStatus.Alert)" @onclick="() => SetFilterAsync(RouteClientStatus.Alert)">Alertas</button>
            </div>
        </article>

        <article class="monitor-panel monitor-kpis">
            <div><span>Clientes</span><strong>@VisibleStops.Count</strong></div>
            <div><span>Visitados</span><strong>@VisibleStops.Count(x => x.Status == RouteClientStatus.Done)</strong></div>
            <div><span>Pendientes</span><strong>@VisibleStops.Count(x => x.Status == RouteClientStatus.Pending)</strong></div>
            <div><span>Alertas</span><strong>@VisibleStops.Count(x => x.Status == RouteClientStatus.Alert)</strong></div>
        </article>
    </section>

    <section class="monitor-shortcuts">
        <a class="shortcut-card" href="@MapaRouteUrl">
            <span class="material-icons-outlined">map</span>
            <div>
                <strong>Mapa de ruta</strong>
                <small>Ubicacion visual y clientes en secuencia.</small>
            </div>
        </a>
        <a class="shortcut-card" href="@VisitasRouteUrl">
            <span class="material-icons-outlined">location_on</span>
            <div>
                <strong>Visitas</strong>
                <small>Auditoria de campo para la ruta seleccionada.</small>
            </div>
        </a>
        <a class="shortcut-card" href="@RecorridosRouteUrl">
            <span class="material-icons-outlined">route</span>
            <div>
                <strong>Recorridos</strong>
                <small>Cierre, efectividad y ventas por recorrido.</small>
            </div>
        </a>
        <a class="shortcut-card" href="@VentasReportUrl">
            <span class="material-icons-outlined">bar_chart</span>
            <div>
                <strong>Reporte de ventas</strong>
                <small>Consulta exportable ligada a operacion.</small>
            </div>
        </a>
    </section>

    <section class="monitor-route-layout">
        <article class="monitor-panel">
            <div class="panel-head">
                <div>
                    <h5>Estado de la ruta</h5>
                    <small>@(_routeName ?? "Sin ruta seleccionada")</small>
                </div>
                <span class="source-pill">@(_routeId > 0 ? "Datos API" : "Esperando seleccion")</span>
            </div>

            @if (_loading)
            {
                <div class="monitor-empty">Cargando informacion de la ruta...</div>
            }
            else if (!VisibleStops.Any())
            {
                <div class="monitor-empty">Selecciona una ruta para visualizar su estado operativo.</div>
            }
            else
            {
                <div class="route-lane">
                    @foreach (var stop in VisibleStops.Take(12))
                    {
                        <button type="button" class="lane-stop @StatusClass(stop.Status) @SelectedClass(stop)" @onclick="() => SelectStopAsync(stop)">
                            <span class="lane-order">@stop.Order</span>
                            <div>
                                <strong>@stop.Name</strong>
                                <small>@stop.Address</small>
                            </div>
                        </button>
                    }
                </div>

                <div class="route-summary-grid">
                    <div class="summary-card">
                        <span>Primer cliente</span>
                        <strong>@VisibleStops.First().Name</strong>
                    </div>
                    <div class="summary-card">
                        <span>Ultimo cliente</span>
                        <strong>@VisibleStops.Last().Name</strong>
                    </div>
                    <div class="summary-card">
                        <span>Con GPS confiable</span>
                        <strong>@VisibleStops.Count(x => x.GeoSource != "SIN_COORDENADA")</strong>
                    </div>
                    <div class="summary-card">
                        <span>Sin coordenada</span>
                        <strong>@VisibleStops.Count(x => x.GeoSource == "SIN_COORDENADA")</strong>
                    </div>
                </div>
            }
        </article>

        <article class="monitor-panel">
            <div class="panel-head">
                <div>
                    <h5>Clientes de la ruta</h5>
                    <small>@VisibleStops.Count registro(s) visibles</small>
                </div>
                <a class="btn btn-sm btn-outline-secondary" href="@ClientesRouteUrl">Vista clientes</a>
            </div>

            <div class="route-client-list">
                @if (!VisibleStops.Any())
                {
                    <div class="monitor-empty small">Sin clientes cargados para esta vista.</div>
                }
                else
                {
                    @foreach (var stop in VisibleStops)
                    {
                        <button type="button" class="route-client-card @(SelectedClass(stop))" @onclick="() => SelectStopAsync(stop)">
                            <span class="status-dot @StatusClass(stop.Status)"></span>
                            <div class="route-client-main">
                                <strong>@stop.Name</strong>
                                <small>@stop.Address</small>
                            </div>
                            <span class="route-client-order">#@stop.Order</span>
                        </button>
                    }
                }
            </div>
        </article>

        <article class="monitor-panel">
            <div class="panel-head">
                <div>
                    <h5>Detalle del cliente</h5>
                    <small>Contexto rapido para operacion</small>
                </div>
            </div>

            @if (_selected is null)
            {
                <div class="monitor-empty small">Selecciona un cliente para revisar detalle.</div>
            }
            else
            {
                <div class="detail-grid">
                    <span>Cliente</span><strong>@_selected.Name</strong>
                    <span>Ruta</span><strong>@_selected.RouteName</strong>
                    <span>Estado</span><strong>@StatusText(_selected.Status)</strong>
                    <span>Credito</span><strong>@_selected.CreditText</strong>
                    <span>Ultima visita</span><strong>@_selected.LastVisit</strong>
                    <span>Telefono</span><strong>@TextOrDash(_selected.Phone)</strong>
                    <span>RFC</span><strong>@TextOrDash(_selected.Rfc)</strong>
                    <span>GPS</span><strong>@GeoText(_selected.GeoSource)</strong>
                    <span>Direccion</span><strong>@_selected.Address</strong>
                </div>

                <div class="detail-actions">
                    <a class="btn btn-sm btn-primary" href="@ClienteDetailUrl(_selected)">Ir a monitor cliente</a>
                    <a class="btn btn-sm btn-outline-secondary" href="@MapaClientUrl(_selected)">Centrar en mapa</a>
                </div>
            }
        </article>
    </section>
</div>

<style>
    .monitor-page{display:grid;gap:1rem}
    .monitor-hero,.monitor-top-grid,.monitor-route-layout,.panel-head,.monitor-kpis,.monitor-pill-row,.route-client-card,.route-lane,.route-summary-grid,.monitor-shortcuts,.shortcut-card,.detail-actions{display:flex}
    .monitor-hero,.panel-head,.shortcut-card{align-items:flex-start;justify-content:space-between;gap:1rem}
    .monitor-hero h4,.panel-head h5{margin:0;font-weight:700;color:#344054}
    .monitor-hero p,.panel-head small{margin:0;color:#667085}
    .monitor-hero-actions,.detail-actions{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
    .monitor-hero-actions .btn,.shortcut-card{display:inline-flex;align-items:center;gap:.35rem}
    .monitor-top-grid{gap:1rem;align-items:stretch}
    .monitor-top-grid>.monitor-panel:first-child{flex:1.2}
    .monitor-top-grid>.monitor-panel:last-child{flex:1}
    .monitor-panel{background:#fff;border:1px solid #e6eaf0;border-radius:10px;padding:1rem;box-shadow:0 4px 18px rgba(18,38,63,.05)}
    .monitor-kpis{display:grid;grid-template-columns:repeat(2,minmax(120px,1fr));gap:.75rem}
    .monitor-kpis div,.summary-card{background:#f8fafc;border:1px solid #edf2f7;border-radius:9px;padding:.9rem}
    .monitor-kpis span,.summary-card span{display:block;color:#667085;font-size:.8rem}
    .monitor-kpis strong,.summary-card strong{font-size:1.2rem;color:#344054}
    .monitor-pill-row{gap:.45rem;flex-wrap:wrap}
    .monitor-pill-row button{border:1px solid #d7dde6;background:#fff;color:#475467;border-radius:999px;padding:.45rem .75rem;font-size:.85rem}
    .monitor-pill-row button.active{border-color:#0d6efd;background:#eaf2ff;color:#0d6efd;font-weight:650}
    .monitor-shortcuts{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.75rem}
    .shortcut-card{text-decoration:none;padding:.95rem 1rem;border-radius:10px;border:1px solid #e6eaf0;background:linear-gradient(180deg,#fff,#f8fbff);box-shadow:0 4px 18px rgba(18,38,63,.04);color:#344054}
    .shortcut-card:hover{border-color:#bfd7ff;background:#eef5ff}
    .shortcut-card span{font-size:22px;color:#0d6efd}
    .shortcut-card strong,.shortcut-card small{display:block}
    .shortcut-card small{color:#667085}
    .monitor-route-layout{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(340px,.95fr) minmax(300px,.8fr);gap:1rem}
    .route-lane{gap:.75rem;overflow:auto;padding-bottom:.35rem}
    .lane-stop{min-width:210px;display:flex;gap:.75rem;align-items:flex-start;padding:.85rem;border-radius:10px;border:1px solid #edf2f7;background:#fbfdff;text-align:left}
    .lane-stop.pending{border-color:#bfd7ff;background:#eef5ff}
    .lane-stop.done{border-color:#bee6ce;background:#eefbf3}
    .lane-stop.alert{border-color:#f4c7cf;background:#fff2f4}
    .lane-stop.active-card{box-shadow:0 0 0 2px rgba(13,110,253,.12) inset}
    .lane-order,.route-client-order{display:inline-flex;align-items:center;justify-content:center;min-width:34px;height:34px;border-radius:999px;background:#eef2f7;font-weight:700;font-size:.8rem;color:#344054}
    .lane-stop strong,.lane-stop small,.route-client-main strong,.route-client-main small{display:block}
    .lane-stop small,.route-client-main small{color:#667085}
    .route-summary-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.75rem;margin-top:1rem}
    .route-client-list{display:grid;gap:.6rem;max-height:620px;overflow:auto}
    .route-client-card{width:100%;border:1px solid #edf2f7;background:#fff;border-radius:10px;padding:.75rem;gap:.75rem;align-items:flex-start;text-align:left}
    .route-client-card.active-card,.route-client-card:hover{background:#eef5ff;border-color:#bfd7ff}
    .route-client-main{flex:1;min-width:0}
    .status-dot{width:12px;height:12px;border-radius:50%;background:#98a2b3;flex:0 0 auto;margin-top:.25rem}
    .status-dot.pending{background:#0d6efd}.status-dot.done{background:#198754}.status-dot.alert{background:#dc3545}
    .detail-grid{display:grid;grid-template-columns:110px 1fr;gap:.7rem .8rem;font-size:.92rem}
    .detail-grid span{color:#667085}.detail-grid strong{color:#344054;font-weight:650}
    .monitor-empty{display:flex;align-items:center;justify-content:center;min-height:180px;text-align:center;color:#667085}
    .monitor-empty.small{min-height:120px}
    @@media (max-width:1199.98px){.monitor-route-layout,.monitor-shortcuts{grid-template-columns:1fr 1fr}.monitor-top-grid{flex-direction:column}}
    @@media (max-width:767.98px){.monitor-shortcuts,.monitor-route-layout{grid-template-columns:1fr}}
</style>

@code {
    [SupplyParameterFromQuery(Name = "ruta")] public int? QueryRouteId { get; set; }
    [SupplyParameterFromQuery(Name = "cliente")] public int? QueryClientId { get; set; }

    private const string StorageKey = "monitor-rutas-state";

    private enum RouteClientStatus { Pending, Done, Alert }

    private List<MapaRutaOptionResponse> _routes = [];
    private List<RouteStop> _stops = [];
    private RouteStop? _selected;
    private RouteClientStatus? _statusFilter;
    private int _routeId;
    private string? _routeName;
    private string? _search;
    private string? _error;
    private bool _loading;
    private bool _restored;

    private List<RouteStop> VisibleStops => _stops
        .Where(x => _statusFilter is null || x.Status == _statusFilter)
        .Where(MatchesSearch)
        .OrderBy(x => x.Order)
        .ToList();

    private string MapaRouteUrl => _routeId > 0 ? $"/monitor/mapa?ruta={_routeId}" : "/monitor/mapa";
    private string ClientesRouteUrl => _routeId > 0 ? $"/monitor/clientes?ruta={_routeId}" : "/monitor/clientes";
    private string RecorridosRouteUrl => _routeId > 0 ? $"/ventas/ruta/recorridos?ruta={_routeId}" : "/ventas/ruta/recorridos";
    private string VisitasRouteUrl => _routeId > 0 ? $"/ventas/ruta/visitas?ruta={_routeId}" : "/ventas/ruta/visitas";
    private string VentasReportUrl => _routeId > 0 ? $"/reportes/ventas?ruta={_routeId}" : "/reportes/ventas";

    protected override async Task OnInitializedAsync()
    {
        var (routes, error) = await MonitorApi.GetRutasAsync();
        _routes = routes?.ToList() ?? [];
        _error = error;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _restored)
        {
            return;
        }

        _restored = true;
        await RestoreStateAsync();
        if (QueryRouteId is > 0)
        {
            _routeId = QueryRouteId.Value;
        }

        if (_routeId > 0)
        {
            await CargarRutaAsync();
            StateHasChanged();
        }
    }

    private async Task OnRouteChangedAsync(ChangeEventArgs e)
    {
        _routeId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        await SaveStateAsync();
        await CargarRutaAsync();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString();
        await SaveStateAsync();
    }

    private async Task SetFilterAsync(RouteClientStatus? status)
    {
        _statusFilter = status;
        await SaveStateAsync();
    }

    private async Task SelectStopAsync(RouteStop stop)
    {
        _selected = stop;
        await SaveStateAsync();
    }

    private async Task RecargarAsync() => await CargarRutaAsync();

    private async Task CargarRutaAsync()
    {
        _selected = null;
        _stops = [];
        _routeName = _routes.FirstOrDefault(x => x.IdRuta == _routeId)?.Nombre;
        _error = null;

        if (_routeId <= 0)
        {
            await SaveStateAsync();
            return;
        }

        _loading = true;
        var (data, error) = await MonitorApi.GetRutaAsync(new MapaRutaRequest
        {
            IdRuta = _routeId,
            Search = _search,
            Modo = "ruta"
        });
        _loading = false;
        _error = error;
        _routeName = data?.NombreRuta ?? _routeName;
        _stops = data?.Puntos.Select(FromApi).ToList() ?? [];
        _selected = _stops.FirstOrDefault();
        if (QueryClientId is > 0)
        {
            _selected = _stops.FirstOrDefault(x => x.Id == QueryClientId.Value) ?? _selected;
        }
        await SaveStateAsync();
    }

    private async Task RestoreStateAsync()
    {
        var json = await JS.InvokeAsync<string?>("AppInterop.localStorageGet", StorageKey);
        if (string.IsNullOrWhiteSpace(json))
        {
            return;
        }

        try
        {
            var state = System.Text.Json.JsonSerializer.Deserialize<MonitorRouteState>(json);
            if (state is null)
            {
                return;
            }

            if (QueryRouteId is null or <= 0)
            {
                _routeId = state.RouteId;
            }

            _search = state.Search;
            _statusFilter = Enum.TryParse<RouteClientStatus>(state.Filter, out var filter) ? filter : null;
        }
        catch
        {
        }
    }

    private async Task SaveStateAsync()
    {
        var payload = new MonitorRouteState(_routeId, _search, _statusFilter?.ToString(), _selected?.Id);
        await JS.InvokeVoidAsync("AppInterop.localStorageSet", StorageKey, System.Text.Json.JsonSerializer.Serialize(payload));
    }

    private bool MatchesSearch(RouteStop stop)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        return stop.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || stop.Address.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || (stop.Phone?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
            || (stop.Rfc?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private string FilterClass(RouteClientStatus? status) => _statusFilter == status ? "active" : "";
    private string SelectedClass(RouteStop stop) => _selected?.Id == stop.Id ? "active-card" : "";
    private static string StatusClass(RouteClientStatus status) => status switch { RouteClientStatus.Done => "done", RouteClientStatus.Alert => "alert", _ => "pending" };
    private static string StatusText(RouteClientStatus status) => status switch { RouteClientStatus.Done => "Visitado", RouteClientStatus.Alert => "Alerta", _ => "Pendiente" };
    private static string TextOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "Sin dato" : value;
    private static string GeoText(string source) => source switch
    {
        "REAL_FIN" => "GPS real de cierre",
        "REAL_INICIO" => "GPS de inicio",
        "CLIENTE_DIR" => "Direccion del cliente",
        _ => "Sin coordenada confiable"
    };

    private string ClienteDetailUrl(RouteStop stop) => $"/monitor/clientes?ruta={_routeId}&cliente={stop.Id}";
    private string MapaClientUrl(RouteStop stop) => $"/monitor/mapa?ruta={_routeId}&cliente={stop.Id}";

    private static RouteStop FromApi(MapaClientePuntoResponse point) => new(
        point.IdCliente,
        point.Orden,
        point.Nombre,
        point.NombreRuta ?? "Sin ruta",
        point.Direccion ?? "Direccion pendiente",
        point.Telefono,
        point.Rfc,
        point.Credito,
        point.UltimaVisita,
        point.GeoSource,
        point.Estado?.ToLowerInvariant() switch
        {
            "visitado" => RouteClientStatus.Done,
            "alerta" => RouteClientStatus.Alert,
            _ => RouteClientStatus.Pending
        });

    private sealed record RouteStop(
        int Id,
        int Order,
        string Name,
        string RouteName,
        string Address,
        string? Phone,
        string? Rfc,
        string CreditText,
        string LastVisit,
        string GeoSource,
        RouteClientStatus Status);

    private sealed record MonitorRouteState(int RouteId, string? Search, string? Filter, int? SelectedClientId);
}
