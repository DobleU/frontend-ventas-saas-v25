@* ============================================================
   [SUSTITUIR COMPLETO]
   Ruta: WEB/Pages/Dashboard/Index.razor
   ============================================================ *@
@page "/dashboard"
@using webVentasSaaSV25.Services.Catalogos
@inject DashboardService Svc

<PageTitle>Dashboard — VentasSaaSDU</PageTitle>

@if (_loading)
{
    <div class="d-flex align-items-center justify-content-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-3 text-muted">Cargando resumen...</span>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger d-flex gap-2 align-items-center">
        <i class="material-icons-outlined">error</i>@_error
    </div>
}
else if (_r != null)
{
    @* Alertas de configuración *@
    @if (_r.AlertaSinSeries)
    {
        <div class="alert alert-warning d-flex gap-2 align-items-center mb-3">
            <i class="material-icons-outlined">warning</i>
            <span>No hay series de documento configuradas. <a href="/configuracion/series-documento">Configurar ahora</a></span>
        </div>
    }
    @if (_r.AlertaSinMoneda)
    {
        <div class="alert alert-warning d-flex gap-2 align-items-center mb-3">
            <i class="material-icons-outlined">warning</i>
            <span>Falta el parámetro <code>MONEDA_DEFAULT</code>. <a href="/configuracion/parametros">Configurar ahora</a></span>
        </div>
    }

    @* KPI Cards *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 rounded-2 bg-primary bg-opacity-10">
                            <i class="material-icons-outlined text-primary">people</i>
                        </div>
                        <div>
                            <div class="fs-4 fw-bold">@_r.ClientesActivos</div>
                            <div class="text-muted small">Clientes activos</div>
                        </div>
                    </div>
                    @if (_r.ClientesConCredito > 0)
                    {
                        <div class="mt-2 text-muted small">
                            <i class="material-icons-outlined" style="font-size:14px;vertical-align:middle;">credit_card</i>
                            @_r.ClientesConCredito con crédito
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 rounded-2 bg-success bg-opacity-10">
                            <i class="material-icons-outlined text-success">inventory_2</i>
                        </div>
                        <div>
                            <div class="fs-4 fw-bold">@_r.ProductosActivos</div>
                            <div class="text-muted small">Productos activos</div>
                        </div>
                    </div>
                    @if (_r.ServiciosActivos > 0)
                    {
                        <div class="mt-2 text-muted small">
                            <i class="material-icons-outlined" style="font-size:14px;vertical-align:middle;">design_services</i>
                            @_r.ServiciosActivos servicios
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 rounded-2 bg-info bg-opacity-10">
                            <i class="material-icons-outlined text-info">local_shipping</i>
                        </div>
                        <div>
                            <div class="fs-4 fw-bold">@_r.ProveedoresActivos</div>
                            <div class="text-muted small">Proveedores</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 rounded-2 bg-warning bg-opacity-10">
                            <i class="material-icons-outlined text-warning">store</i>
                        </div>
                        <div>
                            <div class="fs-4 fw-bold">@_r.SucursalesActivas</div>
                            <div class="text-muted small">Sucursales</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Fila secundaria *@
    <div class="row g-3">
        <div class="col-12 col-md-6">
            <div class="card h-100">
                <div class="card-header fw-medium d-flex align-items-center gap-2">
                    <i class="material-icons-outlined text-primary" style="font-size:18px;">settings</i>
                    Estado de configuración
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted small">Usuarios activos</span>
                            <span class="fw-medium">@_r.UsuariosActivos</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted small">Series de documento</span>
                            <span class="fw-medium @(_r.SeriesDocumentoActivas == 0 ? "text-danger" : "")">
                                @_r.SeriesDocumentoActivas
                                @if (_r.SeriesDocumentoActivas == 0)
                                {
                                    <i class="material-icons-outlined ms-1" style="font-size:14px;">warning</i>
                                }
                            </span>
                        </li>
                        <li class="d-flex justify-content-between py-2">
                            <span class="text-muted small">Moneda configurada</span>
                            @if (_r.AlertaSinMoneda)
                            {
                                <span class="text-danger small"><i class="material-icons-outlined" style="font-size:14px;">close</i> No configurada</span>
                            }
                            else
                            {

                                <span class="text-success small"><i class="material-icons-outlined" style="font-size:14px;">check</i> Configurada</span>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card h-100">
                <div class="card-header fw-medium d-flex align-items-center gap-2">
                    <i class="material-icons-outlined text-primary" style="font-size:18px;">link</i>
                    Accesos rápidos
                </div>
                <div class="card-body d-flex flex-wrap gap-2 align-content-start">
                    <a href="/catalogos/clientes" class="btn btn-sm btn-outline-secondary">Clientes</a>
                    <a href="/catalogos/productos" class="btn btn-sm btn-outline-secondary">Productos</a>
                    <a href="/catalogos/proveedores" class="btn btn-sm btn-outline-secondary">Proveedores</a>
                    <a href="/configuracion/sucursales" class="btn btn-sm btn-outline-secondary">Sucursales</a>
                    <a href="/configuracion/series-documento" class="btn btn-sm btn-outline-secondary">Series doc.</a>
                    <a href="/configuracion/monedas" class="btn btn-sm btn-outline-secondary">Monedas</a>
                    <a href="/configuracion/parametros" class="btn btn-sm btn-outline-secondary">Parámetros</a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    DashboardResumenResponse? _r;
    bool _loading = true;
    string? _error;

    protected override async Task OnInitializedAsync()
    {
        var (d, e) = await Svc.GetResumenAsync();
        _loading = false;
        if (e != null) _error = e; else _r = d;
    }
}
