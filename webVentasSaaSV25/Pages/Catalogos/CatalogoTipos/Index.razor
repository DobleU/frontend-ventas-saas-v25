@* Pages/Catalogos/CatalogoTipos/Index.razor *@
@page "/catalogos/tipos"
@using webVentasSaaSV25.Services.Catalogos
@inject CatalogoTipoService Svc

<PageTitle>Tipos de Catálogo — VentasSaaSDU</PageTitle>
<Breadcrumb Titulo="Tipos de Catálogo" Items="@(new[]{ ("Catálogos","/catalogos"), ("Tipos","") })" />
<AlertMessage @ref="_alerta" />

<DataGrid TItem="CatalogoTipoResponse" Titulo="Tipos de Catálogo" Modulo="catalogos"
          Items="_paged?.Items" TotalRecords="_paged?.TotalRecords ?? 0"
          Page="_f.Page" PageSize="_f.PageSize" Loading="_loading"
          OnPageChanged="OnPage" OnSearch="OnSearch" OnNuevo="AbrirNuevo">
    <HeaderRow>
        <th style="width:130px">Código</th>
        <th>Nombre</th>
        <th>Descripción</th>
        <th style="width:110px" class="text-center">Estado</th>
        <th style="width:90px"  class="text-center">Acciones</th>
    </HeaderRow>
    <RowTemplate>
        <td><code class="small">@context.Codigo</code></td>
        <td class="fw-medium">@context.Nombre</td>
        <td class="text-muted small">@(context.Descripcion ?? "—")</td>
        <td class="text-center"><StatusBadge Value="@context.IsActive" /></td>
        <td class="text-center">
            <button class="btn btn-sm btn-outline-primary me-1 py-1 px-2" @onclick="()=>AbrirEditar(context)">
                <i class="material-icons-outlined" style="font-size:15px;">edit</i>
            </button>
            <button class="btn btn-sm btn-outline-danger py-1 px-2" @onclick="()=>Eliminar(context)">
                <i class="material-icons-outlined" style="font-size:15px;">delete</i>
            </button>
        </td>
    </RowTemplate>
</DataGrid>

<FormOffcanvas @ref="_panel" Titulo="@(_edit?"Editar Tipo":"Nuevo Tipo de Catálogo")"
               Icono="@(_edit?"edit":"add_circle")" OnGuardar="Guardar">
    <Body>
        <div class="mb-3">
            <label class="form-label fw-medium">Código <span class="text-danger">*</span></label>
            <input class="form-control text-uppercase @(_eCodigo?"is-invalid":"")" maxlength="50"
                   @bind="_codigo" @oninput="()=>_eCodigo=false" placeholder="Ej. TIPO_CLIENTE" />
            @if (_eCodigo) { <div class="invalid-feedback">Requerido.</div> }
            <div class="form-text">Identificador único. Sin espacios.</div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-medium">Nombre <span class="text-danger">*</span></label>
            <input class="form-control @(_eNombre?"is-invalid":"")" maxlength="150"
                   @bind="_nombre" @oninput="()=>_eNombre=false" placeholder="Ej. Tipo de Cliente" />
            @if (_eNombre) { <div class="invalid-feedback">Requerido.</div> }
        </div>
        <div class="mb-3">
            <label class="form-label fw-medium">Descripción</label>
            <textarea class="form-control" rows="2" maxlength="300" @bind="_descripcion"
                      placeholder="Opcional"></textarea>
        </div>
        @if (_edit)
        {
            <div class="mb-3">
                <label class="form-label fw-medium">Estado</label>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" @bind="_isActive" />
                    <label class="form-check-label">@(_isActive?"Activo":"Inactivo")</label>
                </div>
            </div>
        }
    </Body>
</FormOffcanvas>
<ConfirmDialog @ref="_confirm" />

@code {
    PagedResult<CatalogoTipoResponse>? _paged; FiltroCatalogoTipoRequest _f=new(); bool _loading;
    AlertMessage? _alerta; FormOffcanvas? _panel; ConfirmDialog? _confirm;
    bool _edit; int _id; string _codigo=""; string _nombre=""; string? _descripcion; bool _isActive=true; bool _eCodigo,_eNombre;

    protected override async Task OnInitializedAsync() => await Cargar();
    async Task Cargar() { _loading=true; var(d,e)=await Svc.GetPagedAsync(_f); _loading=false; if(e!=null)_alerta?.MostrarError(e); else _paged=d; }
    async Task OnPage(int p)       { _f.Page=p; await Cargar(); }
    async Task OnSearch(string? s) { _f.Search=s; _f.Page=1; await Cargar(); }
    void AbrirNuevo()  { _edit=false; _codigo=""; _nombre=""; _descripcion=null; _eCodigo=_eNombre=false; _panel?.Abrir(); }
    void AbrirEditar(CatalogoTipoResponse x) { _edit=true; _id=x.IdTipoCatalogo; _codigo=x.Codigo; _nombre=x.Nombre; _descripcion=x.Descripcion; _isActive=x.IsActive; _eCodigo=_eNombre=false; _panel?.Abrir(); }
    async Task Guardar()
    {
        _eCodigo=string.IsNullOrWhiteSpace(_codigo); _eNombre=string.IsNullOrWhiteSpace(_nombre);
        if(_eCodigo||_eNombre){_panel?.MostrarError("Corrija los campos marcados.");return;}
        if(_edit){ var(_,e)=await Svc.ActualizarAsync(_id,new ActualizarCatalogoTipoRequest{IdTipoCatalogo=_id,Codigo=_codigo.ToUpper(),Nombre=_nombre,Descripcion=_descripcion,IsActive=_isActive}); if(e!=null){_panel?.MostrarError(e);return;} }
        else     { var(_,e)=await Svc.CrearAsync(new CrearCatalogoTipoRequest{Codigo=_codigo.ToUpper(),Nombre=_nombre,Descripcion=_descripcion}); if(e!=null){_panel?.MostrarError(e);return;} }
        _panel?.MostrarExitoYCerrar(_edit?"Tipo actualizado.":"Tipo creado."); await Cargar();
    }
    async Task Eliminar(CatalogoTipoResponse x)
    {
        if(!await _confirm!.ConfirmarEliminarAsync("tipo de catálogo"))return;
        var(_,e)=await Svc.EliminarAsync(x.IdTipoCatalogo);
        if(e!=null)_alerta?.MostrarError(e); else{_alerta?.MostrarExito("Tipo eliminado.");await Cargar();}
    }
}
