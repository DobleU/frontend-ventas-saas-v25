    async Task<List<ClienteResponse>> ObtenerClientesReporte()
    {
        const int pageSize = 500;
        var page = 1;
        var clientes = new List<ClienteResponse>();

        while (true)
        {
            var filtro = new FiltroClienteRequest
            {
                Search = _f.Search,
                IsActive = _f.IsActive,
                BloquearCredito = _f.BloquearCredito,
                IdRuta = _f.IdRuta,
                DiaSemana = _f.DiaSemana,
                Page = page,
                PageSize = pageSize
            };

            var (d, e) = await Svc.GetPagedAsync(filtro);
            if (e != null)
            {
                _alerta?.MostrarError(e);
                break;
            }

            if (d?.Items is null || d.Items.Count == 0) break;
            clientes.AddRange(d.Items);
            if (clientes.Count >= d.TotalRecords || d.Items.Count < pageSize) break;
            page++;
        }

        return clientes;
    }

    bool TieneDatosFacturacion()
        => !string.IsNullOrWhiteSpace(_factRfc)
        || !string.IsNullOrWhiteSpace(_factRazonSocial)
        || !string.IsNullOrWhiteSpace(_factRegimenFiscal)
        || !string.IsNullOrWhiteSpace(_factUsoCfdi);

    static string? NullIfWhite(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    static string SucursalCliente(ClienteResponse c)
    {
        var sucursal = string.IsNullOrWhiteSpace(c.NombreSucursal) ? c.NombreCompleto : c.NombreSucursal.Trim();
        return $"{sucursal} ({c.NombreCompleto})";
    }

    static string ReferenciaDireccion(ClienteResponse c)
    {
        var partes = new[] { c.Referencias, c.Direccion1, c.Colonia }
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!.Trim());
        var texto = string.Join(" | ", partes);
        return string.IsNullOrWhiteSpace(texto) ? "—" : texto;
    }

    static string NombreDia(int? dia) => dia switch
    {
        1 => "Lunes",
        2 => "Martes",
        3 => "Miércoles",
        4 => "Jueves",
        5 => "Viernes",
        6 => "Sábado",
        7 => "Domingo",
        _ => "Todos"
    };

    string RutaFiltroNombre()
        => _f.IdRuta is > 0
            ? _rutas.FirstOrDefault(x => x.IdRuta == _f.IdRuta)?.Nombre ?? $"Ruta {_f.IdRuta}"
            : "Todas las rutas";

    static string Csv(string? value)
    {
        var v = value ?? "";
        const string quote = "\"";
        return quote + v.Replace(quote, quote + quote) + quote;
    }

    static string H(string? value)
        => WebUtility.HtmlEncode(string.IsNullOrWhiteSpace(value) ? "—" : value);
}
