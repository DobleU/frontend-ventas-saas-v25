@* Pages/Catalogos/Unidades/Index.razor *@
@page "/catalogos/unidades"
@using webVentasSaaSV25.Services.Catalogos
@inject UnidadService Svc

<PageTitle>Unidades de Medida — VentasSaaSDU</PageTitle>
<Breadcrumb Titulo="Unidades de Medida" Items="@(new[]{ ("Catálogos","/catalogos"), ("Unidades","") })" />
<AlertMessage @ref="_alerta" />

<DataGrid TItem="UnidadResponse" Titulo="Unidades de Medida" Modulo="catalogos"
          Items="_paged?.Items" TotalRecords="_paged?.TotalRecords ?? 0"
          Page="_f.Page" PageSize="_f.PageSize" Loading="_loading"
          OnPageChanged="OnPage" OnSearch="OnSearch" OnNuevo="AbrirNuevo">
    <HeaderRow>
        <th style="width:120px">Clave</th>
        <th>Nombre</th>
        <th style="width:110px" class="text-center">Estado</th>
        <th style="width:90px"  class="text-center">Acciones</th>
    </HeaderRow>
    <RowTemplate>
        <td><code class="small">@context.Clave</code></td>
        <td class="fw-medium">@context.Nombre</td>
        <td class="text-center"><StatusBadge Value="@context.IsActive" /></td>
        <td class="text-center">
            <button class="btn btn-sm btn-outline-primary me-1 py-1 px-2" @onclick="()=>AbrirEditar(context)">
                <i class="material-icons-outlined" style="font-size:15px;">edit</i>
            </button>
            <button class="btn btn-sm btn-outline-danger py-1 px-2" @onclick="()=>Eliminar(context)">
                <i class="material-icons-outlined" style="font-size:15px;">delete</i>
            </button>
        </td>
    </RowTemplate>
</DataGrid>

<FormOffcanvas @ref="_panel" Titulo="@(_edit?"Editar Unidad":"Nueva Unidad")"
               Icono="@(_edit?"edit":"add_circle")" OnGuardar="Guardar">
    <Body>
        <div class="mb-3">
            <label class="form-label fw-medium">Clave <span class="text-danger">*</span></label>
            <input class="form-control text-uppercase @(_eClave?"is-invalid":"")" maxlength="30"
                   @bind="_clave" @oninput="()=>_eClave=false" placeholder="Ej. PZA, KG, LT" />
            @if (_eClave) { <div class="invalid-feedback">Requerido.</div> }
            <div class="form-text">Abreviatura estándar de la unidad.</div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-medium">Nombre <span class="text-danger">*</span></label>
            <input class="form-control @(_eNombre?"is-invalid":"")" maxlength="100"
                   @bind="_nombre" @oninput="()=>_eNombre=false" placeholder="Ej. Pieza, Kilogramo" />
            @if (_eNombre) { <div class="invalid-feedback">Requerido.</div> }
        </div>
        @if (_edit)
        {
            <div class="mb-3">
                <label class="form-label fw-medium">Estado</label>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" @bind="_isActive" />
                    <label class="form-check-label">@(_isActive ? "Activo" : "Inactivo")</label>
                </div>
            </div>
        }
    </Body>
</FormOffcanvas>
<ConfirmDialog @ref="_confirm" />

@code {
    PagedResult<UnidadResponse>? _paged; FiltroUnidadRequest _f = new(); bool _loading;
    AlertMessage? _alerta; FormOffcanvas? _panel; ConfirmDialog? _confirm;
    bool _edit; int _id; string _clave=""; string _nombre=""; bool _isActive=true; bool _eClave,_eNombre;

    protected override async Task OnInitializedAsync() => await Cargar();
    async Task Cargar() { _loading=true; var(d,e)=await Svc.GetPagedAsync(_f); _loading=false; if(e!=null)_alerta?.MostrarError(e); else _paged=d; }
    async Task OnPage(int p)       { _f.Page=p; await Cargar(); }
    async Task OnSearch(string? s) { _f.Search=s; _f.Page=1; await Cargar(); }
    void AbrirNuevo()  { _edit=false; _clave=""; _nombre=""; _eClave=_eNombre=false; _panel?.Abrir(); }
    void AbrirEditar(UnidadResponse x) { _edit=true; _id=x.IdUnidad; _clave=x.Clave; _nombre=x.Nombre; _isActive=x.IsActive; _eClave=_eNombre=false; _panel?.Abrir(); }
    async Task Guardar()
    {
        _eClave=string.IsNullOrWhiteSpace(_clave); _eNombre=string.IsNullOrWhiteSpace(_nombre);
        if(_eClave||_eNombre){_panel?.MostrarError("Corrija los campos marcados.");return;}
        if(_edit){ var(_,e)=await Svc.ActualizarAsync(_id,new ActualizarUnidadRequest{IdUnidad=_id,Clave=_clave.ToUpper(),Nombre=_nombre,IsActive=_isActive}); if(e!=null){_panel?.MostrarError(e);return;} }
        else     { var(_,e)=await Svc.CrearAsync(new CrearUnidadRequest{Clave=_clave.ToUpper(),Nombre=_nombre}); if(e!=null){_panel?.MostrarError(e);return;} }
        _panel?.MostrarExitoYCerrar(_edit?"Unidad actualizada.":"Unidad creada."); await Cargar();
    }
    async Task Eliminar(UnidadResponse x)
    {
        if(!await _confirm!.ConfirmarEliminarAsync("unidad"))return;
        var(_,e)=await Svc.EliminarAsync(x.IdUnidad);
        if(e!=null)_alerta?.MostrarError(e); else{_alerta?.MostrarExito("Unidad eliminada.");await Cargar();}
    }
}
