@page "/reportes/ventas"
@using System.Globalization
@using System.Text
@inject MonitorMapaService MonitorApi
@inject IJSRuntime JS

<PageTitle>Reporte de Ventas - Integra*System</PageTitle>
<Breadcrumb Titulo="Reporte de Ventas" Items="@(new[] { ("Reportes", "/reportes"), ("Ventas", "") })" />
<AlertMessage @ref="_alerta" />

<section class="report-shell">
    <div class="report-header">
        <div>
            <span class="report-kicker"><span class="material-icons-outlined">payments</span> Comercial</span>
            <h3>Reporte de ventas</h3>
            <p>Buscador de ventas por ruta y periodo con tabla exportable para Excel.</p>
        </div>
        <button class="btn btn-outline-primary" disabled="@(!_items.Any())" @onclick="Exportar">
            <span class="material-icons-outlined fs-6">download</span>
            Exportar
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">Ruta</label>
                    <select class="form-select" @bind="_idRuta">
                        <option value="0">Todas</option>
                        @foreach (var route in _rutas)
                        {
                            <option value="@route.IdRuta">@route.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">Desde</label>
                    <input class="form-control" type="date" @bind="_fechaInicio" />
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">Hasta</label>
                    <input class="form-control" type="date" @bind="_fechaFin" />
                </div>
                <div class="col-12 col-md-3">
                    <button class="btn btn-primary w-100" disabled="@_loading" @onclick="Consultar">
                        <span class="material-icons-outlined fs-6">search</span>
                        Consultar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-6 col-xl-3">@Kpi("Recorridos", _data.Kpi.TotalRecorridos.ToString("N0", _mx), "route")</div>
        <div class="col-6 col-xl-3">@Kpi("Ventas", _data.Kpi.MontoVentas.ToString("C2", _mx), "payments")</div>
        <div class="col-6 col-xl-3">@Kpi("Credito", _items.Sum(x => x.MontoCredito).ToString("C2", _mx), "credit_score")</div>
        <div class="col-6 col-xl-3">@Kpi("Cancelaciones", _data.Kpi.MontoCancelaciones.ToString("C2", _mx), "money_off")</div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ruta</th>
                        <th>Fecha</th>
                        <th>Vendedor</th>
                        <th>Estatus</th>
                        <th class="text-end">Visitas</th>
                        <th class="text-end">Efectividad</th>
                        <th class="text-end">Ventas</th>
                        <th class="text-end">Efectivo</th>
                        <th class="text-end">Credito</th>
                        <th class="text-end">Cancelaciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr><td colspan="10" class="text-center py-4 text-secondary">Cargando ventas...</td></tr>
                    }
                    else if (!_items.Any())
                    {
                        <tr><td colspan="10" class="text-center py-4 text-secondary">Sin resultados para el filtro.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in _items)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Ruta</td>
                                <td>@item.FechaRecorrido.ToString("dd/MM/yyyy")</td>
                                <td>@TextOrDash(item.Vendedor)</td>
                                <td><span class="badge bg-light text-dark">@TextOrDash(item.Estatus)</span></td>
                                <td class="text-end">@item.VisitasRealizadas / @item.VisitasProgramadas</td>
                                <td class="text-end"><span class="@EfectividadBadge(item.Efectividad)">@item.Efectividad.ToString("N1", _mx)%</span></td>
                                <td class="text-end">@item.MontoVentas.ToString("C2", _mx)</td>
                                <td class="text-end">@item.MontoEfectivo.ToString("C2", _mx)</td>
                                <td class="text-end">@item.MontoCredito.ToString("C2", _mx)</td>
                                <td class="text-end">@item.MontoCancelaciones.ToString("C2", _mx)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "ruta")] public int? QueryRouteId { get; set; }

    private readonly CultureInfo _mx = CultureInfo.GetCultureInfo("es-MX");
    private AlertMessage? _alerta;
    private List<MapaRutaOptionResponse> _rutas = [];
    private ReporteRecorridosResponse _data = new();
    private IReadOnlyList<ReporteRecorridoRowResponse> _items => _data.Recorridos;
    private bool _loading;
    private int _idRuta;
    private DateTime _fechaInicio = DateTime.Today.AddDays(-7);
    private DateTime _fechaFin = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        var (routes, error) = await MonitorApi.GetRutasAsync();
        if (error is null && routes is not null) _rutas = routes.ToList();
        if (QueryRouteId is > 0) _idRuta = QueryRouteId.Value;
        await Consultar();
    }

    private async Task Consultar()
    {
        _loading = true;
        var (data, error) = await MonitorApi.GetReporteRecorridosAsync(_idRuta > 0 ? _idRuta : null, _fechaInicio, _fechaFin);
        _loading = false;

        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return;
        }

        _data = data ?? new();
    }

    private async Task Exportar()
    {
        var csv = new StringBuilder();
        csv.AppendLine("Ruta,Fecha,Vendedor,Estatus,VisitasProgramadas,VisitasRealizadas,Efectividad,MontoVentas,MontoEfectivo,MontoCredito,MontoCancelaciones");
        foreach (var item in _items)
        {
            csv.AppendLine(string.Join(",",
                Csv(item.Ruta),
                Csv(item.FechaRecorrido.ToString("dd/MM/yyyy")),
                Csv(item.Vendedor),
                Csv(item.Estatus),
                item.VisitasProgramadas,
                item.VisitasRealizadas,
                item.Efectividad.ToString(CultureInfo.InvariantCulture),
                item.MontoVentas.ToString(CultureInfo.InvariantCulture),
                item.MontoEfectivo.ToString(CultureInfo.InvariantCulture),
                item.MontoCredito.ToString(CultureInfo.InvariantCulture),
                item.MontoCancelaciones.ToString(CultureInfo.InvariantCulture)));
        }

        var serialized = System.Text.Json.JsonSerializer.Serialize(csv.ToString());
        await JS.InvokeVoidAsync("eval",
            $"const blob=new Blob([{serialized}],{{type:'text/csv;charset=utf-8;'}});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='reporte-ventas.csv';document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url);");
    }

    private static string Csv(string? value) => string.Concat("\"", (value ?? string.Empty).Replace("\"", "\"\""), "\"");
    private static string TextOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "Sin dato" : value;
    private static string EfectividadBadge(decimal value) => value < 75 ? "badge bg-danger" : "badge bg-success";

    private RenderFragment Kpi(string title, string value, string icon) => @<div class="card border-0 shadow-sm h-100">
        <div class="card-body d-flex align-items-center justify-content-between">
            <div>
                <div class="text-secondary small">@title</div>
                <div class="fs-5 fw-bold">@value</div>
            </div>
            <span class="material-icons-outlined text-primary">@icon</span>
        </div>
    </div>;
}

<style>
    .report-shell { padding-bottom: 2rem; }
    .report-header { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; margin-bottom:1rem; }
    .report-header h3 { margin:0; font-weight:800; }
    .report-header p { margin:.25rem 0 0; color:#6c757d; }
    .report-kicker { display:flex; align-items:center; gap:.35rem; color:#f05a1a; font-weight:700; font-size:.78rem; text-transform:uppercase; }
    @@media (max-width: 768px) { .report-header { flex-direction:column; } }
</style>
