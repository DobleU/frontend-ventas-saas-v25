@page "/reportes/clientes"
@using System.Text
@inject ClienteService ClienteApi
@inject RutaService RutaApi
@inject IJSRuntime JS

<PageTitle>Reporte de Clientes - Integra*System</PageTitle>
<Breadcrumb Titulo="Reporte de Clientes" Items="@(new[] { ("Reportes", "/reportes"), ("Clientes", "") })" />
<AlertMessage @ref="_alerta" />

<section class="report-shell">
    <div class="report-header">
        <div>
            <span class="report-kicker"><span class="material-icons-outlined">people</span> CRM</span>
            <h3>Reporte de clientes</h3>
            <p>Buscador por ruta, estado y texto libre con exportacion a Excel compatible.</p>
        </div>
    </div>

    <DataGrid TItem="ClienteResponse" Titulo="Clientes" Modulo="catalogos"
              Items="_paged?.Items" TotalRecords="_paged?.TotalRecords ?? 0"
              Page="_filter.Page" PageSize="_filter.PageSize" Loading="_loading"
              OnPageChanged="OnPage" OnPageSizeChange="OnPageSizeChange" OnSearch="OnSearch"
              OnExportar="Exportar"
              MostrarNuevo="false" MostrarImportar="false"
              SearchPlaceholder="Nombre, razon social, RFC, correo">

        <FiltrosExtra>
            <div class="d-flex flex-wrap gap-2">
                <select class="form-select form-select-sm" style="width:170px" @onchange="OnRutaChanged">
                    <option value="">Todas las rutas</option>
                    @foreach (var route in _rutas)
                    {
                        <option value="@route.IdRuta" selected="@(route.IdRuta == _filter.IdRuta)">@route.Nombre</option>
                    }
                </select>
                <select class="form-select form-select-sm" style="width:140px" @onchange="OnEstadoChanged">
                    <option value="">Todos</option>
                    <option value="true">Activos</option>
                    <option value="false">Inactivos</option>
                </select>
            </div>
        </FiltrosExtra>

        <HeaderRow>
            <th>Cliente</th>
            <th>RFC</th>
            <th>Ruta</th>
            <th>Telefono</th>
            <th>Correo</th>
            <th>Credito</th>
        </HeaderRow>
        <RowTemplate>
            <td>
                <div class="fw-medium">@context.NombreCompleto</div>
                <div class="small text-secondary">@(context.IdTipoPersona == 2 ? "Moral" : "Fisica")</div>
            </td>
            <td>@(context.Rfc ?? "-")</td>
            <td>@(context.NombreRuta ?? "Sin ruta")</td>
            <td>@(context.Telefono1 ?? "-")</td>
            <td>@(context.Correo ?? "-")</td>
            <td>@(context.TieneCredito ? $"{context.LimiteCredito:N0} / {context.DiasCredito} d" : "Sin credito")</td>
        </RowTemplate>

        <AccionesExtra Context="item">
            <li>
                <span class="dropdown-item-text text-muted small">Reporte informativo</span>
            </li>
        </AccionesExtra>
    </DataGrid>
</section>

@code {
    [SupplyParameterFromQuery(Name = "ruta")] public int? QueryRouteId { get; set; }

    private AlertMessage? _alerta;
    private bool _loading;
    private PagedResult<ClienteResponse>? _paged;
    private FiltroClienteRequest _filter = new();
    private List<RutaResponse> _rutas = [];

    protected override async Task OnInitializedAsync()
    {
        var (rutas, _) = await RutaApi.GetPagedAsync(new FiltroRutaRequest { IsActive = true, Page = 1, PageSize = 500 });
        _rutas = rutas?.Items ?? [];
        if (QueryRouteId is > 0) _filter.IdRuta = QueryRouteId.Value;
        await Cargar();
    }

    private async Task Cargar()
    {
        _loading = true;
        var (data, error) = await ClienteApi.GetPagedAsync(_filter);
        _loading = false;

        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return;
        }

        _paged = data;
    }

    private async Task OnPage(int page) { _filter.Page = page; await Cargar(); }
    private async Task OnPageSizeChange(int pageSize) { _filter.PageSize = pageSize; _filter.Page = 1; await Cargar(); }
    private async Task OnSearch(string? search) { _filter.Search = search; _filter.Page = 1; await Cargar(); }

    private async Task OnRutaChanged(ChangeEventArgs e)
    {
        _filter.IdRuta = int.TryParse(e.Value?.ToString(), out var id) && id > 0 ? id : null;
        _filter.Page = 1;
        await Cargar();
    }

    private async Task OnEstadoChanged(ChangeEventArgs e)
    {
        _filter.IsActive = bool.TryParse(e.Value?.ToString(), out var active) ? active : null;
        _filter.Page = 1;
        await Cargar();
    }

    private async Task Exportar()
    {
        var rows = _paged?.Items ?? [];
        var sb = new StringBuilder();
        sb.AppendLine("Cliente,RFC,Ruta,Telefono,Correo,TipoPersona,TieneCredito,LimiteCredito,DiasCredito,Estado");
        foreach (var item in rows)
        {
            sb.AppendLine(string.Join(",",
                Csv(item.NombreCompleto),
                Csv(item.Rfc),
                Csv(item.NombreRuta),
                Csv(item.Telefono1),
                Csv(item.Correo),
                Csv(item.IdTipoPersona == 2 ? "Moral" : "Fisica"),
                item.TieneCredito ? "1" : "0",
                item.LimiteCredito.ToString(System.Globalization.CultureInfo.InvariantCulture),
                item.DiasCredito,
                item.IsActive ? "Activo" : "Inactivo"));
        }

        var serialized = System.Text.Json.JsonSerializer.Serialize(sb.ToString());
        await JS.InvokeVoidAsync("eval",
            $"const blob=new Blob([{serialized}],{{type:'text/csv;charset=utf-8;'}});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='reporte-clientes.csv';document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url);");
    }

    private static string Csv(string? value) => string.Concat("\"", (value ?? string.Empty).Replace("\"", "\"\""), "\"");
}
