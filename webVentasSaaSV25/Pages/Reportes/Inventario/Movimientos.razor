@page "/reportes/inventario/movimientos"
@using System.Globalization
@using System.Text
@inject InventarioAlmacenWebService InventarioApi
@inject IJSRuntime JS

<PageTitle>Movimientos de Almacen - Integra*System</PageTitle>
<Breadcrumb Titulo="Movimientos de Almacen" Items="@(new[] { ("Reportes", "/reportes"), ("Inventario", ""), ("Movimientos", "") })" />
<AlertMessage @ref="_alerta" />

<section class="report-shell">
    <div class="report-header">
        <div>
            <span class="report-kicker"><span class="material-icons-outlined">swap_vert</span> Inventarios</span>
            <h3>Movimientos de almacen</h3>
            <p>Consulta operativa de ingresos de produccion, conteos y solicitudes de ruta con exportacion.</p>
        </div>
        <button class="btn btn-outline-primary" disabled="@(!_rows.Any())" @onclick="Exportar">
            <span class="material-icons-outlined fs-6">download</span>
            Exportar
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label">Almacen</label>
                    <select class="form-select" @bind="_idAlmacen">
                        <option value="0">Selecciona almacen</option>
                        @foreach (var item in _almacenes)
                        {
                            <option value="@item.IdAlmacen">@item.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Tipo de movimiento</label>
                    <select class="form-select" @bind="_tipo">
                        <option value="IngresoProduccion">Ingreso produccion</option>
                        <option value="Conteo">Conteo</option>
                        <option value="SolicitudRuta">Solicitud ruta</option>
                        <option value="Intercambio">Intercambio</option>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Buscar</label>
                    <input class="form-control" @bind="_search" placeholder="Folio, usuario, observaciones" />
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-primary" @onclick="Consultar" disabled="@(_loading || _idAlmacen <= 0)">
                    <span class="material-icons-outlined fs-6">search</span>
                    Consultar
                </button>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-6 col-xl-3">@Kpi("Registros", _rows.Count.ToString("N0", _mx), "inventory")</div>
        <div class="col-6 col-xl-3">@Kpi("Tipo", _tipo, "category")</div>
        <div class="col-6 col-xl-3">@Kpi("Almacen", _almacenNombre, "warehouse")</div>
        <div class="col-6 col-xl-3">@Kpi("Filtrados", _rows.Count(x => MatchSearch(x)).ToString("N0", _mx), "filter_alt")</div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Folio</th>
                        <th>Fecha</th>
                        <th>Referencia</th>
                        <th>Usuario</th>
                        <th class="text-end">Lineas</th>
                        <th class="text-end">Piezas</th>
                        <th class="text-end">Monto</th>
                        <th>Estatus</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr><td colspan="8" class="text-center py-4 text-secondary">Cargando movimientos...</td></tr>
                    }
                    else if (!VisibleRows.Any())
                    {
                        <tr><td colspan="8" class="text-center py-4 text-secondary">Sin movimientos para el filtro.</td></tr>
                    }
                    else
                    {
                        @foreach (var row in VisibleRows)
                        {
                            <tr>
                                <td class="fw-semibold">@row.Folio</td>
                                <td>@row.Fecha</td>
                                <td>@row.Referencia</td>
                                <td>@row.Usuario</td>
                                <td class="text-end">@row.Lineas</td>
                                <td class="text-end">@row.Piezas</td>
                                <td class="text-end">@row.Monto</td>
                                <td><span class="badge bg-light text-dark">@row.Estatus</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@code {
    private readonly CultureInfo _mx = CultureInfo.GetCultureInfo("es-MX");
    private AlertMessage? _alerta;
    private List<AlmacenOption> _almacenes = [];
    private List<MovimientoRow> _rows = [];
    private bool _loading;
    private int _idAlmacen;
    private string _tipo = "IngresoProduccion";
    private string? _search;
    private string _almacenNombre = "Sin seleccionar";

    private List<MovimientoRow> VisibleRows => _rows.Where(MatchSearch).ToList();

    protected override async Task OnInitializedAsync()
    {
        var (cards, error) = await InventarioApi.GetAlmacenesCardsAsync(null, true, null);
        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return;
        }

        _almacenes = cards?.Select(x => new AlmacenOption(x.IdAlmacen, x.Nombre)).ToList() ?? [];
    }

    private async Task Consultar()
    {
        _loading = true;
        _rows = [];
        _almacenNombre = _almacenes.FirstOrDefault(x => x.IdAlmacen == _idAlmacen)?.Nombre ?? "Sin seleccionar";

        if (_tipo == "IngresoProduccion")
        {
            var (data, error) = await InventarioApi.GetIngresoProduccionListAsync(_idAlmacen, _search, 1, 200);
            if (error is not null)
            {
                _loading = false;
                _alerta?.MostrarError(error);
                return;
            }

            _rows = data?.Items.Select(x => new MovimientoRow(
                x.Folio,
                x.FechaProduccion.ToString("dd/MM/yyyy"),
                x.Referencia ?? "-",
                x.UsuarioRegistro ?? "-",
                x.TotalLineas.ToString("N0", _mx),
                x.TotalPiezas.ToString("N2", _mx),
                x.TotalCosto.ToString("C2", _mx),
                "Aplicado",
                x.Observaciones ?? "-")).ToList() ?? [];
        }
        else if (_tipo == "Conteo")
        {
            var (data, error) = await InventarioApi.GetConteoListAsync(_idAlmacen, 0, _search, 1, 200);
            if (error is not null)
            {
                _loading = false;
                _alerta?.MostrarError(error);
                return;
            }

            _rows = data?.Items.Select(x => new MovimientoRow(
                x.Folio,
                x.FechaInicioUtc.ToString("dd/MM/yyyy"),
                $"Conteo {x.TipoConteo}",
                x.IdEncargado.ToString(),
                "-",
                "-",
                ((x.MontoFaltante ?? 0m) + (x.MontoSobrante ?? 0m)).ToString("C2", _mx),
                x.DescEstatus,
                x.Encargado ?? "-")).ToList() ?? [];
        }
        else if (_tipo == "SolicitudRuta")
        {
            var (data, error) = await InventarioApi.GetSolicitudesRutaAsync(_idAlmacen, 0, _search, 1, 200);
            if (error is not null)
            {
                _loading = false;
                _alerta?.MostrarError(error);
                return;
            }

            _rows = data?.Items.Select(x => new MovimientoRow(
                x.Folio,
                x.FechaSolicitudUtc.ToString("dd/MM/yyyy"),
                x.NombreAlmacenDestino,
                x.UsuarioSolicita ?? "-",
                x.TotalProductos.ToString("N0", _mx),
                x.TotalPiezasSolicitadas.ToString("N2", _mx),
                x.TotalPiezasSurtidas.ToString("N2", _mx),
                x.DescEstatus,
                x.Observaciones ?? "-")).ToList() ?? [];
        }
        else
        {
            var (data, error) = await InventarioApi.GetIntercambiosAlmacenAsync(_idAlmacen, _search, 1, 200);
            if (error is not null)
            {
                _loading = false;
                _alerta?.MostrarError(error);
                return;
            }

            _rows = data?.Items.Select(x => new MovimientoRow(
                x.Folio,
                x.CreatedUtc.ToString("dd/MM/yyyy"),
                $"{x.NombreRutaDestino} / {x.Motivo}",
                x.UsuarioRegistro ?? "-",
                x.TotalLineas.ToString("N0", _mx),
                x.TotalPiezas.ToString("N2", _mx),
                "-",
                "Aplicado",
                x.Observaciones ?? "-")).ToList() ?? [];
        }

        _loading = false;
    }

    private bool MatchSearch(MovimientoRow row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return row.Folio.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || row.Referencia.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || row.Usuario.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || row.Extra.Contains(_search, StringComparison.OrdinalIgnoreCase);
    }

    private async Task Exportar()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Folio,Fecha,Referencia,Usuario,Lineas,Piezas,Monto,Estatus");
        foreach (var row in VisibleRows)
        {
            sb.AppendLine(string.Join(",",
                Csv(row.Folio),
                Csv(row.Fecha),
                Csv(row.Referencia),
                Csv(row.Usuario),
                Csv(row.Lineas),
                Csv(row.Piezas),
                Csv(row.Monto),
                Csv(row.Estatus)));
        }

        var serialized = System.Text.Json.JsonSerializer.Serialize(sb.ToString());
        await JS.InvokeVoidAsync("eval",
            $"const blob=new Blob([{serialized}],{{type:'text/csv;charset=utf-8;'}});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='reporte-movimientos-almacen.csv';document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url);");
    }

    private RenderFragment Kpi(string title, string value, string icon) => @<div class="card border-0 shadow-sm h-100">
        <div class="card-body d-flex align-items-center justify-content-between">
            <div>
                <div class="text-secondary small">@title</div>
                <div class="fs-6 fw-bold">@value</div>
            </div>
            <span class="material-icons-outlined text-primary">@icon</span>
        </div>
    </div>;

    private static string Csv(string? value) => string.Concat("\"", (value ?? string.Empty).Replace("\"", "\"\""), "\"");

    private sealed record AlmacenOption(int IdAlmacen, string Nombre);
    private sealed record MovimientoRow(string Folio, string Fecha, string Referencia, string Usuario, string Lineas, string Piezas, string Monto, string Estatus, string Extra);
}

<style>
    .report-shell { padding-bottom: 2rem; }
    .report-header { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; margin-bottom:1rem; }
    .report-header h3 { margin:0; font-weight:800; }
    .report-header p { margin:.25rem 0 0; color:#6c757d; }
    .report-kicker { display:flex; align-items:center; gap:.35rem; color:#f05a1a; font-weight:700; font-size:.78rem; text-transform:uppercase; }
    @@media (max-width: 768px) { .report-header { flex-direction:column; } }
</style>
