@page "/ventas/ruta/visitas"
@using System.Globalization
@using System.Text
@inject MonitorMapaService MapaSvc
@inject IJSRuntime JS

<PageTitle>Visitas - VentasSaaSDU</PageTitle>

<Breadcrumb Titulo="Visitas" Items="@(new[] { ("Ventas", "/ventas"), ("Ruta", ""), ("Visitas", "") })" />
<AlertMessage @ref="_alerta" />

<section class="report-shell">
    <div class="report-header">
        <div>
            <span class="report-kicker"><span class="material-icons-outlined">location_on</span> Auditoria de campo</span>
            <h3>Visitas de recorrido</h3>
            <p>Revisa visitas, ventas por cliente, lectura QR y tiempos entre visitas.</p>
        </div>
        <button class="btn btn-outline-primary" disabled="@(!_items.Any())" @onclick="Exportar">
            <span class="material-icons-outlined fs-6">download</span>
            Exportar
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label">Ruta</label>
                    <select class="form-select" @bind="_idRuta">
                        <option value="0">Selecciona ruta</option>
                        @foreach (var r in _rutas)
                        {
                            <option value="@r.IdRuta">@r.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Fecha</label>
                    <input class="form-control" type="date" @bind="_fecha" />
                </div>
                <div class="col-12 col-md-4">
                    <button class="btn btn-primary w-100" disabled="@(_loading || _idRuta <= 0)" @onclick="Cargar">
                        <span class="material-icons-outlined fs-6">search</span>
                        Consultar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="route-context mb-3">
        <strong>@(_data.Header.Ruta == string.Empty ? "Sin recorrido seleccionado" : _data.Header.Ruta)</strong>
        <span>@_data.Header.Fecha.ToString("dd/MM/yyyy")</span>
        @if (!string.IsNullOrWhiteSpace(_data.Header.Vendedor))
        {
            <span>@_data.Header.Vendedor</span>
        }
    </div>

    <div class="row g-3 mb-3">
        <div class="col-6 col-xl-3">@Kpi("Visitas", _data.Kpi.TotalVisitas.ToString("N0", _mx), "fact_check")</div>
        <div class="col-6 col-xl-3">@Kpi("Con venta", _data.Kpi.VisitasConVenta.ToString("N0", _mx), "shopping_cart")</div>
        <div class="col-6 col-xl-3">@Kpi("QR", $"{_data.Kpi.PorcentajeQr:N1}%", "qr_code_scanner")</div>
        <div class="col-6 col-xl-3">@Kpi("Ventas", _data.Kpi.MontoVentas.ToString("C2", _mx), "payments")</div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Cliente / tienda</th>
                        <th>Estatus</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th class="text-end">Min visita</th>
                        <th class="text-end">Traslado</th>
                        <th class="text-center">QR</th>
                        <th class="text-end">Ventas</th>
                        <th class="text-end">Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr><td colspan="9" class="text-center py-4 text-secondary">Cargando...</td></tr>
                    }
                    else if (!_items.Any())
                    {
                        <tr><td colspan="9" class="text-center py-4 text-secondary">Sin visitas para el filtro.</td></tr>
                    }
                    else
                    {
                        @foreach (var v in _items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@(v.Sucursal ?? v.Cliente)</div>
                                    <div class="small text-secondary">@v.Cliente</div>
                                    @if (!string.IsNullOrWhiteSpace(v.Direccion))
                                    {
                                        <div class="small text-secondary">@v.Direccion</div>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">@v.Estatus</span>
                                    @if (!string.IsNullOrWhiteSpace(v.MotivoNoVenta))
                                    {
                                        <div class="small text-secondary">@v.MotivoNoVenta</div>
                                    }
                                </td>
                                <td>@Hora(v.FechaInicioUtc)</td>
                                <td>@Hora(v.FechaFinUtc)</td>
                                <td class="text-end">@Math.Round(v.SegundosVisita / 60m, 1)</td>
                                <td class="text-end">@(v.MinutosTraslado?.ToString("N0", _mx) ?? "-")</td>
                                <td class="text-center">
                                    <span class="material-icons-outlined @(v.TieneQr ? "text-success" : "text-secondary")">@(v.TieneQr ? "check_circle" : "radio_button_unchecked")</span>
                                </td>
                                <td class="text-end">@v.Ventas</td>
                                <td class="text-end">@v.MontoVentas.ToString("C2", _mx)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@code {
    private readonly CultureInfo _mx = CultureInfo.GetCultureInfo("es-MX");
    private AlertMessage? _alerta;
    private List<MapaRutaOptionResponse> _rutas = [];
    private ReporteVisitasResponse _data = new();
    private IReadOnlyList<ReporteVisitaRowResponse> _items => _data.Visitas;
    private bool _loading;
    private int _idRuta;
    private DateTime _fecha = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        var (rutas, error) = await MapaSvc.GetRutasAsync();
        if (error is null && rutas is not null) _rutas = rutas.ToList();
    }

    private async Task Cargar()
    {
        if (_idRuta <= 0)
        {
            _alerta?.MostrarAdvertencia("Selecciona una ruta.");
            return;
        }

        _loading = true;
        var (data, error) = await MapaSvc.GetReporteVisitasAsync(_idRuta, _fecha);
        _loading = false;

        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return;
        }

        _data = data ?? new();
    }

    private async Task Exportar()
    {
        var csv = new StringBuilder();
        csv.AppendLine("Cliente,Sucursal,Direccion,Estatus,MotivoNoVenta,Inicio,Fin,SegundosVisita,MinutosTraslado,TieneQr,Ventas,MontoVentas,Observaciones");
        foreach (var v in _items)
        {
            csv.AppendLine(string.Join(",",
                Csv(v.Cliente),
                Csv(v.Sucursal),
                Csv(v.Direccion),
                Csv(v.Estatus),
                Csv(v.MotivoNoVenta),
                Csv(v.FechaInicioUtc?.ToString("dd/MM/yyyy HH:mm")),
                Csv(v.FechaFinUtc?.ToString("dd/MM/yyyy HH:mm")),
                v.SegundosVisita,
                v.MinutosTraslado?.ToString(CultureInfo.InvariantCulture) ?? "",
                v.TieneQr ? "1" : "0",
                v.Ventas,
                v.MontoVentas.ToString(CultureInfo.InvariantCulture),
                Csv(v.Observaciones)));
        }

        var serialized = System.Text.Json.JsonSerializer.Serialize(csv.ToString());
        await JS.InvokeVoidAsync("eval",
            $"const blob=new Blob([{serialized}],{{type:'text/csv;charset=utf-8;'}});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='visitas-ruta.csv';document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url);");
    }

    private static string Hora(DateTime? value) => value?.ToString("HH:mm") ?? "-";
    private static string Csv(string? value) => string.Concat("\"", (value ?? string.Empty).Replace("\"", "\"\""), "\"");

    private RenderFragment Kpi(string titulo, string valor, string icono) => @<div class="card border-0 shadow-sm h-100">
        <div class="card-body d-flex align-items-center justify-content-between">
            <div>
                <div class="text-secondary small">@titulo</div>
                <div class="fs-5 fw-bold">@valor</div>
            </div>
            <span class="material-icons-outlined text-primary">@icono</span>
        </div>
    </div>;
}

<style>
    .report-shell { padding-bottom: 2rem; }
    .report-header { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; margin-bottom:1rem; }
    .report-header h3 { margin:0; font-weight:800; }
    .report-header p { margin:.25rem 0 0; color:#6c757d; }
    .report-kicker { display:flex; align-items:center; gap:.35rem; color:#f05a1a; font-weight:700; font-size:.78rem; text-transform:uppercase; }
    .route-context { display:flex; flex-wrap:wrap; gap:.6rem; color:#6c757d; }
    .route-context strong { color:#212529; }
    @@media (max-width: 768px) { .report-header { flex-direction:column; } }
</style>
