@page "/ventas/ruta/recorridos"
@using System.Globalization
@using System.Text
@inject MonitorMapaService MapaSvc
@inject IJSRuntime JS

<PageTitle>Recorridos - VentasSaaSDU</PageTitle>

<Breadcrumb Titulo="Recorridos" Items="@(new[] { ("Ventas", "/ventas"), ("Ruta", ""), ("Recorridos", "") })" />
<AlertMessage @ref="_alerta" />

<section class="report-shell">
    <div class="report-header">
        <div>
            <span class="report-kicker"><span class="material-icons-outlined">directions_car</span> Operacion de ruta</span>
            <h3>Recorridos</h3>
            <p>Consulta cierre, efectividad, ventas y cancelaciones por recorrido.</p>
        </div>
        <button class="btn btn-outline-primary" disabled="@(!_items.Any())" @onclick="Exportar">
            <span class="material-icons-outlined fs-6">download</span>
            Exportar
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">Ruta</label>
                    <select class="form-select" @bind="_idRuta">
                        <option value="0">Todas</option>
                        @foreach (var r in _rutas)
                        {
                            <option value="@r.IdRuta">@r.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">Desde</label>
                    <input class="form-control" type="date" @bind="_fechaInicio" />
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">Hasta</label>
                    <input class="form-control" type="date" @bind="_fechaFin" />
                </div>
                <div class="col-12 col-md-3">
                    <button class="btn btn-primary w-100" disabled="@_loading" @onclick="Cargar">
                        <span class="material-icons-outlined fs-6">search</span>
                        Consultar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-6 col-xl-3">@Kpi("Recorridos", _data.Kpi.TotalRecorridos.ToString("N0", _mx), "route")</div>
        <div class="col-6 col-xl-3">@Kpi("Completos", _data.Kpi.RecorridosCompletos.ToString("N0", _mx), "task_alt")</div>
        <div class="col-6 col-xl-3">@Kpi("Efectividad", $"{_data.Kpi.EfectividadPromedio:N1}%", "speed", EfectividadCss(_data.Kpi.EfectividadPromedio))</div>
        <div class="col-6 col-xl-3">@Kpi("Ventas", _data.Kpi.MontoVentas.ToString("C2", _mx), "payments")</div>
    </div>

    @if (_data.ProgramacionDias.Any())
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body py-3">
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var d in _data.ProgramacionDias)
                    {
                        <span class="day-pill">@d.DiaNombre: <strong>@d.TotalProgramado</strong></span>
                    }
                </div>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ruta</th>
                        <th>Fecha</th>
                        <th>Vendedor</th>
                        <th>Estatus</th>
                        <th class="text-end">Visitas</th>
                        <th class="text-end">Efectividad</th>
                        <th class="text-end">Ventas</th>
                        <th class="text-end">Cancelaciones</th>
                        <th class="text-end">Pausa</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr><td colspan="9" class="text-center py-4 text-secondary">Cargando...</td></tr>
                    }
                    else if (!_items.Any())
                    {
                        <tr><td colspan="9" class="text-center py-4 text-secondary">Sin recorridos para el filtro.</td></tr>
                    }
                    else
                    {
                        @foreach (var r in _items)
                        {
                            <tr>
                                <td class="fw-semibold">@r.Ruta</td>
                                <td>@r.FechaRecorrido.ToString("dd/MM/yyyy")</td>
                                <td>@r.Vendedor</td>
                                <td><span class="badge bg-light text-dark">@r.Estatus</span></td>
                                <td class="text-end">@r.VisitasRealizadas / @r.VisitasProgramadas</td>
                                <td class="text-end"><span class="@EfectividadBadge(r.Efectividad)">@r.Efectividad.ToString("N1", _mx)%</span></td>
                                <td class="text-end">@r.MontoVentas.ToString("C2", _mx)</td>
                                <td class="text-end">@r.MontoCancelaciones.ToString("C2", _mx)</td>
                                <td class="text-end">@r.MinutosPausa min</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@code {
    private readonly CultureInfo _mx = CultureInfo.GetCultureInfo("es-MX");
    private AlertMessage? _alerta;
    private List<MapaRutaOptionResponse> _rutas = [];
    private ReporteRecorridosResponse _data = new();
    private IReadOnlyList<ReporteRecorridoRowResponse> _items => _data.Recorridos;
    private bool _loading;
    private int _idRuta;
    private DateTime _fechaInicio = DateTime.Today.AddDays(-7);
    private DateTime _fechaFin = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        var (rutas, error) = await MapaSvc.GetRutasAsync();
        if (error is null && rutas is not null) _rutas = rutas.ToList();
        await Cargar();
    }

    private async Task Cargar()
    {
        _loading = true;
        var (data, error) = await MapaSvc.GetReporteRecorridosAsync(_idRuta > 0 ? _idRuta : null, _fechaInicio, _fechaFin);
        _loading = false;

        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return;
        }

        _data = data ?? new();
    }

    private async Task Exportar()
    {
        var csv = new StringBuilder();
        csv.AppendLine("Ruta,Fecha,Vendedor,Estatus,VisitasProgramadas,VisitasRealizadas,Efectividad,MontoVentas,MontoEfectivo,MontoCredito,MontoCancelaciones,MinutosRecorrido,MinutosPausa");
        foreach (var r in _items)
        {
            csv.AppendLine(string.Join(",",
                Csv(r.Ruta),
                Csv(r.FechaRecorrido.ToString("dd/MM/yyyy")),
                Csv(r.Vendedor),
                Csv(r.Estatus),
                r.VisitasProgramadas,
                r.VisitasRealizadas,
                r.Efectividad.ToString(CultureInfo.InvariantCulture),
                r.MontoVentas.ToString(CultureInfo.InvariantCulture),
                r.MontoEfectivo.ToString(CultureInfo.InvariantCulture),
                r.MontoCredito.ToString(CultureInfo.InvariantCulture),
                r.MontoCancelaciones.ToString(CultureInfo.InvariantCulture),
                r.MinutosRecorrido,
                r.MinutosPausa));
        }

        var serialized = System.Text.Json.JsonSerializer.Serialize(csv.ToString());
        await JS.InvokeVoidAsync("eval",
            $"const blob=new Blob([{serialized}],{{type:'text/csv;charset=utf-8;'}});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='recorridos-ruta.csv';document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url);");
    }

    private static string Csv(string? value) => string.Concat("\"", (value ?? string.Empty).Replace("\"", "\"\""), "\"");
    private static string EfectividadCss(decimal value) => value < 75 ? "kpi-danger" : "kpi-ok";
    private static string EfectividadBadge(decimal value) => value < 75 ? "badge bg-danger" : "badge bg-success";

    private RenderFragment Kpi(string titulo, string valor, string icono, string? css = null) => @<div class="card border-0 shadow-sm h-100 kpi-card @css">
        <div class="card-body d-flex align-items-center justify-content-between">
            <div>
                <div class="text-secondary small">@titulo</div>
                <div class="fs-5 fw-bold">@valor</div>
            </div>
            <span class="material-icons-outlined text-primary">@icono</span>
        </div>
    </div>;
}

<style>
    .report-shell { padding-bottom: 2rem; }
    .report-header { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; margin-bottom:1rem; }
    .report-header h3 { margin:0; font-weight:800; }
    .report-header p { margin:.25rem 0 0; color:#6c757d; }
    .report-kicker { display:flex; align-items:center; gap:.35rem; color:#f05a1a; font-weight:700; font-size:.78rem; text-transform:uppercase; }
    .day-pill { border:1px solid #e5e7eb; border-radius:999px; padding:.35rem .7rem; background:#fff; }
    .kpi-card.kpi-danger { border-left:4px solid #dc3545 !important; }
    .kpi-card.kpi-ok { border-left:4px solid #198754 !important; }
    @@media (max-width: 768px) { .report-header { flex-direction:column; } }
</style>
