@page "/ventas/ruta/recorridos"
@using System.Globalization
@using System.Text
@inject MonitorMapaService MapaSvc
@inject IJSRuntime JS

<PageTitle>Recorridos - VentasSaaSDU</PageTitle>

<Breadcrumb Titulo="Recorridos" Items="@(new[] { ("Ventas", "/ventas"), ("Ruta", ""), ("Recorridos", "") })" />
<AlertMessage @ref="_alerta" />

<section class="route-page">
    <div class="route-titlebar">
        <div>
            <span class="route-kicker"><span class="material-icons-outlined">directions_car</span> ROUTE</span>
            <h3>Recorridos</h3>
            <p>Consulta recorridos activos o concluidos y revisa la informacion de cierre disponible.</p>
        </div>
        <button class="btn btn-outline-primary" disabled="@(!RecorridosVisibles.Any() || _exportando)" @onclick="Exportar">
            <span class="material-icons-outlined fs-6">download</span>
            Exportar
        </button>
    </div>

    <div class="route-filterbar">
        <div class="search-box">
            <span class="material-icons-outlined">search</span>
            <input class="form-control" placeholder="Sucursal, cliente o direccion" @bind="_searchSucursal" @bind:event="oninput" />
        </div>
        <select class="form-select route-select" @bind="_idRuta">
            <option value="0">Todas las rutas</option>
            @foreach (var r in _rutas)
            {
                <option value="@r.IdRuta">@r.Nombre</option>
            }
        </select>
        <input class="form-control route-date" type="date" @bind="_fechaInicio" />
        <input class="form-control route-date" type="date" @bind="_fechaFin" />
        <button class="btn btn-primary route-action" disabled="@_loading" @onclick="Cargar">
            <span class="material-icons-outlined fs-6">search</span>
            Buscar
        </button>
    </div>

    <div class="status-tabs">
        <button type="button" class="@StatusTabClass(51)" @onclick="() => CambiarEstatus(51)">
            <span class="material-icons-outlined">play_circle</span>
            Activos
            <strong>@ContarPorEstatus(51)</strong>
        </button>
        <button type="button" class="@StatusTabClass(52)" @onclick="() => CambiarEstatus(52)">
            <span class="material-icons-outlined">task_alt</span>
            Concluidos
            <strong>@ContarPorEstatus(52)</strong>
        </button>
        <button type="button" class="@StatusTabClass(0)" @onclick="() => CambiarEstatus(0)">
            <span class="material-icons-outlined">list_alt</span>
            Todos
            <strong>@_items.Count</strong>
        </button>
    </div>

    <div class="route-workspace">
        <div class="route-list-panel">
            <div class="panel-head">
                <div>
                    <strong>Lista de recorridos</strong>
                    <span>@RecorridosVisibles.Count() resultado(s)</span>
                </div>
                @if (_loading || _filteringSearch)
                {
                    <span class="loading-pill">Cargando</span>
                }
            </div>

            <div class="route-list">
                @if (_loading)
                {
                    <div class="empty-state">Cargando recorridos...</div>
                }
                else if (MostrarAvisoSinActivos)
                {
                    <div class="route-warning">
                        <span class="material-icons-outlined">warning</span>
                        <div>
                            <strong>No existen recorridos activos</strong>
                            <span>Para la fecha y ruta seleccionadas solo se encontraron recorridos concluidos.</span>
                        </div>
                    </div>
                }
                else if (!RecorridosVisibles.Any())
                {
                    <div class="empty-state">@MensajeListaVacia</div>
                }
                else
                {
                    @foreach (var r in RecorridosVisibles)
                    {
                        <button type="button" class="@RecorridoClass(r)" @onclick="() => SeleccionarRecorrido(r)">
                            <div class="route-row-main">
                                <div>
                                    <strong>@r.Ruta</strong>
                                    <span>@r.FechaRecorrido.ToString("dd/MM/yyyy") - @(r.Vendedor ?? "Sin vendedor")</span>
                                </div>
                                <span class="@EstatusClass(r)">@EstatusTexto(r)</span>
                            </div>
                            <div class="route-row-metrics">
                                <span><b>@r.VisitasProgramadas</b> programadas</span>
                                <span><b>@r.VisitasRealizadas</b> realizadas</span>
                                <span>@r.Efectividad.ToString("N1", _mx)% efectividad</span>
                            </div>
                            <div class="route-row-results">
                                <span class="result-sale"><span class="material-icons-outlined">payments</span>Ventas <b>@r.MontoVentas.ToString("C2", _mx)</b></span>
                                <span class="result-cancel"><span class="material-icons-outlined">money_off</span>Cancelaciones <b>@r.MontoCancelaciones.ToString("C2", _mx)</b></span>
                                @if (r.MontoEfectivo != 0 || r.MontoCredito != 0)
                                {
                                    <span>Efectivo @r.MontoEfectivo.ToString("C2", _mx)</span>
                                    <span>Credito @r.MontoCredito.ToString("C2", _mx)</span>
                                }
                                @if (r.TieneRecargas)
                                {
                                    <span>Recargas @r.TotalRecargas</span>
                                }
                            </div>
                        </button>
                    }
                }
            </div>
        </div>

        <div class="visits-panel">
            <div class="visits-head">
                <div>
                    <strong>@(_selected is null ? "Cierre del recorrido" : _selected.Ruta)</strong>
                    <span>@DetalleSubtitulo</span>
                </div>
                <span class="visit-count">@ConteoDetalle</span>
            </div>

            <div class="visit-kpis">
                @Kpi("Programadas", KpiProgramadas.ToString("N0", _mx), "fact_check")
                @Kpi("Realizadas", KpiRealizadas.ToString("N0", _mx), "where_to_vote")
                @Kpi("Con venta", KpiConVenta.ToString("N0", _mx), "shopping_cart")
                @Kpi("Sin venta", KpiSinVenta.ToString("N0", _mx), "remove_shopping_cart")
                @Kpi("Ventas", KpiMontoVentas.ToString("C2", _mx), "payments")
                @Kpi("Cancelaciones", KpiMontoCancelaciones.ToString("C2", _mx), "money_off")
            </div>

            <div class="close-summary">
                @if (_loadingCierre)
                {
                    <div class="empty-state">Cargando cierre...</div>
                }
                else if (_selected is null)
                {
                    <div class="empty-state">Selecciona un recorrido para ver su cierre.</div>
                }
                else
                {
                    <div class="close-card">
                        <h6>Resumen de cierre</h6>
                        <pre>@TextoOPlaceholder(_cierreData.TxtResumenCierre)</pre>
                    </div>
                    <div class="close-card">
                        <h6>Ventas cierre</h6>
                        <pre>@TextoOPlaceholder(_cierreData.TxtVentasCierre)</pre>
                    </div>
                    <div class="close-card">
                        <h6>Inventario inicio</h6>
                        <pre>@TextoOPlaceholder(_cierreData.TxtInventarioInicio)</pre>
                    </div>
                    <div class="close-card">
                        <h6>Inventario cierre</h6>
                        <pre>@TextoOPlaceholder(_cierreData.TxtInventarioCierre)</pre>
                    </div>
                    <div class="close-card">
                        <h6>Recargas en ruta</h6>
                        <pre>@TextoOPlaceholder(_cierreData.TxtRecargas)</pre>
                    </div>
                    @if (_cierreData.DetalleMovimientos.Any())
                    {
                        <div class="close-card">
                            <h6>Movimientos</h6>
                            <div class="close-table">
                                @foreach (var m in _cierreData.DetalleMovimientos)
                                {
                                    <div>
                                        <span>@m.TipoDescripcion</span>
                                        <strong>@m.MontoTotal.ToString("C2", _mx)</strong>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    @if (_cierreData.ProductosVendidos.Any())
                    {
                        <div class="close-card">
                            <h6>Productos vendidos</h6>
                            <div class="close-table">
                                @foreach (var p in _cierreData.ProductosVendidos.Take(12))
                                {
                                    <div>
                                        <span>@(p.NombreProducto ?? p.Sku ?? $"Producto {p.IdProducto}")</span>
                                        <strong>@p.Total.ToString("C2", _mx)</strong>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</section>

@code {
    private const int EstatusActivo = 51;
    private const int EstatusConcluido = 52;

    [SupplyParameterFromQuery(Name = "ruta")] public int? QueryRouteId { get; set; }
    [SupplyParameterFromQuery(Name = "estatus")] public int? QueryEstatus { get; set; }

    private readonly CultureInfo _mx = CultureInfo.GetCultureInfo("es-MX");
    private readonly Dictionary<long, ReporteVisitasResponse> _visitasCache = [];
    private readonly Dictionary<long, RecorridoCierreCompletoResponse> _cierreCache = [];
    private readonly HashSet<long> _recorridosConSucursal = [];
    private AlertMessage? _alerta;
    private List<MapaRutaOptionResponse> _rutas = [];
    private ReporteRecorridosResponse _data = new();
    private ReporteVisitasResponse _visitasData = new();
    private RecorridoCierreCompletoResponse _cierreData = new();
    private IReadOnlyList<ReporteRecorridoRowResponse> _items => _data.Recorridos;
    private ReporteRecorridoRowResponse? _selected;
    private bool _loading;
    private bool _loadingCierre;
    private bool _filteringSearch;
    private bool _exportando;
    private bool _inicializado;
    private bool _busquedaEjecutada;
    private int? _estatusQueryAplicado;
    private int _idRuta;
    private int _estatus = EstatusActivo;
    private DateTime _fechaInicio = DateTime.Today;
    private DateTime _fechaFin = DateTime.Today;
    private string? _searchSucursal;
    private string MensajeListaVacia => _busquedaEjecutada
        ? "Sin recorridos para el filtro."
        : "Selecciona filtros y presiona Buscar.";

    private IEnumerable<ReporteRecorridoRowResponse> RecorridosVisibles => _items
        .Where(x => CoincideEstatus(x))
        .Where(CoincideBusqueda)
        .OrderByDescending(x => x.FechaRecorrido)
        .ThenByDescending(x => x.IdRecorrido);

    private List<ReporteVisitaRowResponse> VisitasSeleccionadas => _visitasData.Visitas
        .Where(CoincideBusquedaVisita)
        .OrderBy(x => x.FechaInicioUtc ?? DateTime.MaxValue)
        .ThenBy(x => x.IdVisita)
        .ToList();

    private string DetalleSubtitulo => _selected is null
        ? "Sin recorrido seleccionado"
        : $"{_selected.FechaRecorrido:dd/MM/yyyy} - {(_selected.Vendedor ?? "Sin vendedor")}";
    private int KpiProgramadas => _selected?.VisitasProgramadas > 0
        ? _selected.VisitasProgramadas
        : _visitasData.Kpi.VisitasProgramadas;
    private int KpiRealizadas => _cierreData.TotalVisitas > 0
        ? _cierreData.TotalVisitas
        : (_visitasData.Kpi.TotalVisitas > 0 ? _visitasData.Kpi.TotalVisitas : _selected?.VisitasRealizadas ?? 0);
    private int KpiConVenta => _cierreData.VisitasConVenta > 0
        ? _cierreData.VisitasConVenta
        : (_visitasData.Kpi.VisitasConVenta > 0 ? _visitasData.Kpi.VisitasConVenta : VisitasSeleccionadas.Count(x => x.Ventas > 0 || x.MontoVentas > 0));
    private int KpiSinVenta => Math.Max(KpiRealizadas - KpiConVenta, 0);
    private decimal KpiMontoVentas => _cierreData.TotalVentas != 0
        ? _cierreData.TotalVentas
        : (_visitasData.Kpi.MontoVentas != 0 ? _visitasData.Kpi.MontoVentas : _selected?.MontoVentas ?? 0m);
    private decimal KpiMontoCancelaciones => _cierreData.TotalCancelaciones != 0
        ? _cierreData.TotalCancelaciones
        : _selected?.MontoCancelaciones ?? 0m;
    private int ConteoDetalle => _cierreData.TotalVisitas > 0 ? _cierreData.TotalVisitas : (_selected?.VisitasRealizadas ?? 0);

    private bool MostrarAvisoSinActivos => !_loading
        && _estatus == EstatusActivo
        && !_items.Any(r => CoincideEstatus(r, EstatusActivo))
        && _items.Any(r => CoincideEstatus(r, EstatusConcluido));

    protected override async Task OnInitializedAsync()
    {
        var (rutas, error) = await MapaSvc.GetRutasAsync();
        if (error is null && rutas is not null) _rutas = rutas.ToList();
        if (QueryRouteId is > 0) _idRuta = QueryRouteId.Value;
        AplicarEstatusDesdeQuery();
        _inicializado = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_inicializado)
            return;

        var estatus = EstatusDesdeQuery();
        if (_estatusQueryAplicado == estatus)
            return;

        _estatus = estatus;
        _estatusQueryAplicado = estatus;
        if (!_busquedaEjecutada)
            return;

        await AplicarBusquedaSucursalAsync();
        var actualSigueVisible = _selected is not null && RecorridosVisibles.Any(x => x.IdRecorrido == _selected.IdRecorrido);
        if (!actualSigueVisible)
        {
            _selected = null;
            _visitasData = new();
            _cierreData = new();
            var primero = RecorridosVisibles.FirstOrDefault();
            if (primero is not null) await SeleccionarRecorrido(primero);
        }
    }

    private async Task Cargar()
    {
        if (_fechaInicio > _fechaFin)
        {
            _alerta?.MostrarAdvertencia("La fecha inicial no puede ser mayor a la fecha final.");
            return;
        }

        _loading = true;
        _busquedaEjecutada = true;
        _selected = null;
        _visitasData = new();
        _cierreData = new();
        _visitasCache.Clear();
        _cierreCache.Clear();
        _recorridosConSucursal.Clear();

        var (data, error) = await MapaSvc.GetReporteRecorridosAsync(_idRuta > 0 ? _idRuta : null, _fechaInicio, _fechaFin, 50000);
        _loading = false;

        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return;
        }

        _data = data ?? new();
        await AplicarBusquedaSucursalAsync();
        var primero = RecorridosVisibles.FirstOrDefault();
        if (primero is not null) await SeleccionarRecorrido(primero);
    }

    private async Task CambiarEstatus(int estatus)
    {
        _estatus = estatus;
        _estatusQueryAplicado = estatus;
        if (!_busquedaEjecutada)
            return;

        await AplicarBusquedaSucursalAsync();
        var actualSigueVisible = _selected is not null && RecorridosVisibles.Any(x => x.IdRecorrido == _selected.IdRecorrido);
        if (!actualSigueVisible)
        {
            _selected = null;
            _visitasData = new();
            _cierreData = new();
            var primero = RecorridosVisibles.FirstOrDefault();
            if (primero is not null) await SeleccionarRecorrido(primero);
        }
    }

    private async Task SeleccionarRecorrido(ReporteRecorridoRowResponse recorrido)
    {
        _selected = recorrido;
        _loadingCierre = true;

        var cierre = await ObtenerCierreAsync(recorrido);
        _cierreData = cierre ?? new();
        _loadingCierre = false;
    }

    private async Task<RecorridoCierreCompletoResponse?> ObtenerCierreAsync(ReporteRecorridoRowResponse recorrido)
    {
        if (_cierreCache.TryGetValue(recorrido.IdRecorrido, out var cached))
            return cached;

        var (data, error) = await MapaSvc.GetRecorridoCierreCompletoAsync(recorrido.IdRecorrido);
        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return null;
        }

        var cierre = data ?? new();
        _cierreCache[recorrido.IdRecorrido] = cierre;
        return cierre;
    }

    private async Task AplicarBusquedaSucursalAsync()
    {
        _recorridosConSucursal.Clear();
        if (string.IsNullOrWhiteSpace(_searchSucursal))
            return;

        _filteringSearch = true;
        foreach (var r in _items.Where(x => CoincideEstatus(x)))
        {
            var visitas = await ObtenerVisitasAsync(r);
            if (visitas is not null && visitas.Visitas.Any(CoincideBusquedaVisita))
                _recorridosConSucursal.Add(r.IdRecorrido);
        }
        _filteringSearch = false;
    }

    private async Task<ReporteVisitasResponse?> ObtenerVisitasAsync(ReporteRecorridoRowResponse recorrido)
    {
        if (_visitasCache.TryGetValue(recorrido.IdRecorrido, out var cached))
            return cached;

        var (data, error) = await MapaSvc.GetReporteVisitasAsync(recorrido.IdRuta, recorrido.FechaRecorrido.Date, recorrido.IdRecorrido);
        if (error is not null)
        {
            _alerta?.MostrarError(error);
            return null;
        }

        var visitas = data ?? new();
        _visitasCache[recorrido.IdRecorrido] = visitas;
        return visitas;
    }

    private bool CoincideEstatus(ReporteRecorridoRowResponse r)
    {
        if (_estatus == 0) return true;
        if (r.IdEstatus > 0) return r.IdEstatus == _estatus;

        var texto = Normalizar(r.Estatus);
        return _estatus == EstatusActivo
            ? texto.Contains("ACTIVO") || texto.Contains("TRANSITO") || texto.Contains("PAUSA")
            : texto.Contains("CONCLUIDO") || texto.Contains("CERRADO");
    }

    private bool CoincideBusqueda(ReporteRecorridoRowResponse r)
    {
        if (string.IsNullOrWhiteSpace(_searchSucursal)) return true;
        return Contiene(r.Ruta, _searchSucursal)
            || Contiene(r.Vendedor, _searchSucursal)
            || _recorridosConSucursal.Contains(r.IdRecorrido);
    }

    private bool CoincideBusquedaVisita(ReporteVisitaRowResponse v)
    {
        if (string.IsNullOrWhiteSpace(_searchSucursal)) return true;
        return Contiene(v.Sucursal, _searchSucursal)
            || Contiene(v.Cliente, _searchSucursal)
            || Contiene(v.Direccion, _searchSucursal);
    }

    private int ContarPorEstatus(int estatus)
        => _items.Count(r => CoincideEstatus(r, estatus));

    private void AplicarEstatusDesdeQuery()
    {
        _estatus = EstatusDesdeQuery();
        _estatusQueryAplicado = _estatus;
    }

    private int EstatusDesdeQuery()
        => QueryEstatus switch
        {
            EstatusConcluido => EstatusConcluido,
            0 => 0,
            _ => EstatusActivo
        };

    private async Task Exportar()
    {
        _exportando = true;
        var visibles = RecorridosVisibles.ToList();
        var csv = new StringBuilder();
        csv.AppendLine("SECCION,Ruta,Fecha,Vendedor,Estatus,VisitasProgramadas,VisitasRealizadas,Efectividad,MontoVentas,MontoEfectivo,MontoCredito,MontoCancelaciones,MinutosRecorrido,MinutosPausa,Cliente,Sucursal,Direccion,EstatusVisita,Inicio,Fin,SegundosVisita,MinutosTraslado,TieneQr,Ventas,MontoVisita,Observaciones");

        foreach (var r in visibles)
        {
            csv.AppendLine(string.Join(",",
                Csv("RECORRIDO"),
                Csv(r.Ruta),
                Csv(r.FechaRecorrido.ToString("dd/MM/yyyy")),
                Csv(r.Vendedor),
                Csv(EstatusTexto(r)),
                r.VisitasProgramadas,
                r.VisitasRealizadas,
                r.Efectividad.ToString(CultureInfo.InvariantCulture),
                r.MontoVentas.ToString(CultureInfo.InvariantCulture),
                r.MontoEfectivo.ToString(CultureInfo.InvariantCulture),
                r.MontoCredito.ToString(CultureInfo.InvariantCulture),
                r.MontoCancelaciones.ToString(CultureInfo.InvariantCulture),
                r.MinutosRecorrido,
                r.MinutosPausa,
                "", "", "", "", "", "", "", "", "", "", "", ""));

            var visitas = await ObtenerVisitasAsync(r);
            foreach (var v in (visitas?.Visitas ?? []).Where(CoincideBusquedaVisita))
            {
                csv.AppendLine(string.Join(",",
                    Csv("VISITA"),
                    Csv(r.Ruta),
                    Csv(r.FechaRecorrido.ToString("dd/MM/yyyy")),
                    Csv(r.Vendedor),
                    Csv(EstatusTexto(r)),
                    "", "", "", "", "", "", "", "", "",
                    Csv(v.Cliente),
                    Csv(v.Sucursal),
                    Csv(v.Direccion),
                    Csv(v.Estatus),
                    Csv(v.FechaInicioUtc?.ToString("dd/MM/yyyy HH:mm")),
                    Csv(v.FechaFinUtc?.ToString("dd/MM/yyyy HH:mm")),
                    v.SegundosVisita,
                    v.MinutosTraslado?.ToString(CultureInfo.InvariantCulture) ?? "",
                    v.TieneQr ? "1" : "0",
                    v.Ventas,
                    v.MontoVentas.ToString(CultureInfo.InvariantCulture),
                    Csv(v.Observaciones)));
            }
        }

        await JS.InvokeVoidAsync("downloadTextFile", $"recorridos-visitas-{DateTime.Now:yyyyMMdd-HHmm}.csv", csv.ToString(), "text/csv;charset=utf-8;");
        _exportando = false;
    }

    private string StatusTabClass(int estatus) => _estatus == estatus ? "status-tab active" : "status-tab";
    private string RecorridoClass(ReporteRecorridoRowResponse r) => _selected?.IdRecorrido == r.IdRecorrido ? "route-row active" : "route-row";
    private string EstatusTexto(ReporteRecorridoRowResponse r) => string.IsNullOrWhiteSpace(r.Estatus) ? $"Estatus {r.IdEstatus}" : r.Estatus!;
    private string EstatusClass(ReporteRecorridoRowResponse r) => CoincideEstatus(r, EstatusActivo) ? "status-badge active" : "status-badge done";
    private static string TrasladoClass(ReporteVisitaRowResponse v) => IsTrasladoError(v) ? "text-danger" : "text-success";
    private static string VisitDotClass(ReporteVisitaRowResponse v) => v.Ventas > 0 ? "visit-dot sale" : "visit-dot";
    private static string TrasladoTexto(ReporteVisitaRowResponse v)
    {
        var minutos = v.MinutosTraslado ?? 0;
        var segundos = EffectiveTrasladoSeconds(v.SegundosTraslado, v.MinutosTraslado);
        var estado = IsTrasladoError(v) ? "Traslado error" : "Traslado OK";
        return $"{estado} - {minutos:N0} min - {segundos:N0} seg";
    }

    private static bool IsTrasladoError(ReporteVisitaRowResponse v)
    {
        var segundos = EffectiveTrasladoSeconds(v.SegundosTraslado, v.MinutosTraslado);
        if (segundos <= 15)
            return true;

        return (v.MinutosTraslado ?? 0) > 45;
    }

    private static int EffectiveTrasladoSeconds(int segundosTraslado, int? minutosTraslado)
        => segundosTraslado <= 0 && (minutosTraslado ?? 0) > 0
            ? minutosTraslado!.Value * 60
            : segundosTraslado;

    private static bool CoincideEstatus(ReporteRecorridoRowResponse r, int estatus)
    {
        if (estatus == 0) return true;
        if (r.IdEstatus > 0) return r.IdEstatus == estatus;

        var texto = Normalizar(r.Estatus);
        return estatus == EstatusActivo
            ? texto.Contains("ACTIVO") || texto.Contains("TRANSITO") || texto.Contains("PAUSA")
            : texto.Contains("CONCLUIDO") || texto.Contains("CERRADO");
    }

    private static bool Contiene(string? value, string? search)
        => Normalizar(value).Contains(Normalizar(search), StringComparison.Ordinal);

    private static string Normalizar(string? value)
    {
        var text = (value ?? string.Empty).Trim().ToUpperInvariant();
        var normalized = text.Normalize(NormalizationForm.FormD);
        var sb = new StringBuilder(normalized.Length);
        foreach (var c in normalized)
        {
            if (CharUnicodeInfo.GetUnicodeCategory(c) != UnicodeCategory.NonSpacingMark)
                sb.Append(c);
        }
        return sb.ToString().Normalize(NormalizationForm.FormC);
    }

    private static string Csv(string? value) => string.Concat("\"", (value ?? string.Empty).Replace("\"", "\"\""), "\"");
    private static string TextoOPlaceholder(string? value) => string.IsNullOrWhiteSpace(value) ? "Sin dato" : value.Trim();

    private RenderFragment Kpi(string titulo, string valor, string icono) => @<div class="visit-kpi">
        <span class="material-icons-outlined">@icono</span>
        <div>
            <small>@titulo</small>
            <strong>@valor</strong>
        </div>
    </div>;
}

