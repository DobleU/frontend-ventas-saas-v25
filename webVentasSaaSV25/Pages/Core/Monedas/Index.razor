@* ============================================================
   [NUEVO ARCHIVO — crear carpeta Pages/Core/Monedas/]
   Ruta: WEB/Pages/Core/Monedas/Index.razor
   ============================================================ *@
@page "/core/monedas"
@using webVentasSaaSV25.Services.Catalogos
@inject MonedaService Svc

<PageTitle>Monedas — VentasSaaSDU</PageTitle>
<Breadcrumb Titulo="Monedas" Items="@(new[]{ ("Configuración",""), ("Monedas","") })" />
<AlertMessage @ref="_alerta" />

<DataGrid TItem="MonedaResponse" Titulo="Monedas (ISO 4217)" Modulo="configuracion"
          Items="_paged?.Items" TotalRecords="_paged?.TotalRecords ?? 0"
          Page="_f.Page" PageSize="_f.PageSize" Loading="_loading"
          OnPageChanged="OnPage" OnSearch="OnSearch" OnNuevo="AbrirNuevo"
          SearchPlaceholder="Código ISO o nombre">
    <HeaderRow>
        <th style="width:110px">Código ISO</th>
        <th>Nombre</th>
        <th style="width:110px" class="text-center">Estado</th>
        <th style="width:90px"  class="text-center">Acciones</th>
    </HeaderRow>
    <RowTemplate>
        <td><code class="fw-bold">@context.Codigo</code></td>
        <td class="fw-medium">@context.Nombre</td>
        <td class="text-center"><StatusBadge Value="@context.IsActive" /></td>
        <td class="text-center">
            <button class="btn btn-sm btn-outline-primary me-1 py-1 px-2"
                    @onclick="()=>AbrirEditar(context)">
                <i class="material-icons-outlined" style="font-size:15px;">edit</i>
            </button>
            <button class="btn btn-sm btn-outline-danger py-1 px-2"
                    @onclick="()=>Eliminar(context)">
                <i class="material-icons-outlined" style="font-size:15px;">delete</i>
            </button>
        </td>
    </RowTemplate>
</DataGrid>

<FormOffcanvas @ref="_panel" Titulo="@(_edit?"Editar Moneda":"Nueva Moneda")"
               Icono="@(_edit?"edit":"payments")" Ancho="400px" OnGuardar="Guardar">
    <Body>
        <div class="mb-3">
            <label class="form-label fw-medium">Código ISO 4217 <span class="text-danger">*</span></label>
            <input class="form-control text-uppercase @(_eCodigo?"is-invalid":"")" maxlength="3"
                   @bind="_codigo" @oninput="()=>_eCodigo=false"
                   placeholder="Ej. MXN, USD, EUR" disabled="@_edit" />
            @if (_eCodigo) { <div class="invalid-feedback">Requerido (3 caracteres).</div> }
            @if (!_edit)   { <div class="form-text">Tres caracteres, estándar ISO 4217.</div> }
        </div>
        <div class="mb-3">
            <label class="form-label fw-medium">Nombre <span class="text-danger">*</span></label>
            <input class="form-control @(_eNombre?"is-invalid":"")" maxlength="50"
                   @bind="_nombre" @oninput="()=>_eNombre=false"
                   placeholder="Ej. Peso Mexicano" />
            @if (_eNombre) { <div class="invalid-feedback">Requerido.</div> }
        </div>
        @if (_edit)
        {
            <div class="mb-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" @bind="_isActive" />
                    <label class="form-check-label">@(_isActive?"Activa":"Inactiva")</label>
                </div>
            </div>
        }
    </Body>
</FormOffcanvas>
<ConfirmDialog @ref="_confirm" />

@code {
    PagedResult<MonedaResponse>? _paged;
    FiltroMonedaRequest          _f      = new();
    bool                         _loading;
    AlertMessage?                _alerta;
    FormOffcanvas?               _panel;
    ConfirmDialog?               _confirm;

    bool   _edit;
    string _codigo   = "";
    string _nombre   = "";
    bool   _isActive = true;
    bool   _eCodigo, _eNombre;

    protected override async Task OnInitializedAsync() => await Cargar();

    async Task Cargar()
    {
        _loading = true;
        var (d, e) = await Svc.GetPagedAsync(_f);
        _loading = false;
        if (e != null) _alerta?.MostrarError(e); else _paged = d;
    }

    async Task OnPage(int p)       { _f.Page = p;  await Cargar(); }
    async Task OnSearch(string? s) { _f.Search = s; _f.Page = 1; await Cargar(); }

    void AbrirNuevo()
    {
        _edit = false; _codigo = ""; _nombre = ""; _eCodigo = _eNombre = false;
        _panel?.Abrir();
    }

    void AbrirEditar(MonedaResponse x)
    {
        _edit = true; _codigo = x.Codigo; _nombre = x.Nombre;
        _isActive = x.IsActive; _eCodigo = _eNombre = false;
        _panel?.Abrir();
    }

    async Task Guardar()
    {
        _eCodigo = string.IsNullOrWhiteSpace(_codigo) || _codigo.Length != 3;
        _eNombre = string.IsNullOrWhiteSpace(_nombre);
        if (_eCodigo || _eNombre) { _panel?.MostrarError("Corrija los campos marcados."); return; }

        if (_edit)
        {
            var (_, e) = await Svc.ActualizarAsync(_codigo,
                new ActualizarMonedaRequest { Codigo = _codigo, Nombre = _nombre, IsActive = _isActive });
            if (e != null) { _panel?.MostrarError(e); return; }
        }
        else
        {
            var (_, e) = await Svc.CrearAsync(
                new CrearMonedaRequest { Codigo = _codigo.ToUpper(), Nombre = _nombre });
            if (e != null) { _panel?.MostrarError(e); return; }
        }
        _panel?.MostrarExitoYCerrar(_edit ? "Moneda actualizada." : "Moneda creada.");
        await Cargar();
    }

    async Task Eliminar(MonedaResponse x)
    {
        if (!await _confirm!.ConfirmarEliminarAsync("moneda")) return;
        var (_, e) = await Svc.EliminarAsync(x.Codigo);
        if (e != null) _alerta?.MostrarError(e);
        else { _alerta?.MostrarExito("Moneda eliminada."); await Cargar(); }
    }
}
