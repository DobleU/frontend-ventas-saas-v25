@* Pages/Core/Sucursales/Index.razor *@
@page "/core/sucursales"
@using webVentasSaaSV25.Services.Catalogos
@inject SucursalService SucSvc
@inject ZonaService ZonaSvc

<PageTitle>Sucursales — VentasSaaSDU</PageTitle>
<Breadcrumb Titulo="Sucursales" Items="@(new[]{ ("Configuración",""), ("Sucursales","") })" />
<AlertMessage @ref="_alerta" />

<DataGrid TItem="SucursalResponse" Titulo="Sucursales" Modulo="configuracion"
          Items="_paged?.Items" TotalRecords="_paged?.TotalRecords ?? 0"
          Page="_f.Page" PageSize="_f.PageSize" Loading="_loading"
          OnPageChanged="OnPage" OnSearch="OnSearch" OnNuevo="AbrirNuevo">
    <HeaderRow>
        <th style="width:110px">Código</th>
        <th>Nombre</th>
        <th style="width:130px">Zona</th>
        <th style="width:110px" class="text-center">Estado</th>
        <th style="width:90px"  class="text-center">Acciones</th>
    </HeaderRow>
    <RowTemplate>
        <td><code class="small">@context.Codigo</code></td>
        <td class="fw-medium">@context.Nombre</td>
        <td class="text-muted small">@(context.NombreZona ?? "—")</td>
        <td class="text-center"><StatusBadge Value="@context.IsActive" /></td>
        <td class="text-center">
            <button class="btn btn-sm btn-outline-primary me-1 py-1 px-2" @onclick="()=>AbrirEditar(context)">
                <i class="material-icons-outlined" style="font-size:15px;">edit</i>
            </button>
            <button class="btn btn-sm btn-outline-danger py-1 px-2" @onclick="()=>Eliminar(context)">
                <i class="material-icons-outlined" style="font-size:15px;">delete</i>
            </button>
        </td>
    </RowTemplate>
</DataGrid>

<FormOffcanvas @ref="_panel" Titulo="@(_edit?"Editar Sucursal":"Nueva Sucursal")"
               Icono="@(_edit?"edit":"add_circle")" OnGuardar="Guardar">
    <Body>
        <div class="row g-3 mb-3">
            <div class="col-5">
                <label class="form-label fw-medium">Código <span class="text-danger">*</span></label>
                <input class="form-control text-uppercase @(_eCodigo?"is-invalid":"")" maxlength="20"
                       @bind="_codigo" @oninput="()=>_eCodigo=false" placeholder="Ej. SUC-01" />
                @if (_eCodigo) { <div class="invalid-feedback">Requerido.</div> }
            </div>
            <div class="col-7">
                <label class="form-label fw-medium">Zona</label>
                <select class="form-select" @bind="_idZona">
                    <option value="0">— Sin zona —</option>
                    @foreach (var z in _zonas)
                    {
                        <option value="@z.IdZona">@z.Nombre</option>
                    }
                </select>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-medium">Nombre <span class="text-danger">*</span></label>
            <input class="form-control @(_eNombre?"is-invalid":"")" maxlength="150"
                   @bind="_nombre" @oninput="()=>_eNombre=false" placeholder="Ej. Sucursal Centro" />
            @if (_eNombre) { <div class="invalid-feedback">Requerido.</div> }
        </div>
        <div class="mb-3">
            <label class="form-label fw-medium">Maneja Inventario</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="_manejaInventario" />
                <label class="form-check-label">@(_manejaInventario?"Sí":"No")</label>
            </div>
        </div>
        @if (_edit)
        {
            <div class="mb-3">
                <label class="form-label fw-medium">Estado</label>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" @bind="_isActive" />
                    <label class="form-check-label">@(_isActive?"Activo":"Inactivo")</label>
                </div>
            </div>
        }
    </Body>
</FormOffcanvas>
<ConfirmDialog @ref="_confirm" />

@code {
    PagedResult<SucursalResponse>? _paged; FiltroSucursalRequest _f=new(); bool _loading;
    List<ZonaResponse> _zonas = [];
    AlertMessage? _alerta; FormOffcanvas? _panel; ConfirmDialog? _confirm;
    bool _edit; int _id;
    string _codigo=""; string _nombre=""; int _idZona=0;
    bool _manejaInventario=true; bool _isActive=true; bool _eCodigo,_eNombre;

    protected override async Task OnInitializedAsync()
    {
        var (zd,_) = await ZonaSvc.GetPagedAsync(new FiltroZonaRequest { PageSize=500, IsActive=true });
        _zonas = zd?.Items ?? [];
        await Cargar();
    }

    async Task Cargar() { _loading=true; var(d,e)=await SucSvc.GetPagedAsync(_f); _loading=false; if(e!=null)_alerta?.MostrarError(e); else _paged=d; }
    async Task OnPage(int p)       { _f.Page=p; await Cargar(); }
    async Task OnSearch(string? s) { _f.Search=s; _f.Page=1; await Cargar(); }

    void AbrirNuevo()  { _edit=false; _codigo=""; _nombre=""; _idZona=0; _manejaInventario=true; _eCodigo=_eNombre=false; _panel?.Abrir(); }
    void AbrirEditar(SucursalResponse x)
    {
        _edit=true; _id=x.IdSucursal; _codigo=x.Codigo; _nombre=x.Nombre;
        _idZona=x.IdZona??0; _isActive=x.IsActive; _eCodigo=_eNombre=false; _panel?.Abrir();
    }

    async Task Guardar()
    {
        _eCodigo=string.IsNullOrWhiteSpace(_codigo); _eNombre=string.IsNullOrWhiteSpace(_nombre);
        if(_eCodigo||_eNombre){_panel?.MostrarError("Corrija los campos marcados.");return;}
        if(_edit)
        {
            var(_,e)=await SucSvc.ActualizarAsync(_id,new ActualizarSucursalRequest
            { IdSucursal=_id,Codigo=_codigo.ToUpper(),Nombre=_nombre,
              IdZona=_idZona>0?_idZona:null,ManejaInventario=_manejaInventario,IsActive=_isActive });
            if(e!=null){_panel?.MostrarError(e);return;}
        }
        else
        {
            var(_,e)=await SucSvc.CrearAsync(new CrearSucursalRequest
            { Codigo=_codigo.ToUpper(),Nombre=_nombre,
              IdZona=_idZona>0?_idZona:null,ManejaInventario=_manejaInventario });
            if(e!=null){_panel?.MostrarError(e);return;}
        }
        _panel?.MostrarExitoYCerrar(_edit?"Sucursal actualizada.":"Sucursal creada."); await Cargar();
    }

    async Task Eliminar(SucursalResponse x)
    {
        if(!await _confirm!.ConfirmarEliminarAsync("sucursal"))return;
        var(_,e)=await SucSvc.EliminarAsync(x.IdSucursal);
        if(e!=null)_alerta?.MostrarError(e); else{_alerta?.MostrarExito("Sucursal eliminada.");await Cargar();}
    }
}
