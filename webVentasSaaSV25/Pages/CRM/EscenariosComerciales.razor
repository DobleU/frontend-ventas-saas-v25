@page "/crm/escenarios-comerciales"
@page "/route/escenarios-comerciales"
@using webVentasSaaSV25.Services.Crm
@using webVentasSaaSV25.Services.Catalogos
@inject CrmWebService Crm
@inject CatalogoTipoService CatalogoTipos
@inject CatalogoItemService CatalogoItems

<section class="crm-page">
    <div class="crm-head">
        <div>
            <span class="crm-kicker"><span class="material-icons-outlined">forum</span> CRM</span>
            <h1>Escenarios Comerciales</h1>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" @onclick="Cargar"><span class="material-icons-outlined">refresh</span></button>
            <button class="btn btn-primary btn-sm" @onclick="AbrirNuevo"><span class="material-icons-outlined">add</span>Nuevo</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger py-2">@error</div>
    }

    <div class="esc-layout">
        <div class="crm-panel">
            <div class="crm-toolbar">
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><span class="material-icons-outlined">search</span></span>
                    <input class="form-control" placeholder="Buscar escenario, objetivo, situacion o respuesta" @bind="search" @bind:event="oninput" />
                </div>
                <label class="form-check form-switch m-0">
                    <input class="form-check-input" type="checkbox" @bind="soloAprobados" @bind:after="Cargar" />
                    <span class="form-check-label">Publicados</span>
                </label>
            </div>
            <div class="esc-list">
                @foreach (var e in Filtrados)
                {
                    <button class="esc-row @(seleccion?.id_escenario == e.id_escenario ? "active" : "")" @onclick="() => Seleccionar(e)">
                        <span>
                            <strong>@e.nombre</strong>
                            <small>@(e.situacion_cliente ?? e.objetivo ?? e.descripcion ?? "-")</small>
                        </span>
                        <span class="row-meta">
                            <span class="crm-badge">P @e.prioridad</span>
                            <span class="crm-status @(e.aprobado ? "ok" : "warn")">@(e.aprobado ? "Publicado" : "Borrador")</span>
                        </span>
                    </button>
                }
            </div>
        </div>

        <div class="crm-panel detail-panel">
            @if (detalle?.Escenario is null)
            {
                <div class="empty-state"><span class="material-icons-outlined">forum</span><strong>Selecciona un escenario</strong></div>
            }
            else
            {
                <div class="detail-title">
                    <div>
                        <h2>@detalle.Escenario.nombre</h2>
                        <span>@(detalle.Escenario.objetivo ?? "Sin objetivo")</span>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-primary btn-sm" @onclick="AbrirEditar">
                            <span class="material-icons-outlined">edit</span>
                            Editar
                        </button>
                        <button class="btn btn-outline-success btn-sm" @onclick="() => Aprobar(detalle.Escenario.id_escenario, !detalle.Escenario.aprobado)">
                            <span class="material-icons-outlined">published_with_changes</span>
                            @(detalle.Escenario.aprobado ? "Despublicar" : "Publicar")
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => Activar(detalle.Escenario.id_escenario, !detalle.Escenario.is_active)">
                            <span class="material-icons-outlined">power_settings_new</span>
                        </button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Eliminar(detalle.Escenario)">
                            <span class="material-icons-outlined">delete</span>
                        </button>
                    </div>
                </div>
                <p class="desc">@detalle.Escenario.descripcion</p>
                <div class="tag-wrap">
                    @foreach (var t in detalle.Tags)
                    {
                        <span class="crm-badge">@(t.tag ?? $"Tag {t.id_tag_item}") - @t.peso</span>
                    }
                    @foreach (var tn in detalle.TiposNegocio)
                    {
                        <span class="crm-badge">@(tn.tipo_negocio ?? $"Tipo {tn.id_tipo_negocio_item}")</span>
                    }
                </div>
                <h3>Respuestas para vendedor</h3>
                @foreach (var r in detalle.Respuestas.OrderBy(r => r.orden))
                {
                    <article class="respuesta">
                        <div>
                            <strong>@r.titulo</strong>
                            <span>@(r.tono ?? "Sin tono")</span>
                        </div>
                        <p>@r.texto_respuesta</p>
                    </article>
                }
            }
        </div>

        <AppModal @ref="modalEscenario" Titulo="Escenario comercial" Icono="forum" Tamanio="lg" Scrollable="true" CerrarAlFondo="false">
        <Cuerpo>
        <EditForm Model="form" OnValidSubmit="Guardar" class="crm-modal-form">
            <DataAnnotationsValidator />
            <h2>@(form.IdEscenario is null ? "Nuevo escenario" : "Editar escenario")</h2>
            <label>Codigo</label>
            <InputText class="form-control form-control-sm" @bind-Value="form.Codigo" />
            <label>Nombre</label>
            <InputText class="form-control form-control-sm" @bind-Value="form.Nombre" />
            <label>Situacion cliente</label>
            <InputTextArea class="form-control form-control-sm" rows="2" @bind-Value="form.SituacionCliente" />
            <label>Objetivo</label>
            <InputTextArea class="form-control form-control-sm" rows="2" @bind-Value="form.Objetivo" />
            <label>Descripcion</label>
            <InputTextArea class="form-control form-control-sm" rows="2" @bind-Value="form.Descripcion" />
            <div class="row g-2">
                <div class="col-6">
                    <label>Etapa comercial</label>
                    <InputSelect class="form-select form-select-sm" @bind-Value="form.IdEtapaComercialItem">
                        <option value="">Seleccionar</option>
                        @foreach (var item in etapaItems)
                        {
                            <option value="@item.IdCatalogoItem">@item.Nombre</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-6">
                    <label>Tono sugerido</label>
                    <InputSelect class="form-select form-select-sm" @bind-Value="form.IdTonoSugeridoItem">
                        <option value="">Seleccionar</option>
                        @foreach (var item in tonoItems)
                        {
                            <option value="@item.IdCatalogoItem">@item.Nombre</option>
                        }
                    </InputSelect>
                </div>
            </div>
            <div class="row g-2 mt-1">
                <div class="col-6">
                    <label>Prioridad</label>
                    <InputNumber class="form-control form-control-sm" @bind-Value="form.Prioridad" />
                </div>
                <div class="col-6">
                    <label>Estado</label>
                    <InputSelect class="form-select form-select-sm" @bind-Value="form.Aprobado">
                        <option value="false">Borrador</option>
                        <option value="true">Publicado</option>
                    </InputSelect>
                </div>
            </div>

            <div class="crm-form-section">
                <div class="section-title">
                    <strong>Tipos de negocio</strong>
                    <div class="d-flex gap-2">
                        <InputSelect class="form-select form-select-sm" @bind-Value="tipoNegocioAgregarId">
                            <option value="">Tipo</option>
                            @foreach (var item in tipoNegocioItems)
                            {
                                <option value="@item.IdCatalogoItem">@item.Nombre</option>
                            }
                        </InputSelect>
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AgregarTipoNegocio">Agregar</button>
                    </div>
                </div>
                <div class="chip-list">
                    @foreach (var item in form.TiposNegocio)
                    {
                        <span class="edit-chip">
                            @NombreItem(tipoNegocioItems, item.id_tipo_negocio_item)
                            <InputNumber class="chip-input" @bind-Value="item.peso" />
                            <button type="button" @onclick="() => QuitarTipoNegocio(item)">x</button>
                        </span>
                    }
                </div>
            </div>

            <div class="crm-form-section">
                <div class="section-title">
                    <strong>Tags comerciales</strong>
                    <div class="d-flex gap-2">
                        <InputSelect class="form-select form-select-sm" @bind-Value="tagAgregarId">
                            <option value="">Tag</option>
                            @foreach (var item in tagItems)
                            {
                                <option value="@item.IdCatalogoItem">@item.Nombre</option>
                            }
                        </InputSelect>
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AgregarTag">Agregar</button>
                    </div>
                </div>
                <div class="chip-list">
                    @foreach (var item in form.Tags)
                    {
                        <span class="edit-chip">
                            @NombreItem(tagItems, item.id_tag_item)
                            <InputNumber class="chip-input" @bind-Value="item.peso" />
                            <label class="chip-check"><InputCheckbox @bind-Value="item.es_tag_requerido" /> Req.</label>
                            <button type="button" @onclick="() => QuitarTag(item)">x</button>
                        </span>
                    }
                </div>
            </div>

            <div class="crm-form-section">
                <div class="section-title">
                    <strong>Respuestas</strong>
                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AgregarRespuesta">Agregar respuesta</button>
                </div>
                @foreach (var r in form.Respuestas)
                {
                    <div class="respuesta-editor">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label>Titulo</label>
                                <InputText class="form-control form-control-sm" @bind-Value="r.titulo" />
                            </div>
                            <div class="col-md-3">
                                <label>Tono</label>
                                <InputSelect class="form-select form-select-sm" @bind-Value="r.id_tono_item">
                                    <option value="">Seleccionar</option>
                                    @foreach (var item in tonoItems)
                                    {
                                        <option value="@item.IdCatalogoItem">@item.Nombre</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-3">
                                <label>Orden</label>
                                <InputNumber class="form-control form-control-sm" @bind-Value="r.orden" />
                            </div>
                        </div>
                        <label>Texto respuesta</label>
                        <InputTextArea class="form-control form-control-sm" rows="3" @bind-Value="r.texto_respuesta" />
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <label class="form-check m-0"><InputCheckbox class="form-check-input" @bind-Value="r.es_principal" /> Principal</label>
                            <label class="form-check m-0"><InputCheckbox class="form-check-input" @bind-Value="r.permite_reproducir" /> Reproducir</label>
                            <label class="form-check m-0"><InputCheckbox class="form-check-input" @bind-Value="r.aprobado" /> Aprobada</label>
                            <button type="button" class="btn btn-outline-danger btn-sm ms-auto" @onclick="() => QuitarRespuesta(r)">Quitar</button>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="LimpiarModal">Limpiar</button>
                <button type="submit" class="btn btn-primary btn-sm"><span class="material-icons-outlined">save</span>Guardar</button>
            </div>
        </EditForm>
        </Cuerpo>
        </AppModal>
    </div>
</section>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;
    private string? error;
    private string search = string.Empty;
    private bool soloAprobados;
    private List<CrmEscenarioListItemResponse> escenarios = [];
    private CrmEscenarioListItemResponse? seleccion;
    private CrmEscenarioDetalleResponse? detalle;
    private CrmEscenarioGuardarRequest form = new() { AplicaGlobal = true };
    private AppModal? modalEscenario;
    private List<CatalogoItemResponse> etapaItems = [];
    private List<CatalogoItemResponse> tonoItems = [];
    private List<CatalogoItemResponse> tagItems = [];
    private List<CatalogoItemResponse> tipoNegocioItems = [];
    private int? tipoNegocioAgregarId;
    private int? tagAgregarId;

    private List<CrmEscenarioListItemResponse> Filtrados => escenarios
        .Where(e => string.IsNullOrWhiteSpace(search) || $"{e.nombre} {e.objetivo} {e.situacion_cliente} {e.descripcion}".Contains(search, StringComparison.OrdinalIgnoreCase))
        .OrderBy(e => e.prioridad)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await CargarCatalogos();
        await Cargar();
    }

    private async Task CargarCatalogos()
    {
        etapaItems = await GetItemsCatalogoAsync("CRM_ETAPA_COMERCIAL");
        tonoItems = await GetItemsCatalogoAsync("CRM_TONO_COMERCIAL");
        tagItems = await GetItemsCatalogoAsync("CRM_TAG_COMERCIAL");
        tipoNegocioItems = await GetItemsCatalogoAsync("CRM_TIPO_NEGOCIO");
    }

    private async Task<List<CatalogoItemResponse>> GetItemsCatalogoAsync(string codigo)
    {
        var (tipos, _) = await CatalogoTipos.GetPagedAsync(new FiltroCatalogoTipoRequest { Search = codigo, IsActive = true, PageSize = 20 });
        var tipo = tipos?.Items.FirstOrDefault(t => string.Equals(t.Codigo, codigo, StringComparison.OrdinalIgnoreCase));
        if (tipo is null) return [];
        var (items, _) = await CatalogoItems.GetByTipoAsync(tipo.IdTipoCatalogo);
        return items?.Items.Where(i => i.IsActive).OrderBy(i => i.Orden ?? 0).ThenBy(i => i.Nombre).ToList() ?? [];
    }

    private async Task Cargar()
    {
        error = null;
        var (d, e) = await Crm.GetEscenariosAsync(soloAprobados: soloAprobados);
        error = e;
        escenarios = d ?? [];
        if (seleccion is null && escenarios.Count > 0) await Seleccionar(escenarios[0]);
    }

    private async Task Seleccionar(CrmEscenarioListItemResponse e)
    {
        seleccion = e;
        var (d, err) = await Crm.GetEscenarioAsync(e.id_escenario);
        error = err;
        detalle = d;
        form = new()
        {
            IdEscenario = e.id_escenario,
            Codigo = e.codigo,
            Nombre = e.nombre,
            Descripcion = e.descripcion,
            SituacionCliente = e.situacion_cliente,
            Objetivo = e.objetivo ?? string.Empty,
            IdEtapaComercialItem = e.id_etapa_comercial_item,
            IdTonoSugeridoItem = e.id_tono_sugerido_item,
            Prioridad = e.prioridad,
            AplicaGlobal = e.aplica_global,
            Aprobado = e.aprobado,
            IsActive = e.is_active,
            TiposNegocio = detalle?.TiposNegocio.Select(x => new CrmEscenarioTipoNegocioRequest { id_tipo_negocio_item = x.id_tipo_negocio_item, peso = x.peso }).ToList() ?? [],
            Tags = detalle?.Tags.Select(x => new CrmEscenarioTagRequest { id_tag_item = x.id_tag_item, peso = x.peso, es_tag_requerido = x.es_tag_requerido }).ToList() ?? [],
            Respuestas = detalle?.Respuestas.OrderBy(x => x.orden).Select(x => new CrmEscenarioRespuestaRequest
            {
                id_respuesta = x.id_respuesta,
                titulo = x.titulo,
                texto_respuesta = x.texto_respuesta,
                id_tono_item = x.id_tono_item,
                orden = x.orden,
                es_principal = x.es_principal,
                permite_reproducir = x.permite_reproducir,
                aprobado = x.aprobado
            }).ToList() ?? []
        };
        if (form.Respuestas.Count == 0) AgregarRespuesta();
    }

    private void Nuevo()
    {
        seleccion = null;
        detalle = null;
        LimpiarModal();
    }

    private void LimpiarModal()
    {
        form = new() { AplicaGlobal = true, IsActive = true, Prioridad = 100 };
        tipoNegocioAgregarId = null;
        tagAgregarId = null;
        AgregarRespuesta();
    }

    private void AbrirNuevo()
    {
        Nuevo();
        modalEscenario?.Abrir();
    }

    private void AbrirEditar()
    {
        if (detalle?.Escenario is not null)
            modalEscenario?.Abrir();
    }

    private async Task Guardar()
    {
        form.Respuestas = form.Respuestas
            .Where(r => !string.IsNullOrWhiteSpace(r.titulo) && !string.IsNullOrWhiteSpace(r.texto_respuesta))
            .OrderBy(r => r.orden)
            .ToList();
        var (_, e) = form.IdEscenario is long id
            ? await Crm.ActualizarEscenarioAsync(id, form)
            : await Crm.CrearEscenarioAsync(form);
        error = e;
        if (e is null) { modalEscenario?.Cerrar(); await Cargar(); }
    }

    private async Task Aprobar(long id, bool aprobado) { var (_, e) = await Crm.AprobarEscenarioAsync(id, aprobado); error = e; await Cargar(); if (seleccion is not null) await Seleccionar(seleccion); }
    private async Task Activar(long id, bool activo) { var (_, e) = await Crm.ActivarEscenarioAsync(id, activo); error = e; await Cargar(); if (seleccion is not null) await Seleccionar(seleccion); }
    private async Task Eliminar(CrmEscenarioListItemResponse e)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Eliminar escenario '{e.nombre}'?")) return;
        var (_, err) = await Crm.EliminarEscenarioAsync(e.id_escenario);
        error = err;
        seleccion = null;
        detalle = null;
        await Cargar();
    }

    private void AgregarTipoNegocio()
    {
        if (tipoNegocioAgregarId is not int id || form.TiposNegocio.Any(x => x.id_tipo_negocio_item == id)) return;
        form.TiposNegocio.Add(new() { id_tipo_negocio_item = id, peso = 10 });
        tipoNegocioAgregarId = null;
    }

    private void QuitarTipoNegocio(CrmEscenarioTipoNegocioRequest item) => form.TiposNegocio.Remove(item);

    private void AgregarTag()
    {
        if (tagAgregarId is not int id || form.Tags.Any(x => x.id_tag_item == id)) return;
        form.Tags.Add(new() { id_tag_item = id, peso = 10 });
        tagAgregarId = null;
    }

    private void QuitarTag(CrmEscenarioTagRequest item) => form.Tags.Remove(item);

    private void AgregarRespuesta()
    {
        form.Respuestas.Add(new()
        {
            titulo = form.Respuestas.Count == 0 ? "Respuesta principal" : $"Respuesta {form.Respuestas.Count + 1}",
            orden = form.Respuestas.Count + 1,
            es_principal = form.Respuestas.Count == 0,
            permite_reproducir = true,
            aprobado = form.Aprobado
        });
    }

    private void QuitarRespuesta(CrmEscenarioRespuestaRequest item)
    {
        form.Respuestas.Remove(item);
        var orden = 1;
        foreach (var respuesta in form.Respuestas.OrderBy(r => r.orden))
        {
            respuesta.orden = orden++;
        }
    }

    private static string NombreItem(List<CatalogoItemResponse> items, int id)
        => items.FirstOrDefault(i => i.IdCatalogoItem == id)?.Nombre ?? $"Item {id}";
}

<style>
