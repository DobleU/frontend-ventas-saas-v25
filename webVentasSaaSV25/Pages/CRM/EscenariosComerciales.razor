;padding-top:.85rem}.section-title{display:flex;align-items:center;justify-content:space-between;gap:.75rem}.section-title .form-select{min-width:220px}.edit-chip{display:inline-flex;align-items:center;gap:.35rem;border:1px solid #d0d5dd;border-radius:999px;padding:.2rem .45rem;background:#fff;font-size:.8rem}.edit-chip button{border:0;background:transparent;color:#b42318}.chip-input{width:58px;border:1px solid #d0d5dd;border-radius:6px;padding:.1rem .25rem}.chip-check{display:inline-flex;align-items:center;gap:.2rem;margin:0!important}.empty-state{min-height:260px;display:grid;place-items:center;text-align:center;color:#667085}.empty-state .material-icons-outlined{font-size:2.5rem}.material-icons-outlined{font-size:1.1rem;vertical-align:middle}@@media (max-width: 992px){.esc-layout{grid-template-columns:1fr}.crm-toolbar,.section-title{align-items:stretch;flex-direction:column}.section-title .form-select{min-width:0}}
</style>
