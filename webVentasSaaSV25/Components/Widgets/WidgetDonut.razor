@* Components/Widgets/WidgetDonut.razor — VentasSaaSDU
   Widget de gráfica de dona/pie con leyenda de series al pie.
   Para distribución de ventas, estados de pedidos, inventario por categoría.

   <WidgetDonut Titulo="Estado de Pedidos"
                IdChart="chart-pedidos"
                ValorCentro="68%"
                EtiquetaCentro="Total Ventas">
       <Leyenda>
           <div class="d-flex align-items-center justify-content-between">
               <p class="mb-0 d-flex align-items-center gap-2 w-25">
                   <span class="material-icons-outlined fs-6 text-primary">fiber_manual_record</span>
                   Ventas
               </p>
               <p class="mb-0">68%</p>
           </div>
           <div class="d-flex align-items-center justify-content-between">
               <p class="mb-0 d-flex align-items-center gap-2 w-25">
                   <span class="material-icons-outlined fs-6 text-danger">fiber_manual_record</span>
                   Productos
               </p>
               <p class="mb-0">25%</p>
           </div>
       </Leyenda>
   </WidgetDonut>
*@

<div class="card w-100 rounded-4 h-100">
    <div class="card-body">

        @* Header *@
        <div class="d-flex align-items-start justify-content-between mb-3">
            <h5 class="mb-0">@Titulo</h5>
            <div class="dropdown">
                <a href="javascript:;" class="dropdown-toggle-nocaret options dropdown-toggle"
                   onclick="GridMenu.toggle(this)">
                    <span class="material-icons-outlined fs-5">more_vert</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end grid-action-menu">
                    @if (Opciones != null)
                    {
                        @Opciones
                    }
                    else
                    {
                        <li><a class="dropdown-item" href="javascript:;">Ver detalle</a></li>
                        <li><a class="dropdown-item" href="javascript:;">Exportar</a></li>
                    }
                </ul>
            </div>
        </div>

        @* Dona con valor central *@
        <div class="position-relative">
            @if (!string.IsNullOrEmpty(ValorCentro))
            {
                <div class="piechart-legend">
                    <h2 class="mb-1">@ValorCentro</h2>
                    @if (!string.IsNullOrEmpty(EtiquetaCentro))
                    {
                        <h6 class="mb-0 font-text1 text-secondary">@EtiquetaCentro</h6>
                    }
                </div>
            }
            @if (!string.IsNullOrEmpty(IdChart))
            {
                <div id="@IdChart" style="min-height:@AlturaChart;"></div>
            }
            @GraficaSlot
        </div>

        @* Leyenda de series *@
        @if (Leyenda != null)
        {
            <div class="d-flex flex-column gap-3 mt-3">
                @Leyenda
            </div>
        }

    </div>
</div>

@code {
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public string IdChart { get; set; } = string.Empty;
    [Parameter] public string AlturaChart { get; set; } = "270px";
    [Parameter] public string ValorCentro { get; set; } = string.Empty;
    [Parameter] public string EtiquetaCentro { get; set; } = string.Empty;
    [Parameter] public RenderFragment? GraficaSlot { get; set; }
    [Parameter] public RenderFragment? Leyenda { get; set; }
    [Parameter] public RenderFragment? Opciones { get; set; }
}
