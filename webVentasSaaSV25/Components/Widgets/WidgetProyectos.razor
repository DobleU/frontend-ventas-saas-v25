@* Components/Widgets/WidgetProyectos.razor — VentasSaaSDU
   Lista de ítems con imagen cuadrada + nombre + descripción + barra de progreso + %.
   Uso: proyectos en curso, tareas pendientes, vendedores con cuota, rutas con avance.

   <WidgetProyectos Titulo="Avance por Vendedor">
       <Items>
           @foreach (var v in _vendedores)
           {
               <WidgetItemProgreso Imagen="@v.AvatarUrl"
                                   Titulo="@v.Nombre"
                                   Subtitulo="@v.Sucursal"
                                   Porcentaje="@v.PorcentajeCuota"
                                   ColorBarra="danger" />
           }
       </Items>
   </WidgetProyectos>
*@

<div class="card w-100 rounded-4 h-100">
    <div class="card-body">

        @* Header *@
        <div class="d-flex align-items-start justify-content-between mb-3">
            <h5 class="mb-0 fw-bold">@Titulo</h5>
            <div class="dropdown">
                <a href="javascript:;" class="dropdown-toggle-nocaret options dropdown-toggle"
                   onclick="GridMenu.toggle(this)">
                    <span class="material-icons-outlined fs-5">more_vert</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end grid-action-menu">
                    @if (Opciones != null)
                    {
                        @Opciones
                    }
                    else
                    {
                        <li><a class="dropdown-item" href="javascript:;">Ver todo</a></li>
                        <li><a class="dropdown-item" href="javascript:;">Exportar</a></li>
                    }
                </ul>
            </div>
        </div>

        @* Lista *@
        <div class="d-flex flex-column gap-4">
            @Items
        </div>

    </div>
</div>

@code {
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public RenderFragment? Items { get; set; }
    [Parameter] public RenderFragment? Opciones { get; set; }
}
