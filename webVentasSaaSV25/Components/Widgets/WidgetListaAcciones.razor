@* Components/Widgets/WidgetListaAcciones.razor — VentasSaaSDU
   Lista tipo list-group con ícono cuadrado gradiente + nombre + valor + porcentaje coloreado.
   Uso: Campaign Stats, métricas por acción, KPIs operativos por categoría.

   <WidgetListaAcciones Titulo="Estadísticas de Operación">
       <Items>
           <WidgetItemAccion Icono="point_of_sale"  Gradiente="primary"    Nombre="Ventas tienda"  Valor="1,248" Porcentaje="28%"  PorcentajePositivo="true"  />
           <WidgetItemAccion Icono="route"           Gradiente="success"    Nombre="Ventas ruta"    Valor="845"   Porcentaje="15%"  PorcentajePositivo="true"  />
           <WidgetItemAccion Icono="inventory"       Gradiente="info"       Nombre="Entradas inv."  Valor="320"   Porcentaje="30%"  PorcentajePositivo="true"  />
           <WidgetItemAccion Icono="output"          Gradiente="branding"   Nombre="Salidas inv."   Valor="198"   Porcentaje="12%"  PorcentajePositivo="false" />
           <WidgetItemAccion Icono="people"          Gradiente="warning"    Nombre="Clientes nvo."  Valor="54"    Porcentaje="8.5%" PorcentajePositivo="true"  />
           <WidgetItemAccion Icono="warning_amber"   Gradiente="danger"     Nombre="Devoluciones"   Valor="12"    Porcentaje="3.2%" PorcentajePositivo="false" />
       </Items>
   </WidgetListaAcciones>
*@

<div class="card w-100 rounded-4 h-100">
    <div class="card-body">

        @* Header *@
        <div class="d-flex align-items-start justify-content-between mb-3">
            <h6 class="mb-0 fw-bold">@Titulo</h6>
            <div class="dropdown">
                <a href="javascript:;" class="dropdown-toggle-nocaret options dropdown-toggle"
                   onclick="GridMenu.toggle(this)">
                    <span class="material-icons-outlined fs-5">more_vert</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end grid-action-menu">
                    @if (Opciones != null)
                    {
                        @Opciones
                    }
                    else
                    {
                        <li><a class="dropdown-item" href="javascript:;">Ver todo</a></li>
                        <li><a class="dropdown-item" href="javascript:;">Exportar</a></li>
                    }
                </ul>
            </div>
        </div>

        @* Lista *@
        <ul class="list-group list-group-flush">
            @Items
        </ul>

    </div>
</div>

@code {
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public RenderFragment? Items { get; set; }
    [Parameter] public RenderFragment? Opciones { get; set; }
}
