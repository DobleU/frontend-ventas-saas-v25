@* Components/Widgets/WidgetListaItems.razor — VentasSaaSDU
   Lista vertical de ítems con imagen o ícono + título + subtítulo + valor/tendencia.
   Cubre: Productos populares, Transacciones recientes, Ingresos/Gastos, Ventas por país.

   VARIANTE PRODUCTO (imagen + nombre + subtítulo + precio):
   <WidgetListaItems Titulo="Top Productos">
       <Items>
           @foreach (var p in _productos)
           {
               <WidgetItemLista Imagen="@p.ImagenUrl" Titulo="@p.Nombre"
                                Subtitulo="@($"Ventas: {p.Ventas}")" Valor="@p.Precio" />
           }
       </Items>
   </WidgetListaItems>

   VARIANTE TRANSACCIÓN (ícono con color + nombre + fecha + monto):
   <WidgetListaItems Titulo="Transacciones recientes">
       <Items>
           <WidgetItemLista Icono="shopping_cart" ColorIcono="danger"
                            Titulo="Venta mostrador" Subtitulo="12/Apr 10:30"
                            Valor="$1,250" />
       </Items>
   </WidgetListaItems>
*@

<div class="card w-100 rounded-4 h-100">

    @* Header *@
    <div class="card-header p-3 bg-transparent border-bottom-0">
        <div class="d-flex align-items-center justify-content-between">
            <h5 class="mb-0">@Titulo</h5>
            <div class="dropdown">
                <a href="javascript:;" class="dropdown-toggle-nocaret options dropdown-toggle"
                   onclick="GridMenu.toggle(this)">
                    <span class="material-icons-outlined fs-5">more_vert</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end grid-action-menu">
                    @if (Opciones != null)
                    {
                        @Opciones
                    }
                    else
                    {
                        <li><a class="dropdown-item" href="javascript:;">Ver todo</a></li>
                        <li><a class="dropdown-item" href="javascript:;">Exportar</a></li>
                    }
                </ul>
            </div>
        </div>
    </div>

    @* Body *@
    <div class="card-body pt-0">
        <div class="d-flex flex-column gap-4">
            @Items
        </div>
    </div>

    @* Footer opcional *@
    @if (Footer != null)
    {
        <div class="card-footer bg-transparent p-3">
            @Footer
        </div>
    }

</div>

@code {
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public RenderFragment? Items { get; set; }
    [Parameter] public RenderFragment? Opciones { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
}
