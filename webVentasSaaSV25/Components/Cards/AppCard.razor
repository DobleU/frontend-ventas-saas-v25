@* Components/Cards/AppCard.razor — VentasSaaSDU
   Card básica del template Maxton.

   VARIANTES:
   ─────────────────────────────────────────────────────
   1) Imagen arriba + contenido:
      <AppCard ImagenTop="assets/images/..." Titulo="Título" Texto="Descripción..." />

   2) Imagen en body (más grande) + botón:
      <AppCard ImagenBody="assets/images/..." Titulo="Título" Texto="..."
               TextoBoton="Agregar" TipoBoton="primary" OnAccion="..." />

   3) Solo contenido (sin imagen):
      <AppCard Titulo="Título" Texto="Descripción">
          <ContenidoExtra>
              <p>HTML adicional aquí</p>
          </ContenidoExtra>
      </AppCard>

   4) Redondeada (rounded-4):
      <AppCard ImagenTop="..." Titulo="..." Redondeada="true" />
   ─────────────────────────────────────────────────────
*@

<div class="card @(Redondeada ? "rounded-4" : "") @Clase">

    @* Imagen arriba *@
    @if (!string.IsNullOrEmpty(ImagenTop))
    {
        <img src="@ImagenTop" class="card-img-top" alt="@AltImagen" />
    }

    <div class="card-body @(string.IsNullOrEmpty(ImagenTop) && !string.IsNullOrEmpty(ImagenBody) ? "pt-0" : "")">

        @* Imagen en body *@
        @if (!string.IsNullOrEmpty(ImagenBody))
        {
            <img src="@ImagenBody" class="w-100 mb-4 rounded" alt="@AltImagen" />
        }

        @* Título *@
        @if (!string.IsNullOrEmpty(Titulo))
        {
            <h5 class="card-title @(!string.IsNullOrEmpty(TextoBoton) ? "mb-4" : "")">@Titulo</h5>
        }

        @* Texto *@
        @if (!string.IsNullOrEmpty(Texto))
        {
            <p class="card-text @(!string.IsNullOrEmpty(TextoBoton) ? "mb-4" : "")">@Texto</p>
        }

        @* Contenido extra (slot) *@
        @ContenidoExtra

        @* Botón de acción *@
        @if (!string.IsNullOrEmpty(TextoBoton))
        {
            <button class="btn btn-grd btn-grd-@TipoBoton w-100 raised border-0" @onclick="OnAccion">
                @TextoBoton
            </button>
        }

    </div>
</div>

@code {
    [Parameter] public string ImagenTop { get; set; } = string.Empty;
    [Parameter] public string ImagenBody { get; set; } = string.Empty;
    [Parameter] public string AltImagen { get; set; } = string.Empty;
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public string Texto { get; set; } = string.Empty;
    [Parameter] public string TextoBoton { get; set; } = string.Empty;
    /// <summary>primary | danger | success | warning | info</summary>
    [Parameter] public string TipoBoton { get; set; } = "primary";
    [Parameter] public bool Redondeada { get; set; } = false;
    [Parameter] public string Clase { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ContenidoExtra { get; set; }
    [Parameter] public EventCallback OnAccion { get; set; }
}
